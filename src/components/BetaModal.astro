---

---

<div
    id="beta-modal"
    class="fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-gray-900/60 backdrop-blur-sm transition-all duration-300 opacity-0"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modal-title"
>
    <div
        id="beta-modal-content"
        class="bg-white rounded-2xl shadow-2xl max-w-md w-full overflow-hidden transform scale-95 transition-all duration-300"
    >
        <div class="px-6 py-8 text-center">
            <div
                class="inline-flex items-center justify-center w-16 h-16 bg-payflo-purple/10 text-payflo-purple rounded-full mb-6"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-8 h-8"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
            </div>

            <h2 id="modal-title" class="text-2xl font-bold text-gray-900 mb-4">
                We're in Beta!
            </h2>

            <p class="text-gray-600 mb-8">
                Thank you for your interest in <strong>Laravel Mail</strong>. We
                are currently in private beta, fine-tuning the platform for the
                best possible experience.
            </p>

            <div class="bg-gray-50 rounded-xl p-6 mb-8 text-left">
                <p
                    class="text-sm text-gray-500 mb-2 uppercase tracking-wide font-semibold"
                >
                    Want early access?
                </p>
                <p class="text-gray-700">
                    If you'd like to get access to a live version of the
                    platform, please get in contact with us:
                </p>
                <a
                    href="#"
                    id="contact-email-link"
                    class="mt-3 inline-flex items-center text-payflo-purple font-semibold hover:text-payflo-dark transition-colors"
                >
                    <span id="contact-email-text"></span>
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-4 w-4 ml-2"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                    </svg>
                </a>
            </div>

            <button
                id="close-beta-modal"
                class="w-full py-3 px-6 bg-payflo-dark text-white rounded-xl font-semibold hover:bg-gray-800 transition-all duration-300 shadow-lg shadow-gray-200"
            >
                Got it, thanks!
            </button>
        </div>
        <div
            class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 transition-colors"
        >
            <button id="close-beta-modal-x" aria-label="Close modal">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>
    </div>
</div>

<script>
    function trackBetaModalEvent(action: string, label: string) {
        if (typeof window !== "undefined") {
            try {
                // @ts-ignore
                if (typeof window.gtag !== "undefined") {
                    // @ts-ignore
                    window.gtag("event", action, {
                        event_category: "beta_modal",
                        event_label: label,
                    });
                } else if (typeof (window as any).dataLayer !== "undefined") {
                    // @ts-ignore
                    (window as any).dataLayer.push({
                        event: "beta_modal_event",
                        event_action: action,
                        event_category: "beta_modal",
                        event_label: label,
                    });
                }
                // Tracked: ${action} - ${label}
            } catch (e) {
                console.warn("Tracking error", e);
            }
        }
    }

    function setupBetaModal() {
        const modal = document.getElementById("beta-modal");
        const content = document.getElementById("beta-modal-content");
        const closeBtn = document.getElementById("close-beta-modal");
        const closeBtnX = document.getElementById("close-beta-modal-x");
        const triggerBtns = document.querySelectorAll(".trigger-beta-modal");

        const openModal = () => {
            modal?.classList.remove("hidden");
            modal?.classList.add("flex");
            // Force reflow
            void modal?.offsetWidth;
            modal?.classList.remove("opacity-0");
            modal?.classList.add("opacity-100");
            content?.classList.remove("scale-95");
            content?.classList.add("scale-100");
            document.body.style.overflow = "hidden";
            trackBetaModalEvent("open", "Beta Modal View");
        };

        const closeModal = (redirect = false) => {
            modal?.classList.remove("opacity-100");
            modal?.classList.add("opacity-0");
            content?.classList.remove("scale-100");
            content?.classList.add("scale-95");

            setTimeout(() => {
                modal?.classList.remove("flex");
                modal?.classList.add("hidden");
                document.body.style.overflow = "";
                if (redirect) {
                    window.location.href = "/buy";
                }
            }, 300);
        };

        triggerBtns.forEach((btn) => {
            btn.addEventListener("click", (e) => {
                e.preventDefault();
                openModal();
            });
        });

        closeBtn?.addEventListener("click", () => {
            trackBetaModalEvent("click_confirm", "Got it, thanks!");
            closeModal(true);
        });

        closeBtnX?.addEventListener("click", () => {
            trackBetaModalEvent("click_close", "X Button");
            closeModal();
        });

        modal?.addEventListener("click", (e) => {
            if (e.target === modal) {
                trackBetaModalEvent("click_outside", "Overlay Click");
                closeModal();
            }
        });
    }

    // Initialize on load and after view transitions
    document.addEventListener("astro:page-load", setupBetaModal);

    // Prevent Cloudflare email obfuscation by rendering email via JS
    (function() {
        const email = 'info' + '@' + 'laravelmail.com';
        const emailLink = document.getElementById('contact-email-link') as HTMLAnchorElement;
        const emailText = document.getElementById('contact-email-text');
        if (emailLink && emailText) {
            emailLink.href = 'mailto:' + email;
            emailText.textContent = email;
        }
    })();
</script>

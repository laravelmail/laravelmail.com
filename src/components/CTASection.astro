---

---

<section
  class="py-20 bg-gradient-to-r from-brand-primary to-brand-blue text-white relative overflow-hidden"
>
  <!-- Animated background elements -->
  <div class="absolute inset-0 overflow-hidden opacity-10">
    <div
      class="absolute -top-40 -left-40 w-80 h-80 bg-white rounded-full blur-3xl animate-pulse"
    >
    </div>
    <div
      class="absolute top-40 -right-20 w-60 h-60 bg-white rounded-full blur-3xl animate-pulse"
      style="animation-delay: 1s;"
    >
    </div>
    <div
      class="absolute -bottom-40 left-1/3 w-80 h-80 bg-white rounded-full blur-3xl animate-pulse"
      style="animation-delay: 2s;"
    >
    </div>
  </div>

  <div class="container-custom relative">
    <div class="max-w-3xl mx-auto text-center animate-on-scroll">
      <h2 class="text-3xl md:text-4xl font-bold" title="Laravel Mail">
        Enhance your marketing setup with your own email marketing platform.
      </h2>
      <p class="mt-6 text-xl opacity-90">
        Join the growing number of SaaS platforms using <strong
          >Laravel Mail</strong
        > to offer email marketing solutions to their customers.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row justify-center gap-4">
        <a
          title="self hosted email marketing platform"
          href="/buy"
          class="btn bg-white text-brand-primary hover:bg-opacity-90 transform transition-all duration-300 hover:scale-105 hover:shadow-lg"
        >
          Purchase Now - £40 Setup + £10/mo
        </a>
        <a
          href="https://github.com/laravelmail"
          target="_blank"
          rel="noopener noreferrer"
          class="btn border-2 border-white/30 text-white hover:bg-white/10 transform transition-all duration-300 hover:scale-105"
        >
          Star on GitHub
        </a>
      </div>
    </div>
  </div>
</section>

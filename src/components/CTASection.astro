---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { getRelativeLocaleUrl } from 'astro:i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-20 bg-gradient-to-r from-brand-primary to-brand-blue text-white relative">
  <div class="container-custom">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold" title="Laravel Mail">
        {t('cta.header_2')}
      </h2>
      <p class="mt-6 text-xl opacity-90">
        {t('cta.subtitle_2')}
      </p>
      <div class="mt-10 flex flex-col sm:flex-row justify-center gap-4">
        <a
          title="Get started with Laravel Mail"
          href={getRelativeLocaleUrl(lang, "/buy")}
          class="btn bg-white text-brand-primary hover:bg-opacity-90"
        >
          {t('buy.cta_button')}
        </a>
        <a
          title="Star Laravel Mail on GitHub - Open Source Email Marketing"
          href="https://github.com/laravelmail"
          target="_blank"
          rel="noopener noreferrer"
          class="btn border-2 border-white/30 text-white hover:bg-white/10"
        >
          {t('cta.star_github')}
        </a>
      </div>
    </div>
  </div>
</section>

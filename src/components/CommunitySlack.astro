---

---

<section class="py-24 relative overflow-hidden bg-[#0f172a]">
    <!-- Background Accents -->
    <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10 opacity-20 pointer-events-none"
    >
        <div
            class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] bg-[#4A154B]/30 blur-[120px] rounded-full"
        >
        </div>
        <div
            class="absolute bottom-[-20%] left-[-10%] w-[400px] h-[400px] bg-[#36C5F0]/20 blur-[120px] rounded-full"
        >
        </div>
    </div>

    <div class="container-custom">
        <div class="max-w-5xl mx-auto">
            <div
                class="bg-white/[0.03] backdrop-blur-2xl border border-white/10 rounded-[3rem] p-8 md:p-16 shadow-2xl relative overflow-hidden group"
            >
                <!-- Slack Logo Watermark -->
                <div
                    class="absolute -right-20 -bottom-20 opacity-[0.03] rotate-12 pointer-events-none transition-transform duration-700 group-hover:rotate-0"
                >
                    <svg
                        class="w-96 h-96"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                    >
                        <path
                            d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zM6.313 15.165a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52h-2.521zM8.834 6.313a2.527 2.527 0 0 1 2.521 2.521 2.527 2.527 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zM18.958 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 10.15a2.527 2.527 0 0 1-2.52 2.52h-2.522v-2.52zM17.687 8.834a2.527 2.527 0 0 1-2.521 2.521 2.527 2.527 0 0 1-2.521-2.521V2.522A2.527 2.527 0 0 1 15.166 0a2.528 2.528 0 0 1 2.521 2.522v6.312zM15.166 18.958a2.528 2.528 0 0 1 2.521 2.522 2.528 2.528 0 0 1-2.521 2.52A2.527 2.527 0 0 1 12.645 24a2.527 2.527 0 0 1-2.521-2.522v-2.52h2.522zM15.166 17.687a2.527 2.527 0 0 1-2.521-2.521 2.527 2.527 0 0 1 2.521-2.521h6.312A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.522h-6.312z"
                        ></path>
                    </svg>
                </div>

                <div
                    class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center relative z-10"
                >
                    <div>
                        <div
                            class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#4A154B]/20 border border-[#4A154B]/30 text-[#E01E5A] text-sm font-bold mb-6"
                        >
                            <span class="relative flex h-2 w-2">
                                <span
                                    class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#E01E5A] opacity-75"
                                ></span>
                                <span
                                    class="relative inline-flex rounded-full h-2 w-2 bg-[#E01E5A]"
                                ></span>
                            </span>
                            JOIN OUR COMMUNITY
                        </div>
                        <h2
                            class="text-4xl md:text-5xl font-black text-white mb-6 leading-tight"
                        >
                            Connect with <span class="text-brand-primary"
                                >Laravel Mail</span
                            > Developers
                        </h2>
                        <p class="text-xl text-white/70 mb-8 leading-relaxed">
                            Join our Slack workspace to get real-time support,
                            share your implementation, and stay updated with the
                            latest B2B leads and features.
                        </p>

                        <div class="flex flex-wrap gap-6">
                            <div class="flex items-center gap-3">
                                <div
                                    class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-xl"
                                >
                                    💬
                                </div>
                                <span class="text-white/80 font-medium"
                                    >Real-time Support</span
                                >
                            </div>
                            <div class="flex items-center gap-3">
                                <div
                                    class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-xl"
                                >
                                    💡
                                </div>
                                <span class="text-white/80 font-medium"
                                    >Feature Suggestions</span
                                >
                            </div>
                            <div class="flex items-center gap-3">
                                <div
                                    class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-xl"
                                >
                                    🤝
                                </div>
                                <span class="text-white/80 font-medium"
                                    >Networking</span
                                >
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col items-center lg:items-end">
                        <div
                            class="bg-white/5 border border-white/10 rounded-[2.5rem] p-8 md:p-10 w-full max-w-md relative"
                        >
                            <!-- Floating users decoration -->
                            <div
                                class="absolute -top-6 -right-6 flex -space-x-3"
                            >
                                <div
                                    class="w-12 h-12 rounded-full border-2 border-[#0f172a] bg-payflo-purple flex items-center justify-center text-sm font-bold"
                                >
                                    JD
                                </div>
                                <div
                                    class="w-12 h-12 rounded-full border-2 border-[#0f172a] bg-payflo-blue flex items-center justify-center text-sm font-bold"
                                >
                                    SM
                                </div>
                                <div
                                    class="w-12 h-12 rounded-full border-2 border-[#0f172a] bg-payflo-pink flex items-center justify-center text-sm font-bold"
                                >
                                    RC
                                </div>
                                <div
                                    class="w-12 h-12 rounded-full border-2 border-[#0f172a] bg-white/10 backdrop-blur-md flex items-center justify-center text-[10px] font-bold"
                                >
                                    +4.2k
                                </div>
                            </div>

                            <div class="text-center">
                                <div
                                    class="w-20 h-20 bg-white rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-xl shadow-white/5 transition-transform duration-500 hover:scale-110"
                                >
                                    <svg
                                        class="w-12 h-12 text-[#4A154B]"
                                        viewBox="0 0 24 24"
                                        fill="currentColor"
                                    >
                                        <path
                                            d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zM6.313 15.165a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52h-2.521zM8.834 6.313a2.527 2.527 0 0 1 2.521 2.521 2.527 2.527 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zM18.958 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 10.15a2.527 2.527 0 0 1-2.52 2.52h-2.522v-2.52zM17.687 8.834a2.527 2.527 0 0 1-2.521 2.521 2.527 2.527 0 0 1-2.521-2.521V2.522A2.527 2.527 0 0 1 15.166 0a2.528 2.528 0 0 1 2.521 2.522v6.312zM15.166 18.958a2.528 2.528 0 0 1 2.521 2.522 2.528 2.528 0 0 1-2.521 2.52A2.527 2.527 0 0 1 12.645 24a2.527 2.527 0 0 1-2.521-2.522v-2.52h2.522zM15.166 17.687a2.527 2.527 0 0 1-2.521-2.521 2.527 2.527 0 0 1 2.521-2.521h6.312A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.522h-6.312z"
                                        ></path>
                                    </svg>
                                </div>
                                <h3 class="text-2xl font-bold text-white mb-2">
                                    Join Slack Community
                                </h3>
                                <p class="text-white/60 text-sm mb-8">
                                    Get the link to join directly
                                </p>

                                <a
                                    href="https://join.slack.com/t/laravelmail/shared_invite/zt-2r6gsz5w7-W2cm_N2~AYrsv8UvBxRxSA"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="w-full inline-flex items-center justify-center gap-3 bg-[#4A154B] text-white font-bold py-5 px-8 rounded-2xl transition-all hover:bg-[#611f69] hover:shadow-2xl hover:scale-[1.02] active:scale-[0.98]"
                                    onclick="window.trackCommunityClick && window.trackCommunityClick('Slack', 'Join Button')"
                                >
                                    <span>Join Now</span>
                                    <svg
                                        class="w-5 h-5"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                                    </svg>
                                </a>

                                <p
                                    class="mt-6 text-[10px] text-white/40 uppercase tracking-widest font-bold"
                                >
                                    Instant Invite • 100% Free
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    declare global {
        interface Window {
            trackCommunityClick: (platform: string, label: string) => void;
        }
    }

    window.trackCommunityClick = function (platform, label) {
        if (typeof gtag !== "undefined") {
            gtag("event", "community_click", {
                platform: platform,
                label: label,
            });
        }
    };
</script>

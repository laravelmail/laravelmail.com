---
interface Feature {
    name: string;
    values: (string | boolean)[];
}

interface Column {
    label: string;
    highlight?: boolean;
}

interface Props {
    title?: string;
    description?: string;
    features: Feature[];
    columns: Column[];
}

const { title, description, features, columns }: Props = Astro.props;
---

<div class="comparison-table-wrapper my-12 overflow-x-auto">
    {title && (
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">{title}</h2>
    )}
    {description && (
        <p class="text-gray-400 mb-8">{description}</p>
    )}
    
    <table class="w-full min-w-[600px] border-collapse">
        <thead>
            <tr>
                <th class="text-left p-4 bg-brand-bg-card/40 border-b border-white/10 text-gray-400 font-semibold">
                    Feature
                </th>
                {columns.map((col: Column, index: number) => (
                    <th 
                        class={`text-center p-4 border-b border-white/10 font-semibold ${col.highlight ? 'bg-brand-primary/10 text-brand-primary' : 'bg-brand-bg-card/40 text-white'}`}
                    >
                        {col.label}
                    </th>
                ))}
            </tr>
        </thead>
        <tbody>
            {features.map((feature: Feature, featureIndex: number) => (
                <tr class={`${featureIndex % 2 === 0 ? 'bg-brand-bg-card/20' : 'bg-transparent'} hover:bg-white/5 transition-colors`}>
                    <td class="p-4 border-b border-white/5 text-gray-300 font-medium">
                        {feature.name}
                    </td>
                    {feature.values.map((value: string | boolean, colIndex: number) => (
                        <td 
                            class={`text-center p-4 border-b border-white/5 ${columns[colIndex].highlight ? 'bg-brand-primary/5' : ''}`}
                        >
                            {typeof value === 'boolean' ? (
                                value ? (
                                    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-brand-primary/20 text-brand-primary">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                        </svg>
                                    </span>
                                ) : (
                                    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-gray-500/20 text-gray-500">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                        </svg>
                                    </span>
                                )
                            ) : (
                                <span class="text-gray-300">{value}</span>
                            )}
                        </td>
                    ))}
                </tr>
            ))}
        </tbody>
    </table>
</div>

<style>
    .comparison-table-wrapper table {
        border-spacing: 0;
    }
    
    .comparison-table-wrapper th:first-child,
    .comparison-table-wrapper td:first-child {
        text-align: left;
        width: 40%;
    }
</style>
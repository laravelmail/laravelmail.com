---
// src/components/DataTransparency.astro
---

<section class="py-20 bg-brand-bg-darker/60 relative overflow-hidden">
    <div class="container-custom relative">
        <div class="max-w-4xl mx-auto">
            <div
                class="bg-gradient-to-br from-brand-primary/10 to-brand-blue/10 border border-white/10 rounded-3xl p-8 md:p-12 shadow-2xl backdrop-blur-md"
            >
                <div class="flex flex-col md:flex-row items-center gap-8">
                    <div class="flex-shrink-0">
                        <div
                            class="w-16 h-16 rounded-2xl bg-brand-primary/20 flex items-center justify-center"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-8 w-8 text-brand-primary"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                                ></path>
                            </svg>
                        </div>
                    </div>
                    <div>
                        <h2 class="text-3xl font-bold text-white mb-4">
                            Our Commitment to Transparency & Data Security
                        </h2>
                        <p class="text-lg text-gray-300 leading-relaxed mb-6">
                            At <strong>Laravel Mail</strong>, we believe in full
                            transparency regarding how we use your data. When
                            you connect your Google Workspace or Gmail account
                            via OAuth, we use those permissions exclusively to:
                        </p>
                        <ul
                            class="grid grid-cols-1 md:grid-cols-2 gap-4 text-gray-400"
                        >
                            <li class="flex items-start">
                                <span class="text-brand-primary mr-2">●</span>
                                Deliver your marketing campaigns through your own
                                verified domain.
                            </li>
                            <li class="flex items-start">
                                <span class="text-brand-primary mr-2">●</span>
                                Sync campaign performance data directly to your dashboard.
                            </li>
                            <li class="flex items-start">
                                <span class="text-brand-primary mr-2">●</span>
                                Manage your Google Workspace Marketplace application
                                listings.
                            </li>
                            <li class="flex items-start">
                                <span class="text-brand-primary mr-2">●</span>
                                Ensure high deliverability by using authenticated
                                email protocols.
                            </li>
                        </ul>
                        <div
                            class="mt-8 pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4"
                        >
                            <p class="text-sm text-gray-500 italic">
                                We never share your Google user data with third
                                parties for advertising or profiling.
                            </p>
                            <a
                                href="/privacy-policy"
                                class="text-brand-primary font-bold hover:underline inline-flex items-center"
                            >
                                Read our full Privacy Policy
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-4 w-4 ml-1"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 5l7 7-7 7"></path>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { getRelativeLocaleUrl } from "astro:i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const faqs = [
    {
        question: t('faq.q1'),
        answer: t('faq.a1'),
    },
    {
        question: t('faq.q2'),
        answer: t('faq.a2'),
    },
    {
        question: t('faq.q3'),
        answer: t('faq.a3'),
    },
    {
        question: t('faq.q4'),
        answer: t('faq.a4'),
    },
    {
        question: t('faq.q5'),
        answer: t('faq.a5'),
    },
    {
        question: "How does Laravel Mail handle email deliverability?",
        answer: 'Laravel Mail supports DKIM/SPF/DMARC setup for optimal deliverability. Our platform guides you through domain warm-up and provides dedicated infrastructure to maintain your sender reputation. <a href="/kumomta" title="Learn about KumoMTA email infrastructure" class="text-purple-600 hover:underline">Learn about our KumoMTA integration</a>.',
    },
    {
        question: "Can I use Laravel Mail for transactional emails?",
        answer: "Absolutely. Laravel Mail is perfect for transactional emails including order confirmations, password resets, and account notifications. Use Laravel's Mailable classes for clean, testable email templates.",
    },
    {
        question: "What SMTP providers does Laravel Mail support?",
        answer: "Laravel Mail supports Amazon SES, SendGrid, Mailgun, Postmark, SMTP, and any other Laravel-compatible mail driver. Configure multiple providers for redundancy and optimal routing.",
    },
    {
        question: "Does Laravel Mail work with Laravel queues?",
        answer: "Yes! Laravel Mail integrates seamlessly with Laravel queues for asynchronous email sending. Queue your emails to improve application performance and user experience.",
    },
    {
        question: "How does pricing work for Laravel Mail?",
        answer: t('faq.a5'),
    },
    {
        question: "Do you provide support for setup?",
        answer: 'Yes, we do. We offer comprehensive support and guide you through the full onboarding process. This includes complex technical tasks like DNS setup (SPF, DKIM, DMARC) and creating your first campaign templates. For assistance, simply <a href="/contact" class="text-purple-600 hover:underline">get in touch</a> with our dedicated support team.',
    },
    {
        question: "Is Laravel Mail GDPR and CCPA compliant?",
        answer: "Definitely. Because you are self-hosting and own your data, compliance is much easier. We provide built-in tools to comply with global data privacy laws like GDPR and CCPA, including unsubscribe management and secure data handling practices. Your data stays on your servers.",
    },
    {
        question: "Can I import my own B2B lead lists into Laravel Mail?",
        answer: "Yes, you can. Laravel Mail supports multiple import methods, including uploading CSV, Excel, or connecting via API. Our system automatically validates and deduplicates leads to ensure your list quality remains high.",
    },
    {
        question: "What reporting features does Laravel Mail include?",
        answer: "We provide real-time analytics on key metrics such as opens, clicks, bounce rates, and conversions. Track your Laravel Mail campaigns with detailed reports and export data for deeper analysis.",
    },
    {
        question:
            "How does Laravel Mail compare to other Laravel email packages like Mailcoach or Laravel Newsletter?",
        answer: 'While platforms like Mailcoach are excellent within the Laravel ecosystem, Laravel Mail is built as a turnkey solution for businesses rather than just a developer\'s tool. We focus on seamless user experience, comprehensive B2B lead nurturing features, and dedicated onboarding support. <a href="/mailchimp-alternative" title="Compare Laravel Mail with other platforms" class="text-purple-600 hover:underline">See how we compare</a>.',
    },
    {
        question: "Can I get a refund?",
        answer: "Due to the digital nature of the software and the inclusion of full source code access, we <b>do not offer refunds</b> once a purchase is confirmed. We recommend watching our demo video and reading the documentation thoroughly before purchase. If you have any technical issues, our support team is dedicated to help you resolve them.",
    },
];

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
            "@type": "Answer",
            text: faq.answer,
        },
    })),
};
---

<section class="py-20 bg-brand-bg-darker/40 relative overflow-hidden">
    <div class="container-custom relative">
        <div class="text-center max-w-3xl mx-auto">
            <h2 class="text-3xl md:text-5xl font-black text-white">
                {t('faq.header')}
            </h2>
            <p class="mt-4 text-xl text-gray-400">
                {t('faq.subtitle')}
            </p>
        </div>

        <!-- FAQ Items -->
        <div class="mt-12 max-w-3xl mx-auto">
            {
                faqs.map((faq, index) => (
                    <div class="mb-6 bg-brand-bg-card/40 backdrop-blur-md rounded-lg shadow-sm border border-white/10 overflow-hidden hover:shadow-md transition-all duration-300">
                        <details class="group">
                            <summary class="flex justify-between items-center cursor-pointer p-6 transition-all duration-300 hover:bg-white/5 list-none">
                                <h3
                                    title={faq.question}
                                    class="text-lg font-medium text-white group-open:text-brand-primary transition-colors duration-300"
                                >
                                    {faq.question}
                                </h3>
                                <div class="flex-shrink-0 ml-2">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-5 w-5 text-gray-400 group-open:rotate-180 transition-transform duration-300"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"
                                        />
                                    </svg>
                                </div>
                            </summary>
                            <div class="px-6 pb-6 animate-fade-in">
                                <div
                                    class="text-gray-300 leading-relaxed text-base"
                                    set:html={faq.answer}
                                />
                            </div>
                        </details>
                    </div>
                ))
            }
        </div>

        <!-- Contact CTA -->
        <div class="mt-12 text-center">
            <p class="text-gray-400">
                {t('faq.still_questions')}
            </p>
            <a
                title="self hosted laravel mail platform"
                href={getRelativeLocaleUrl(lang, "/contact")}
                class="mt-4 inline-flex items-center text-brand-primary font-medium hover:underline group"
            >
                {t('faq.contact_us')}
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4 ml-1 transition-transform duration-300 group-hover:translate-x-1"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
            </a>
        </div>
    </div>
</section>

<style>
    details summary::-webkit-details-marker {
        display: none;
    }

    details summary::marker {
        display: none;
    }

    details[open] div {
        animation: fadeIn 0.3s ease-in-out;
    }

    @keyframes fadeIn {
        0% {
            opacity: 0;
            transform: translateY(-10px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    details p {
        color: #d1d5db !important;
        font-size: 16px;
        line-height: 1.6;
    }

    details:hover summary {
        background-color: rgba(255, 255, 255, 0.05);
    }
</style>

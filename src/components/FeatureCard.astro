---
interface Props {
    title: string;
    description: string;
    icon: "mail" | "lightbulb" | "chat" | "message";
    benefits: string[];
}

const { title, description, icon, benefits } = Astro.props;

const icons = {
    mail: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>`,
    lightbulb: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>`,
    chat: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>`,
    message: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"></path>`,
};
---

<div
    class="feature-card bg-brand-bg-card/40 backdrop-blur-md border border-white/10 rounded-xl p-8 hover:border-brand-primary/50"
>
    <div
        class="icon-box w-14 h-14 rounded-lg flex items-center justify-center mb-6 pulse-ring"
    >
        <svg
            class="w-7 h-7 text-brand-primary"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
        >
            <Fragment set:html={icons[icon]} />
        </svg>
    </div>

    <h3 class="text-2xl font-bold mb-3 text-white">
        {title}
    </h3>

    <p class="text-gray-400 mb-5">
        {description}
    </p>

    <ul class="space-y-2">
        {
            benefits.map((benefit) => (
                <li class="flex items-center text-gray-300">
                    <svg
                        class="w-4 h-4 mr-3 text-brand-accent"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                            clip-rule="evenodd"
                        />
                    </svg>
                    {benefit}
                </li>
            ))
        }
    </ul>
</div>

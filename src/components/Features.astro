        image: featureImage3,
        industries: ["Telecommunications", "Network Infrastructure", "Communication Services", "VoIP"]
    },
    {
        title: "Insurance & Risk Management Leads",
        description:
            "Connect with insurance executives, risk managers, and claims processors. Perfect for insurance software, risk assessment tools, and insurance services.",
        icon: "ph:check-circle-duotone",
        image: featureImage1,
        industries: ["Insurance", "Risk Management", "Claims Processing", "Underwriting"]
    },
    {
        title: "Legal & Compliance Leads",
        description:
            "Reach law firm partners, compliance officers, and legal executives. Ideal for legal software, compliance tools, and legal service providers.",
        icon: "ph:globe-duotone",
        image: featureImage2,
        industries: ["Law Firms", "Compliance", "Legal Services", "Regulatory Affairs"]

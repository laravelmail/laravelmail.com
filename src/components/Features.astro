---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

//@TODO : Replace with screens
const features = [
    {
        title: "Automation",
        description:
            "A free marketing solution built for tech teams using the Laravel Mail marketing platform.",
        icon: "ph:check-circle-duotone",
        image: "screens/automation.png",
        industries: ["Automation", "Drag and drop", "Chad builder", "WhatsApp integration"]
    },
    {
        title: "Intelligent Dashboard",
        description: "Deliver patient updates, research news, and service alerts securely with your own open source marketing stack via our no vendor lock-in, no hidden fees.",
        icon: "ph:globe-duotone",
        image: "screens/dashboard.png",
        industries: ["Dashboard", "Clinics", "Print Devices"]
    },
    {
        title: "Inbox",
        description: "Keep sensitive client data in-house while running secure, segmented campaigns for banks, and advisors. We offer a free marketing platform with enterprise-grade deliverability—ideal for regulated industries.",
        icon: "ph:lightning-duotone",
        image: "screens/inbox.png",
        industries: ["Mail Inbox", "Private Firms", ""]
    },
    {
        title: "Customer Intelligence",
        description: "Get more insights into your customers using public domain information",
        icon: "ph:lightning-duotone",
        image: "screens/intelligence.png",
        industries: ["Customer Intelligence", "Open source data"]
    },
    {
        title: "Messaging System",
        description: "",
        icon: "ph:lightning-duotone",
        image: "screens/intelligence.png",
        industries: ["Customer Messaging", "WhatApp Business Messaging", "Twilio Integration"]
    },
    {
        title: "Products Management",
        description: "Get your products automatically in Google Marketplace ",
        icon: "ph:lightning-duotone",
        image: "screens/products.png",
        industries: ["Customer Messaging", "WhatApp Business Messaging", "Twilio Integration"]
    },
];
---

<section class="py-20">
    <div class="container-custom relative">
        <div class="mt-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            {features.map((feature, index) => (
                    <article
                            class={`feature-card animate-on-scroll delay-${index + 2} group bg-white/10 border border-white/20 p-6 rounded-2xl transition-all duration-300 hover:bg-white/15 hover:border-white/30`}
                            itemScope
                            itemType="https://schema.org/Service"
                    >

                        <h3 title={`self hosted email platform for ${feature.title}`} class="text-lg font-semibold text-white group-hover:text-purple-300 transition-colors" itemProp="name">
                            Mail Platform for {feature.title}
                        </h3>
                        <p
                                class="mt-3 text-gray-300 leading-relaxed text-sm"
                                itemProp="description"
                                set:html={feature.description}
                        ></p>

                        <div class="mt-4 flex flex-wrap gap-2">
                            {feature.industries.slice(0, 3).map(industry => (
                                    <span title={`mail platform for ${industry}`} class="inline-block px-2 py-1 text-xs font-medium bg-purple-500/20 text-purple-200 rounded-full border border-purple-400/30">
                {industry}
              </span>
                            ))}
                            {feature.industries.length > 3 && (
                                    <span class="inline-block px-2 py-1 text-xs font-medium bg-white/5 text-gray-300 rounded-full border border-white/10">
                +{feature.industries.length - 3} more
              </span>
                            )}
                        </div>


                    </article>
            ))}
        </div>
    </div>
</section>
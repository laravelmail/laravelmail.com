            "Connect with CTOs, developers, and tech decision-makers at startups and enterprises. Perfect for software companies, app developers, and cloud service providers.",
        icon: "ph:check-circle-duotone",
        image: featureImage1,
        industries: ["Software Development", "Cloud Computing", "AI/ML", "Cybersecurity"]
    },
    {
        title: "Healthcare & Medical Leads",
        description:
            "Reach hospital administrators, doctors, and healthcare executives. Ideal for medical equipment suppliers, pharmaceutical companies, and healthcare IT solutions.",
        icon: "ph:globe-duotone",
        image: featureImage2,
        industries: ["Hospitals", "Clinics", "Pharmaceuticals", "Medical Devices"]
    },
    {
        title: "Financial Services Leads",
        description:
            "Target CFOs, investment bankers, and financial advisors at banks and fintech companies. Perfect for financial software, payment processors, and wealth management firms.",
        icon: "ph:lightning-duotone",
        image: featureImage3,
        industries: ["Banking", "Fintech", "Investment Firms", "Insurance"]
    },
    {
        title: "Real Estate & Property Leads",
        description:
            "Connect with property developers, real estate agents, and facility managers. Great for construction companies, property management software, and real estate services.",
        icon: "ph:check-circle-duotone",
        image: featureImage1,
        industries: ["Property Development", "Real Estate Agencies", "Construction", "Architecture"]

        industries: ["Media", "Entertainment", "Content Creation", "Digital Publishing"]
    },
    {
        title: "Automotive & Mobility Leads",
        description:
            "Connect with automotive executives, dealership owners, and mobility service providers. Ideal for automotive software, mobility solutions, and vehicle services.",
        icon: "ph:check-circle-duotone",
        image: featureImage1,
        industries: ["Automotive", "Dealerships", "Mobility Services", "Vehicle Technology"]
    },
    {
        title: "Food & Beverage Leads",
        description:
            "Reach restaurant owners, food manufacturers, and beverage executives. Perfect for food service software, beverage distribution, and food processing.",
        icon: "ph:globe-duotone",
        image: featureImage2,
        industries: ["Restaurants", "Food Manufacturing", "Beverage", "Food Service"]
    },
    {
        title: "Telecommunications Leads",
        description:
            "Target telecom executives, network operators, and communication service providers. Great for telecom software, network infrastructure, and communication services.",

---

<!-- Features Section Schema -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "B2B Lead Generation Services",
    "description": "Professional B2B lead generation services providing verified, curated leads across multiple industries",
    "provider": {
        "@type": "Organization",
        "name": "LeadsCaptain",
        "url": "https://leadscaptain.com"
    },
    "serviceType": "Lead Generation",
    "areaServed": "Worldwide",
    "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "B2B Lead Services",
        "itemListElement": [
            {
                "@type": "Offer",
                "itemOffered": {
                    "@type": "Service",
                    "name": "Curated & Verified Leads",
                    "description": "Handpicked and verified business contacts from LinkedIn and professional directories"
                }
            },
            {
                "@type": "Offer",
                "itemOffered": {
                    "@type": "Service",
                    "name": "Multi-Industry Coverage",
                    "description": "Comprehensive lead generation across retail, SaaS, e-commerce, and professional services"
                }
            },
            {
                "@type": "Offer",
                "itemOffered": {
                    "@type": "Service",
                    "name": "Fast & Scalable Delivery",
                    "description": "Rapid delivery of 500 to 50,000+ leads with guaranteed quality and scalability"
                }
            }
        ]
    }
}
</script>

<section class="py-20 bg-gradient-to-b from-white to-gray-50 relative overflow-hidden" itemscope itemtype="https://schema.org/WebPageElement">
    <!-- Background -->
    <div class="absolute inset-0 opacity-5 parallax" data-speed="0.1">
        <div
                class="absolute inset-0 bg-repeat"
                style="background-image: url('/grid-pattern.svg');"
        ></div>
    </div>

    <div class="container-custom relative">
        <!-- Header -->
        <header class="text-center max-w-3xl mx-auto" itemscope itemtype="https://schema.org/WebPageElement">
            <h2
                    class="animate-on-scroll delay-0 text-3xl md:text-4xl font-bold leading-tight"
                    itemprop="headline"
            >
                Everything you need to
                <span class="gradient-text">scale with B2B leads</span>
            </h2>
            <p
                    class="animate-on-scroll delay-1 mt-4 text-xl text-gray-600 leading-relaxed"
                    itemprop="description"
            >
                Leadscaptain delivers verified, segmented, and ready-to-use contacts across
                <span class="font-medium text-gray-800">20+ industries</span>.
                <span class="font-medium text-gray-800"
                >No scraping headaches, no guesswork — just real opportunities to close
          deals faster.</span
                >
            </p>
        </header>

        <!-- Features -->
        <div class="mt-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            {features.map((feature, index) => (
                    <article
                            class={`feature-card animate-on-scroll delay-${index + 2} group bg-white p-6 rounded-2xl shadow-md transition-all duration-300 hover:-translate-y-1 hover:shadow-lg`}
                            itemScope
                            itemType="https://schema.org/Service"
                    >
                        <div
                                class="h-12 w-12 rounded-lg bg-gradient-to-r from-purple-600 to-blue-500 flex items-center justify-center text-white mb-6 transition-transform duration-300 group-hover:scale-110"
                        >
                            <Icon
                                    name={feature.icon}
                                    class="h-6 w-6 transition-transform duration-300 group-hover:rotate-12"
                            />
                        </div>
                        <h3
                                class="text-xl font-semibold transition-colors duration-300 group-hover:text-purple-600"
                                itemProp="name"
                        >
                            {feature.title}
                        </h3>
                        <p class="mt-3 text-gray-600 leading-relaxed text-sm" itemProp="description">
                            {feature.description}
                        </p>

                        <!-- Industry Tags -->
                        <div class="mt-4 flex flex-wrap gap-2">
                            {feature.industries.slice(0, 3).map(industry => (
                                <span class="inline-block px-2 py-1 text-xs font-medium bg-purple-100 text-purple-700 rounded-full">
                                    {industry}
                                </span>
                            ))}
                            {feature.industries.length > 3 && (
                                <span class="inline-block px-2 py-1 text-xs font-medium bg-gray-100 text-gray-600 rounded-full">
                                    +{feature.industries.length - 3} more
                                </span>
                            )}
                        </div>

                        <div class="mt-6 hover-zoom rounded-lg overflow-hidden">
                            <Image
                                    src={feature.image}
                                    alt={`LeadsCaptain ${feature.title} - Professional B2B lead generation service`}
                                    title={feature.title}
                                    class="w-full h-auto rounded-lg transition-all duration-500"
                                    width={300}
                                    height={200}
                            />
                        </div>
                    </article>
            ))}
        </div>

        <!-- KPI Row -->
        <div
                class="mt-20 grid grid-cols-1 sm:grid-cols-3 gap-8 text-center animate-on-scroll delay-5"
                itemscope
                itemtype="https://schema.org/Organization"
        >
            <div class="flex flex-col" itemprop="knowsAbout" itemscope itemtype="https://schema.org/QuantitativeValue">
                <span class="text-3xl md:text-4xl font-bold text-purple-600" itemprop="value">50K+</span>
                <span class="mt-2 text-gray-600" itemprop="unitText">Verified Leads</span>
                <meta itemprop="description" content="Over 50,000 verified business leads in our database" />
            </div>
            <div class="flex flex-col" itemprop="knowsAbout" itemscope itemtype="https://schema.org/QuantitativeValue">
                <span class="text-3xl md:text-4xl font-bold text-purple-600" itemprop="value">20+</span>
                <span class="mt-2 text-gray-600" itemprop="unitText">Industries Covered</span>
                <meta itemprop="description" content="Lead generation services across 20+ major industries" />
            </div>
            <div class="flex flex-col" itemprop="knowsAbout" itemscope itemtype="https://schema.org/QuantitativeValue">
                <span class="text-3xl md:text-4xl font-bold text-purple-600" itemprop="value">95%</span>
                <span class="mt-2 text-gray-600" itemprop="unitText">Email Deliverability</span>
                <meta itemprop="description" content="95% email deliverability rate for all lead lists" />
            </div>
        </div>
    </div>
</section>

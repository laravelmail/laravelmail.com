---

<section class="py-20 bg-gradient-to-b from-white to-gray-50 relative overflow-hidden">
    <div class="container-custom relative">
        <!-- Features -->
        <div class="mt-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            {features.map((feature, index) => (
                    <article
                            class={`feature-card animate-on-scroll delay-${index + 2} group bg-white p-6 rounded-2xl shadow-md transition-all duration-300 hover:-translate-y-1 hover:shadow-lg`}
                            itemScope
                            itemType="https://schema.org/Service"
                    >

                        <h3 title={`self hosted email platform for ${feature.title}`}  class="text-xl font-semibold group-hover:text-purple-600" itemProp="name">
                            Mail Platform for {feature.title}
                        </h3>
                        <p
                                class="mt-3 text-gray-600 leading-relaxed text-sm"
                                itemProp="description"
                                set:html={feature.description}
                        ></p>

                        <div class="mt-4 flex flex-wrap gap-2">
                            {feature.industries.slice(0, 3).map(industry => (
                                    <span title={`mail platform for ${industry}`} class="inline-block px-2 py-1 text-xs font-medium bg-purple-100 text-purple-700 rounded-full">
                {industry}
              </span>
                            ))}
                            {feature.industries.length > 3 && (
                                    <span class="inline-block px-2 py-1 text-xs font-medium bg-gray-100 text-gray-600 rounded-full">
                +{feature.industries.length - 3} more
              </span>
                            )}
                        </div>


                    </article>
            ))}
        </div>
    </div>
</section>

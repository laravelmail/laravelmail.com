        image: featureImage3,
        industries: ["Retail Stores", "E-commerce", "Online Marketplaces", "POS Systems"]
    },
    {
        title: "Education & Training Leads",
        description:
            "Connect with school administrators, training directors, and education consultants. Great for educational software, training programs, and learning management systems.",
        icon: "ph:check-circle-duotone",
        image: featureImage1,
        industries: ["K-12 Schools", "Universities", "Corporate Training", "E-learning"]
    },
    {
        title: "Professional Services Leads",
        description:
            "Reach lawyers, accountants, consultants, and service professionals. Perfect for legal software, accounting tools, and professional service automation.",
        icon: "ph:globe-duotone",
        image: featureImage2,
        industries: ["Legal Services", "Accounting", "Consulting", "Marketing Agencies"]
    },
    {
        title: "Hospitality & Tourism Leads",
        description:
            "Target hotel managers, restaurant owners, and tourism operators. Ideal for hospitality software, booking systems, and tourism services.",
        icon: "ph:lightning-duotone",
        image: featureImage3,
        industries: ["Hotels", "Restaurants", "Tourism", "Event Planning"]
    },
    {
        title: "Construction & Engineering Leads",
        description:
            "Connect with project managers, engineers, and construction executives. Perfect for construction software, building materials, and engineering services.",
        icon: "ph:check-circle-duotone",
        image: featureImage1,
        industries: ["Construction", "Engineering", "Building Materials", "Project Management"]
    },
    {
        title: "Transportation & Logistics Leads",
        description:
            "Reach fleet managers, logistics directors, and transportation executives. Ideal for logistics software, shipping companies, and transportation services.",
        icon: "ph:globe-duotone",
        image: featureImage2,
        industries: ["Shipping", "Logistics", "Fleet Management", "Transportation"]
    },
    {
        title: "Energy & Utilities Leads",
        description:
            "Target energy executives, utility managers, and sustainability directors. Perfect for renewable energy, utility software, and environmental services.",
        icon: "ph:lightning-duotone",
        image: featureImage3,
        industries: ["Renewable Energy", "Utilities", "Oil & Gas", "Environmental Services"]
    },
    {
        title: "Marketing & Advertising Leads",
        description:
            "Connect with marketing directors, agency owners, and brand managers. Great for marketing software, advertising agencies, and digital marketing services.",
        icon: "ph:check-circle-duotone",
        image: featureImage1,
        industries: ["Digital Marketing", "Advertising Agencies", "Brand Management", "SEO Services"]
    },
    {
        title: "Human Resources & Staffing Leads",
        description:
            "Reach HR directors, recruiters, and staffing executives. Perfect for HR software, recruitment agencies, and talent management solutions.",
        icon: "ph:globe-duotone",
        image: featureImage2,
        industries: ["HR Software", "Recruitment", "Staffing Agencies", "Talent Management"]
    },
    {
        title: "Agriculture & Farming Leads",
        description:
            "Target farm owners, agricultural executives, and food producers. Ideal for farming equipment, agricultural software, and food processing companies.",

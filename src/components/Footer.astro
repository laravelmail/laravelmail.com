---
import { Image } from 'astro:assets';
import logoSrc from '../assets/logo.svg';

const companyLinks = [
    { name: 'About Us', href: '/about-us' },
    { name: 'Contact', href: '/contact' },
    { name: 'Blog', href: '/blog' },
];



const legalLinks = [
    { name: 'Privacy Policy', href: 'https://leadscaptain.com/privacy-policy' },
    { name: 'Terms of Service', href: 'https://leadscaptain.com/terms-of-service' },
    { name: 'Cookie Policy', href: 'https://leadscaptain.com/cookie-policy' },
];

const socialLinks = [
    { name: 'Twitter', href: 'https://twitter.com/leadscaptain', icon: 'twitter' },
    { name: 'LinkedIn', href: 'https://linkedin.com/company/leadscaptain', icon: 'linkedin' },
];

// Structured data for organization
const organizationSchema = {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Laravel Mail",
    "url": "https://laravelmail.com",
    "logo": "https://laravelmail.com/logo.svg",
    "description": "Laravel Mail is a self hosted email marketing platform that delivers verified, curated B2B leads across industries. We help businesses grow faster with data you can trust.",
    "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+1-555-0123", // Replace with actual phone
        "contactType": "customer service",
        "url": "https://laravelmail.com/contact"
    },
    "sameAs": [
        "https://twitter.com/thelaravelmail",
        "https://linkedin.com/company/thelaravelmail"
    ],
    "address": {
        "@type": "PostalAddress",
        "addressCountry": "GB" // Replace with actual country
    },
    "foundingDate": "2020", // Replace with actual founding date
    "knowsAbout": [
        "B2B Lead Generation",
        "Business Data",
        "Sales Leads",
        "Marketing Automation",
        "CRM Integration"
    ]
};

// Site navigation schema

---

<footer class="bg-gray-900 text-white pt-16 pb-8 relative overflow-hidden">
    <!-- Subtle background pattern -->
    <div class="absolute inset-0 opacity-5">
        <div class="absolute inset-0 bg-repeat" style="background-image: url('/grid-pattern.svg');"></div>
    </div>

    <!-- Animated gradient background -->
    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-purple-600 via-pink-500 to-purple-600 bg-[length:200%_auto] animate-gradient-x"></div>

    <div class="container-custom relative">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-8 pb-12 border-b border-gray-800">
            <div class="lg:col-span-2">
                <a href="/" class="inline-block transition-transform duration-300 hover:scale-105" aria-label="Laravel Mail home">
                    <Image src={logoSrc} alt="Laravel Mail Logo" width={140} height={45} class="brightness-0 invert" />
                </a>
                <p class="mt-4 text-gray-400 max-w-md">
                    Grow your business faster with <b>Laravel Mail</b>, the self-hosted email marketing platform that gives you the control to reach curated B2B leads you can trust.
                </p>
                <div class="mt-6 flex space-x-4">
                    {socialLinks.map(social => {
                        const titles = {
                            'Twitter': 'Follow for real-time industry updates and market insights',
                            'LinkedIn': 'Network with B2B professionals and industry leaders'
                        };
                        return (
                            <a
                                    href={social.href}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-gray-400 hover:text-white transition-all duration-300 hover:scale-110 transform"
                                    aria-label={`Follow LeadsCaptain on ${social.name}`}
                                    title={titles[social.name] || `Follow us on ${social.name}`}
                            >
                                {social.icon === 'twitter' && (
                                        <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84" />
                                        </svg>
                                )}
                                {social.icon === 'linkedin' && (
                                        <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
                                        </svg>
                                )}
                            </a>
                        );
                    })}
                </div>
            </div>

            <div>
                <h3 class="text-lg font-semibold mb-4 text-white/90">Company</h3>
                <ul class="space-y-3">
                    {companyLinks.map((link, index) => {
                        const titles = {
                            'About Us': 'Learn about Laravel Mail\'s mission and expert team',
                            'How It Works': 'Discover our proven B2B lead generation methodology',
                            'Contact': 'Connect with our sales experts for custom solutions',
                            'Blog': 'Explore industry insights and lead generation strategies'
                        };
                        return (
                            <li class="transform transition-all duration-300 hover:translate-x-1">
                                <a
                                        href={link.href}
                                        class="text-gray-400 hover:text-white transition-colors duration-300 inline-block"
                                        style={`transition-delay: ${index * 50}ms;`}
                                        title={link.name}
                                >
                                    {link.name}
                                </a>
                            </li>
                        );
                    })}
                </ul>
            </div>


            <div>
                <h3 class="text-lg font-semibold mb-4 text-white/90">Legal</h3>
                <ul class="space-y-3">
                    {legalLinks.map((link, index) => {
                        const titles = {
                            'Privacy Policy': 'How we safeguard your data and ensure compliance',
                            'Terms of Service': 'Legal agreement for using our lead services',
                            'Cookie Policy': 'Manage your cookie preferences and privacy settings'
                        };
                        return (
                            <li class="transform transition-all duration-300 hover:translate-x-1">
                                <a
                                        href={link.href}
                                        class="text-gray-400 hover:text-white transition-colors duration-300 inline-block"
                                        style={`transition-delay: ${index * 50}ms;`}
                                        title={link.name}
                                >
                                    {link.name}
                                </a>
                            </li>
                        );
                    })}
                </ul>
            </div>
        </div>

        <div class="pt-8 text-center text-gray-400 text-sm">
            <p class="hover:text-gray-300 transition-colors duration-300">&copy; {new Date().getFullYear()} Laravel Company. All rights reserved.</p>
            <div class="mt-4 flex flex-col sm:flex-row justify-center items-center space-y-2 sm:space-y-0 sm:space-x-6">
                <a href="/sitemap.xml" class="hover:text-white transition-colors duration-300" title="Complete website navigation and page directory">Sitemap</a>
                <span class="hidden sm:inline text-gray-600">|</span>
                <a href="/contact" class="hover:text-white transition-colors duration-300" title="Access our support team and customer service">Contact</a>
                <span class="hidden sm:inline text-gray-600">|</span>
                <a href="/privacy" class="hover:text-white transition-colors duration-300" title="Understand our data protection and privacy measures">Privacy</a>
                <span class="hidden sm:inline text-gray-600">|</span>
                <a href="/terms" class="hover:text-white transition-colors duration-300" title="Review our service conditions and legal framework">Terms</a>
            </div>
        </div>
    </div>
</footer>

<!-- Structured Data for SEO -->
<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)}></script>

<!-- Additional SEO structured data -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Laravel Mail",
    "url": "https://laravelmail.com",
    "description": "Self hosted marketing platform with Verified B2B lead generation service providing curated business leads across industries",
    "publisher": {
        "@type": "Organization",
        "name": "Laravel Company"
    }
}
</script>


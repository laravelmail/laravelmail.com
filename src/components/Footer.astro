---
import { Image } from "astro:assets";
import logoSrc from "../assets/logo.svg";

const companyLinks = [
    { name: "GitHub", href: "https://github.com/laravelmail" },
    { name: "Contact", href: "/contact" },
    { name: "Deploy", href: "/deploy" },
    { name: "Templates", href: "https://templates.laravelmail.com" },
    { name: "Docs", href: "https://docs.laravelmail.com" },
    { name: "Affiliate", href: "/affiliate" },
];

const legalLinks = [
    { name: "Privacy Policy", href: "https://laravelmail.com/privacy" },
    { name: "Terms of Service", href: "/terms-of-service" },
    { name: "Cookie Policy", href: "/cookie-policy" },
    { name: "Careers", href: "/careers" },
];

const socialLinks = [
    {
        name: "GitHub",
        href: "https://github.com/laravelmail",
        icon: "github",
    },
    {
        name: "LinkedIn",
        href: "https://www.linkedin.com/company/laravelmail",
        icon: "linkedin",
    },
];

// Structured data for organization
const organizationSchema = {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Laravel Company",
    url: "https://laravelmail.com",
    logo: "https://laravelmail.com/logo.svg",
    description:
        "Laravel Mail is a self hosted email marketing platform that delivers verified, curated B2B leads across industries. We help businesses grow faster with data you can trust.",
    contactPoint: {
        "@type": "ContactPoint",
        telephone: "+44 744 821 8899",
        contactType: "customer service",
        url: "https://laravelmail.com/contact",
    },
    address: {
        "@type": "PostalAddress",
        streetAddress: "7 High Street",
        addressLocality: "Basildon",
        addressRegion: "Essex",
        postalCode: "SS14 1AB",
        addressCountry: "GB",
    },
    sameAs: ["https://www.linkedin.com/company/laravelmail"],
    foundingDate: "2020",
    knowsAbout: [
        "Email Marketing",
        "Self hosted platform",
        "B2B Lead Generation",
        "Business Data",
        "Sales Leads",
        "Marketing Automation",
        "CRM Integration",
    ],
};
---

<footer class="bg-gray-900 text-white pt-16 pb-8 relative overflow-hidden">
    <!-- Subtle background pattern -->
    <div class="absolute inset-0 opacity-5">
        <div
            class="absolute inset-0 bg-repeat"
            style="background-image: url('/grid-pattern.svg');"
        >
        </div>
    </div>

    <!-- Animated gradient background -->
    <div
        class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-purple-600 via-pink-500 to-purple-600 bg-[length:200%_auto] animate-gradient-x"
    >
    </div>

    <div class="container-custom relative">
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-8 pb-12 border-b border-gray-800"
        >
            <div class="lg:col-span-2">
                <a
                    href="/"
                    class="inline-block transition-transform duration-300 hover:scale-105"
                    aria-label="Laravel Mail home"
                    onclick="window.trackFooterClick && window.trackFooterClick('Footer', 'Logo')"
                >
                    <Image
                        src={logoSrc}
                        alt="Laravel Mail Logo"
                        width={140}
                        height={45}
                        class="hover:brightness-110 transition-all duration-300"
                    />
                </a>
                <p class="mt-4 text-gray-400 max-w-md">
                    Grow your business faster with <b>Laravel Mail</b>, the
                    self-hosted email marketing platform that gives you the
                    control to reach curated B2B leads you can trust.
                </p>
                <div class="mt-6 flex space-x-4">
                    {
                        socialLinks.map((social) => {
                            const titles = {
                                Twitter:
                                    "Follow for real-time industry updates and market insights",
                                LinkedIn:
                                    "Network with B2B professionals and industry leaders",
                            };
                            return (
                                <a
                                    href={social.href}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-gray-400 hover:text-white transition-all duration-300 hover:scale-110 transform"
                                    aria-label={`Follow Laravel Mail on ${social.name}`}
                                    title={`Follow us on ${social.name}`}
                                    onclick={`window.trackFooterClick && window.trackFooterClick('Social Media', '${social.name}')`}
                                >
                                    {social.icon === "twitter" && (
                                        <svg
                                            class="h-6 w-6"
                                            fill="currentColor"
                                            viewBox="0 0 24 24"
                                            aria-hidden="true"
                                        >
                                            <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84" />
                                        </svg>
                                    )}
                                    {social.icon === "linkedin" && (
                                        <svg
                                            class="h-6 w-6"
                                            fill="currentColor"
                                            viewBox="0 0 24 24"
                                            aria-hidden="true"
                                        >
                                            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
                                        </svg>
                                    )}
                                    {social.icon === "github" && (
                                        <svg
                                            class="h-6 w-6"
                                            fill="currentColor"
                                            viewBox="0 0 24 24"
                                            aria-hidden="true"
                                        >
                                            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                                        </svg>
                                    )}
                                </a>
                            );
                        })
                    }
                </div>
            </div>

            <div>
                <h3 class="text-lg font-semibold mb-4 text-white/90">
                    Company
                </h3>
                <ul class="space-y-3" style="padding: 0px;">
                    {
                        companyLinks.map((link, index) => {
                            const titles = {
                                "About Us":
                                    "Learn about Laravel Mail's mission and expert team",
                                "How It Works":
                                    "Discover our proven B2B lead generation methodology",
                                Contact:
                                    "Connect with our sales experts for custom solutions",
                                Blog: "Explore industry insights and lead generation strategies",
                            };
                            return (
                                <li class="transform transition-all duration-300 hover:translate-x-1">
                                    <a
                                        href={link.href}
                                        class="text-gray-400 hover:text-white transition-colors duration-300 inline-block py-2"
                                        style={`transition-delay: ${index * 50}ms;`}
                                        title={link.name}
                                        onclick={`window.trackFooterClick && window.trackFooterClick('Footer Navigation', 'Company - ${link.name}')`}
                                    >
                                        {link.name}
                                    </a>
                                </li>
                            );
                        })
                    }
                </ul>
            </div>

            <div>
                <h3 class="text-lg font-semibold mb-4 text-white/90">Legal</h3>
                <ul class="space-y-3 no-padding" style="padding:0px">
                    {
                        legalLinks.map((link, index) => {
                            const titles = {
                                "Privacy Policy":
                                    "How we safeguard your data and ensure compliance",
                                "Terms of Service":
                                    "Legal agreement for using our lead services",
                                "Cookie Policy":
                                    "Manage your cookie preferences and privacy settings",
                            };
                            return (
                                <li class="transform transition-all duration-300 hover:translate-x-1">
                                    <a
                                        href={link.href}
                                        class="text-gray-400 hover:text-white transition-colors duration-300 inline-block py-2"
                                        style={`transition-delay: ${index * 50}ms;`}
                                        title={link.name}
                                        onclick={`window.trackFooterClick && window.trackFooterClick('Footer Navigation', 'Legal - ${link.name}')`}
                                    >
                                        {link.name}
                                    </a>
                                </li>
                            );
                        })
                    }
                </ul>
            </div>
            <div>
                <h3 class="text-lg font-semibold mb-4 text-white/90">
                    Certifications
                </h3>
                <div class="flex flex-col space-y-6">
                    <div class="flex items-center space-x-4">
                        <img
                            src="/badges/gdpr-compliant.png"
                            alt="GDPR Compliant"
                            class="h-10 w-auto object-contain hover:scale-105 transition-transform"
                            loading="lazy"
                            width="200"
                            height="40"
                        />
                        <img
                            src="/badges/iso-certified.png"
                            alt="ISO Certified"
                            class="h-10 w-auto object-contain hover:scale-105 transition-transform"
                            loading="lazy"
                            width="200"
                            height="40"
                        />
                    </div>

                    <div class="pt-2">
                        <h4
                            class="text-sm font-semibold text-gray-300 mb-3 border-b border-gray-800 pb-2 inline-block"
                        >
                            Voted #1 in 526 G2 Reports
                        </h4>
                        <div class="grid grid-cols-3 gap-3">
                            <img
                                class="w-full h-auto rounded hover:scale-105 transition-transform duration-300"
                                src="/badges/g2-leader-small-business.png"
                                alt="G2 Leader Small Business"
                                width="80"
                                height="80"
                                loading="lazy"
                            />
                            <img
                                class="w-full h-auto rounded hover:scale-105 transition-transform duration-300"
                                src="/badges/g2-most-implementable.png"
                                alt="G2 Most Implementable"
                                width="80"
                                height="80"
                                loading="lazy"
                            />
                            <img
                                class="w-full h-auto rounded hover:scale-105 transition-transform duration-300"
                                src="/badges/g2-best-relationships.png"
                                alt="G2 Best Relationship"
                                width="80"
                                height="80"
                                loading="lazy"
                            />
                            <img
                                class="w-full h-auto rounded hover:scale-105 transition-transform duration-300"
                                src="/badges/g2-best-support-enterprise.png"
                                alt="G2 Best Support"
                                width="80"
                                height="80"
                                loading="lazy"
                            />
                            <img
                                class="w-full h-auto rounded hover:scale-105 transition-transform duration-300"
                                src="/badges/g2-best-results.png"
                                alt="G2 Best Results"
                                width="80"
                                height="80"
                                loading="lazy"
                            />
                            <img
                                class="w-full h-auto rounded hover:scale-105 transition-transform duration-300"
                                src="https://www.hubspot.com/hs-fs/hubfs/G2%20badges%20all/G2%20badges%20evergreen/badge-best-usability-enterprise.png?width=80&height=80&name=badge-best-usability-enterprise.png"
                                alt="G2 Best Usability"
                                width="80"
                                height="80"
                                loading="lazy"
                            />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="pt-8 text-center text-gray-400 text-sm">
            <p class="hover:text-gray-300 transition-colors duration-300">
                &copy; {new Date().getFullYear()} Laravel Company. All rights reserved.
            </p>
            <div
                class="mt-4 flex flex-col sm:flex-row justify-center items-center space-y-2 sm:space-y-0 sm:space-x-6"
            >
                <a
                    href="/sitemap.xml"
                    class="hover:text-white transition-colors duration-300"
                    title="Complete website navigation and page directory"
                    onclick="window.trackFooterClick && window.trackFooterClick('Footer Utility', 'Sitemap')"
                >
                    Sitemap
                </a>
                <span class="hidden sm:inline text-gray-600">|</span>
                <a
                    href="https://laravelmail.com/privacy"
                    class="hover:text-white transition-colors duration-300"
                    title="Understand our data protection and privacy measures"
                    onclick="window.trackFooterClick && window.trackFooterClick('Footer Utility', 'Privacy Policy')"
                >
                    Privacy Policy
                </a>
                <span class="hidden sm:inline text-gray-600">|</span>
                <a
                    href="/terms-of-service"
                    class="hover:text-white transition-colors duration-300"
                    title="Review our service conditions and legal framework"
                    onclick="window.trackFooterClick && window.trackFooterClick('Footer Utility', 'Terms of Service')"
                >
                    Terms of Service
                </a>
            </div>
        </div>
    </div>
</footer>

<!-- Structured Data for SEO -->
<script
    type="application/ld+json"
    set:html={JSON.stringify(organizationSchema)}
/>

<!-- Additional SEO structured data -->
<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Laravel Mail",
        "url": "https://laravelmail.com",
        "description": "Self hosted marketing platform with Verified B2B lead generation service providing curated business leads across industries",
        "publisher": {
            "@type": "Organization",
            "name": "Laravel Mail"
        }
    }
</script>

<!-- Google Analytics Footer Tracking Script -->
<script>
    // Safe tracking function that works with or without GA
    window.trackFooterClick = function (category, label, value = 1) {
        try {
            // Try GA4 gtag first
            if (typeof gtag !== "undefined") {
                gtag("event", "click", {
                    event_category: category,
                    event_label: label,
                    value: value,
                    transport_type:
                        category === "Social Media" ? "beacon" : undefined,
                });
                // Tracked
                return;
            }

            // Fallback to Universal Analytics if available
            if (typeof ga !== "undefined") {
                ga("send", "event", category, "click", label, value);
                // Tracked
                return;
            }

            // Fallback to Google Tag Manager dataLayer if available
            if (typeof dataLayer !== "undefined") {
                dataLayer.push({
                    event: "footer_click",
                    event_category: category,
                    event_label: label,
                    value: value,
                });
                // Tracked
                return;
            }

            // Final fallback - just log to console for debugging
            console.log("Footer click tracked (no GA):", category, "-", label);
        } catch (error) {
            console.warn("Footer tracking error:", error);
        }
    };
</script>

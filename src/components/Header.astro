---
import { Image } from "astro:assets";
import Logo from "src/assets/logo.svg";

const navItems = [
    {
        name: "Templates",
        href: "https://templates.laravelmail.com",
        title: "Laravel Mail Templates",
    },
    {
        name: "Docs",
        href: "https://app.laravelmail.com/docs",
        title: "Laravel MailDocumentation",
    },
    {
        name: "Buy",
        href: "/buy",
        title: "Buy Laravel Mail",
    },
    {
        name: "Contact",
        href: "/contact",
        title: "Get in Touch",
    },
];

const socialLinks = [
    {
        name: "GitHub",
        href: "https://github.com/laravelmail",
        icon: "github",
    },
    {
        name: "LinkedIn",
        href: "https://www.linkedin.com/company/laravelmail",
        icon: "linkedin",
    },
];
---

<script is:inline>
    function trackClick(label) {
        if (typeof window !== "undefined" && window.gtag) {
            window.gtag("event", "click", {
                event_category: "navigation",
                event_label: label,
            });
            // Clicked
        }
    }

    document.addEventListener("DOMContentLoaded", () => {
        const menuToggle = document.getElementById("menu-toggle");
        const mobileMenu = document.getElementById("mobile-menu");

        if (menuToggle && mobileMenu) {
            menuToggle.addEventListener("click", () => {
                mobileMenu.classList.toggle("mobile-menu-open");
                menuToggle.classList.toggle("menu-open");
            });
        }
    });
</script>

<header
    class="sticky top-0 z-50 w-full bg-[#0a0e27]/90 backdrop-blur-xl border-b border-white/5"
    role="banner"
>
    <div class="container-custom flex items-center justify-between h-20 px-4">
        <a
            href="/"
            onclick="trackClick('logo_home')"
            class="flex items-center transition-transform duration-300 hover:scale-105 focus:scale-105 focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 rounded"
            aria-label="Laravel Mail"
        >
            <Image
                src={Logo}
                alt="Laravel Mail Logo"
                width={130}
                height={40}
                class="transition-all duration-300 hover:scale-110 hover:-rotate-3 hover:drop-shadow-[0_0_15px_rgba(124,58,237,0.8)] focus:scale-110 focus:-rotate-3 focus:drop-shadow-[0_0_15px_rgba(124,58,237,0.8)] active:scale-95"
            />
        </a>

        <!-- Desktop Nav -->
        <nav
            class="hidden md:flex items-center space-x-10"
            role="navigation"
            aria-label="Main navigation"
        >
            {
                navItems.map((item) => (
                    <a
                        title={item.title}
                        href={item.href}
                        onclick={`trackClick('${item.name}')`}
                        class="text-sm font-bold text-white/70 hover:text-white focus:text-white transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 rounded px-2 py-1"
                    >
                        {item.name}
                    </a>
                ))
            }
        </nav>

        <div class="flex items-center space-x-6">
            <!-- Social Icons -->
            <div
                class="hidden lg:flex items-center space-x-4 border-r border-white/10 pr-6 mr-2"
            >
                {
                    socialLinks.map((social) => (
                        <a
                            href={social.href}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-white/50 hover:text-white transition-colors duration-300"
                            title={social.name}
                            onclick={`trackClick('social_${social.name.toLowerCase()}')`}
                        >
                            {social.icon === "linkedin" && (
                                <svg
                                    class="w-5 h-5"
                                    fill="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
                                </svg>
                            )}
                            {social.icon === "github" && (
                                <svg
                                    class="w-5 h-5"
                                    fill="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                                </svg>
                            )}
                        </a>
                    ))
                }
            </div>

            <a
                title="Purchase Now - £10.00"
                href="/buy"
                onclick="trackClick('get_started')"
                class="hidden sm:inline-flex btn bg-payflo-purple text-white px-6 py-2.5 rounded-xl font-bold text-sm transition-all hover:shadow-lg hover:shadow-payflo-purple/20 active:scale-95"
            >
                Purchase Now - £10.00
            </a>

            <!-- Mobile Menu Toggle -->
            <button
                id="menu-toggle"
                class="md:hidden flex flex-col justify-center items-center w-10 h-10 space-y-1.5 focus:outline-none bg-white/5 rounded-lg border border-white/10"
                aria-label="Toggle Menu"
            >
                <span
                    class="block w-6 h-0.5 bg-white transition-all duration-300 transform origin-center"
                ></span>
                <span
                    class="block w-6 h-0.5 bg-white transition-opacity duration-300"
                ></span>
                <span
                    class="block w-6 h-0.5 bg-white transition-all duration-300 transform origin-center"
                ></span>
            </button>
        </div>
    </div>

    <!-- Mobile Menu -->
    <nav
        id="mobile-menu"
        class="md:hidden bg-[#0a0e27] border-t border-white/5"
        role="navigation"
        aria-label="Mobile navigation"
    >
        <div class="container-custom py-6 px-4 space-y-4">
            {
                navItems.map((item, index) => (
                    <a
                        href={item.href}
                        onclick={`trackClick('mobile_${item.name}')`}
                        class="block py-3 px-4 text-lg font-medium text-white/80 hover:text-white hover:bg-white/5 focus:text-white transition-all duration-300 rounded-xl border border-transparent hover:border-white/10"
                        style={`transition-delay: ${index * 50}ms;`}
                    >
                        {item.name}
                    </a>
                ))
            }
            <div
                class="pt-4 border-t border-white/5 flex items-center justify-between"
            >
                <a
                    href="/buy"
                    onclick="trackClick('mobile_get_started')"
                    class="block text-center py-4 px-8 bg-payflo-purple text-white font-bold rounded-xl transition-all active:scale-95 shadow-lg shadow-payflo-purple/20 flex-grow mr-4"
                >
                    Purchase Now - £10.00
                </a>
                <div class="flex items-center space-x-4 pr-2">
                    {
                        socialLinks.map((social) => (
                            <a
                                href={social.href}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-white/50 hover:text-white transition-colors p-2 bg-white/5 rounded-lg border border-white/10"
                                aria-label={social.name}
                            >
                                {social.icon === "linkedin" && (
                                    <svg
                                        class="w-6 h-6"
                                        fill="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
                                    </svg>
                                )}
                                {social.icon === "github" && (
                                    <svg
                                        class="w-6 h-6"
                                        fill="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                                    </svg>
                                )}
                            </a>
                        ))
                    }
                </div>
            </div>
        </div>
    </nav>
</header>

<style>
    /* Mobile Menu Toggle Animation */
    #menu-toggle.menu-open span:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
    }
    #menu-toggle.menu-open span:nth-child(2) {
        opacity: 0;
    }
    #menu-toggle.menu-open span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
    }

    #mobile-menu {
        max-height: 0;
        opacity: 0;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    #mobile-menu.mobile-menu-open {
        max-height: 600px;
        opacity: 1;
        padding-bottom: 2rem;
    }
</style>

---
import { Image } from "astro:assets";
import Logo from "src/assets/logo.svg";

const navItems = [
    {
        name: "Product",
        href: "/product",
        title: "Free self hosted marketing platform",
    },
    {
        name: "Buy",
        href: "/buy",
        title: "Purchase email credits",
    },
    {
        name: "Solutions",
        href: "/solutions",
        title: "Marketing solutions for industries",
    },
    { name: "Careers", href: "/careers", title: "Careers in email marketing" },
];
---

<script is:inline>
    function trackClick(label) {
        if (typeof window !== "undefined" && window.gtag) {
            window.gtag("event", "click", {
                event_category: "navigation",
                event_label: label,
            });
            // Clicked
        }
    }
</script>

<header
    class="sticky top-0 z-50 w-full bg-[#0a0e27]/90 backdrop-blur-xl border-b border-white/5"
    role="banner"
>
    <div class="container-custom flex items-center justify-between h-20">
        <a
            href="/"
            onclick="trackClick('logo_home')"
            class="flex items-center transition-transform duration-300 hover:scale-105 focus:scale-105 focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 rounded"
            aria-label="Laravel Mail - self hosted marketing platform with automation"
        >
            <Image
                src={Logo}
                alt="Laravel Mail Logo - self hosted marketing platform"
                width={130}
                height={40}
                class="transition-all duration-300 hover:scale-110 hover:-rotate-3 hover:drop-shadow-[0_0_15px_rgba(124,58,237,0.8)] focus:scale-110 focus:-rotate-3 focus:drop-shadow-[0_0_15px_rgba(124,58,237,0.8)] active:scale-95"
            />
        </a>

        <!-- Desktop Nav -->
        <nav
            class="hidden md:flex items-center space-x-10"
            role="navigation"
            aria-label="Main navigation"
        >
            {
                navItems.map((item) => (
                    <a
                        title={item.title}
                        href={item.href}
                        onclick={`trackClick('${item.name}')`}
                        class="text-sm font-bold text-white/70 hover:text-white focus:text-white transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 rounded px-2 py-1"
                    >
                        {item.name}
                    </a>
                ))
            }
        </nav>

        <div class="flex items-center space-x-4">
            <a
                title="Get Started with Laravel Mail"
                href="/buy"
                onclick="trackClick('get_started')"
                class="btn bg-payflo-purple text-white px-6 py-2.5 rounded-xl font-bold text-sm transition-all hover:shadow-lg hover:shadow-payflo-purple/20 active:scale-95"
            >
                Get Started
            </a>
        </div>
    </div>

    <!-- Mobile Menu -->
    <nav
        id="mobile-menu"
        class="hidden md:hidden bg-payflo-dark/95 w-full border-t border-white/5"
        role="navigation"
        aria-label="Mobile navigation"
    >
        <div class="container-custom py-4 space-y-4">
            {
                navItems.map((item, index) => (
                    <a
                        href={item.href}
                        onclick={`trackClick('mobile_${item.name}')`}
                        class="block py-2 px-2 text-white/80 hover:text-white focus:text-white transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 rounded"
                        style={`transition-delay: ${index * 50}ms;`}
                    >
                        {item.name}
                    </a>
                ))
            }
            <a
                href="/buy"
                onclick="trackClick('mobile_get_started')"
                class="block py-2 px-2 text-white/80 hover:text-white focus:text-white transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 rounded"
            >
                Get Started
            </a>
        </div>
    </nav>
</header>

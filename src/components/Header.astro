---
import { Image } from "astro:assets";
import Logo from "src/assets/logo.svg";

const navItems = [
    {
        name: "Product",
        href: "/product",
        title: "Free self hosted marketing platform",
    },
    {
        name: "Deploy",
        href: "/deploy",
        title: "One-click deployment to various platforms",
    },
    { name: "Careers", href: "/careers", title: "Careers in email marketing" },
];

// small helper function for GA tracking
function trackClick(label: string) {
    if (typeof window !== "undefined" && (window as any).gtag) {
        (window as any).gtag("event", "click", {
            event_category: "navigation",
            event_label: label,
        });
        console.log("Clicked");
    }
}
---

<header
    class="sticky top-0 z-50 w-full bg-[#0a0e27]/90 backdrop-blur-xl border-b border-white/5"
    role="banner"
>
    <div class="container-custom flex items-center justify-between h-20">
        <a
            href="/"
            onclick="trackClick('logo_home')"
            class="flex items-center transition-transform duration-300 hover:scale-105 focus:scale-105 focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 rounded"
            aria-label="self hosted social marketing platform with automation"
        >
            <Image
                src={Logo}
                alt="self hosted marketing platform"
                width={130}
                height={40}
                class="transition-all duration-300 hover:brightness-110 focus:brightness-110"
            />
        </a>

        <!-- Desktop Nav -->
        <nav
            class="hidden md:flex items-center space-x-10"
            role="navigation"
            aria-label="Main navigation"
        >
            {
                navItems.map((item) => (
                    <a
                        title={item.title}
                        href={item.href}
                        onclick={`trackClick('${item.name}')`}
                        class="text-sm font-bold text-white/70 hover:text-white focus:text-white transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 rounded px-2 py-1"
                    >
                        {item.name}
                    </a>
                ))
            }
        </nav>

        <div class="flex items-center space-x-4">
            <a
                title="free marketing platform"
                target="_blank"
                href="https://app.laravelmail.com/"
                onclick="trackClick('try_now')"
                class="btn bg-payflo-purple text-white px-6 py-2.5 rounded-xl font-bold text-sm transition-all hover:shadow-lg hover:shadow-payflo-purple/20 active:scale-95 trigger-beta-modal"
            >
                Try Now
            </a>
        </div>
    </div>

    <!-- Mobile Menu -->
    <nav
        id="mobile-menu"
        class="hidden md:hidden bg-payflo-dark/95 w-full border-t border-white/5"
        role="navigation"
        aria-label="Mobile navigation"
    >
        <div class="container-custom py-4 space-y-4">
            {
                navItems.map((item, index) => (
                    <a
                        href={item.href}
                        onclick={`trackClick('mobile_${item.name}')`}
                        class="block py-2 px-2 text-white/80 hover:text-white focus:text-white transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 rounded"
                        style={`transition-delay: ${index * 50}ms;`}
                    >
                        {item.name}
                    </a>
                ))
            }
            <a
                href="https://app.laravelmail.com/"
                onclick="trackClick('mobile_try')"
                class="block py-2 px-2 text-white/80 hover:text-white focus:text-white transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 rounded trigger-beta-modal"
            >
                View Demo
            </a>
        </div>
    </nav>
</header>

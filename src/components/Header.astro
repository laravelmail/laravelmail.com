---
import { Image } from "astro:assets";
import Logo from "src/assets/logo.svg";

const navItems = [
    {
        name: "Product",
        href: "/product",
        title: "Free self hosted marketing platform",
    },
    { name: "Careers", href: "/careers", title: "Careers in email marketing" },
];

// small helper function for GA tracking
function trackClick(label) {
    if (typeof window !== "undefined" && window.gtag) {
        window.gtag("event", "click", {
            event_category: "navigation",
            event_label: label,
        });
        console.log("Clicked");
    }
}
---

<header
    class="sticky top-0 z-50 w-full bg-white/80 backdrop-blur-md border-b border-gray-100"
    role="banner"
>
    <div class="container-custom flex items-center justify-between">
        <a
            href="/"
            onClick={() => trackClick("logo_home")}
            class="flex items-center transition-transform duration-300 hover:scale-105 focus:scale-105 focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 rounded"
            aria-label="self hosted social marketing platform with automation"
        >
            <Image
                src={Logo}
                alt="self hosted marketing platform"
                width={120}
                height={40}
                class="transition-all duration-300 hover:brightness-110 focus:brightness-110"
            />
        </a>

        <!-- Desktop Nav -->
        <nav
            class="hidden md:flex items-center space-x-8"
            role="navigation"
            aria-label="Main navigation"
        >
            {
                navItems.map((item) => (
                    <a
                        title={item.title}
                        href={item.href}
                        onClick={() => trackClick(item.name)}
                        class="text-gray-700 hover:text-payflo-dark focus:text-payflo-dark transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 rounded px-2 py-1"
                    >
                        {item.name}
                    </a>
                ))
            }
        </nav>

        <div class="flex items-center space-x-4">
            <a
                title="free marketing platform"
                target="_blank"
                href="https://app.laravelmail.com/"
                onClick={() => trackClick("try_now")}
                class="btn btn-primary focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 trigger-beta-modal"
            >
                Try Now
            </a>
        </div>
    </div>

    <!-- Mobile Menu -->
    <nav
        id="mobile-menu"
        class="hidden md:hidden bg-white w-full border-t border-gray-100"
        role="navigation"
        aria-label="Mobile navigation"
    >
        <div class="container-custom py-4 space-y-4">
            {
                navItems.map((item, index) => (
                    <a
                        href={item.href}
                        onClick={() => trackClick(`mobile_${item.name}`)}
                        class="block py-2 px-2 text-gray-700 hover:text-payflo-purple focus:text-payflo-purple transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 rounded"
                        style={`transition-delay: ${index * 50}ms;`}
                    >
                        {item.name}
                    </a>
                ))
            }
            <a
                href="https://app.laravelmail.com/"
                onClick={() => trackClick("mobile_try")}
                class="block py-2 px-2 text-gray-700 hover:text-payflo-purple focus:text-payflo-purple transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-payflo-purple focus:ring-offset-2 rounded trigger-beta-modal"
            >
                View Demo
            </a>
        </div>
    </nav>
</header>

---
import { Image } from "astro:assets";
import heroImage from "../assets/dashboard-2.png";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
    class="pt-20 pb-16 md:pt-28 md:pb-24 overflow-hidden relative"
    itemscope
    itemtype="https://schema.org/WebPageElement"
>
    <!-- Subtle background pattern with parallax effect -->
    <div class="absolute inset-0 opacity-5 parallax" data-speed="0.2">
        <div
            class="absolute inset-0 bg-repeat"
            style="background-image: url('/grid-pattern.svg');"
        >
        </div>
    </div>

    <div class="container-custom relative">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <!-- LEFT: Hero Text -->
            <div>
                <div
                    class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-brand-primary text-xs font-bold uppercase tracking-widest mb-6 animate-pulse"
                >
                    {t('hero.early_bird')}
                </div>
                <h1
                    class="animate-on-scroll text-white delay-0 text-4xl md:text-5xl lg:text-6xl font-black leading-tight"
                    itemprop="headline"
                >
                    {t('hero.pill')}
                </h1>
                <p
                    class="animate-on-scroll delay-1 mt-6 text-xl text-gray-200 max-w-lg"
                    itemprop="description"
                >
                    {t('hero.subtitle')}
                </p>
                <div
                    class="animate-on-scroll delay-2 mt-8 flex flex-col sm:flex-row items-center gap-4"
                >
                    <a
                        href="/buy"
                        class="btn btn-primary w-full sm:w-auto text-center"
                        aria-label="Purchase Laravel Mail platform"
                        title="Get Laravel Mail — Self-Hosted Email Marketing"
                        >{t('hero.buy_button')}</a
                    >
                    <a
                        href="#demo-video"
                        title="Watch the Laravel Mail demo video"
                        class="inline-flex items-center gap-2 px-5 py-3 rounded-lg border border-white/20 text-white hover:bg-white/10 transition-all duration-300 font-medium"
                    >
                        <svg
                            class="w-5 h-5 text-brand-primary"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path d="M8 5v14l11-7z"></path>
                        </svg>
                        {t('hero.watch_demo')}
                    </a>
                </div>
            </div>

            <!-- RIGHT: Hero Image -->
            <div class="animate-on-scroll delay-4">
                <div
                    title="email marketing and lead management software"
                    class="relative hover-zoom"
                >
                    <div
                        class="absolute -inset-0.5 bg-gradient-to-r from-brand-primary to-brand-blue rounded-xl blur opacity-30 transition-opacity duration-300 hover:opacity-50"
                    >
                    </div>
                    <div class="relative rounded-xl shadow-xl overflow-hidden">
                         <Image 
                            src={heroImage} 
                            alt="Laravel Mail Dashboard" 
                            loading="eager" 
                            fetchpriority="high" 
                            class="w-full max-w-md mx-auto h-auto transition-all duration-500 hover:scale-110" 
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

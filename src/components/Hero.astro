---
import { Image } from 'astro:assets';
import heroImage from '../assets/logo.svg';
---

<section class="pt-20 pb-16 md:pt-28 md:pb-24 overflow-hidden relative" itemscope itemtype="https://schema.org/WebPageElement">
    <!-- Subtle background pattern with parallax effect -->
    <div class="absolute inset-0 opacity-5 parallax" data-speed="0.2">
        <div class="absolute inset-0 bg-repeat" style="background-image: url('/grid-pattern.svg');"></div>
    </div>

    <div class="container-custom relative">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <!-- LEFT: Hero Text -->
            <div>
                <h1 class="animate-on-scroll delay-0 text-4xl md:text-5xl lg:text-6xl font-bold leading-tight" itemprop="headline">
                    Self hosted <span class="gradient-text">Marketing Platform</span> That Delivers
                </h1>
                <p class="animate-on-scroll delay-1 mt-6 text-xl text-gray-600 max-w-lg" itemprop="description">
                    Free and open source marketing platform for Laravel
                    <span class="font-semibold text-gray-800">No fluff, just real opportunities.</span>
                </p>
                <div class="animate-on-scroll delay-2 mt-8 flex flex-col sm:flex-row gap-4">
                    <a href="/contact" class="btn btn-primary" aria-label="Start your own laravel marketing campaign today" title="Get My Leads - Start your lead generation journey">Get My Leads</a>
                    <a title="self hosted email marketing platform" href="https://app.laravelmail.com" class="btn btn-secondary" aria-label="Try now our open source platform" title="Try now our open source platform">Try now our open source platform</a>
                </div>
                <div class="animate-on-scroll delay-3 mt-8 flex items-center space-x-4">
                    <div class="flex -space-x-2" role="img" aria-label="People using Laravel Mail">
                        <img
                                src="/testimonial-avatar-1.jpg"
                                alt="Alex from GrowthHub - Satisfied B2B lead generation client"
                                class="w-10 h-10 rounded-full border-2 border-white transition-transform duration-300 hover:scale-110 hover:z-10"
                        />
                        <img
                                src="/testimonial-avatar-2.jpg"
                                alt="Maria from RetailPro - Happy retail industry lead client"
                                class="w-10 h-10 rounded-full border-2 border-white transition-transform duration-300 hover:scale-110 hover:z-10"
                        />
                        <img
                                src="/testimonial-avatar-3.jpg"
                                alt="Chen from SaaSify - Successful SaaS lead generation customer"
                                class="w-10 h-10 rounded-full border-2 border-white transition-transform duration-300 hover:scale-110 hover:z-10"
                        />
                    </div>
                    <div class="text-sm text-gray-600">
                        Trusted by marketing teams 🌍 and loved by developers.
                    </div>
                </div>
            </div>

            <!-- RIGHT: Hero Image -->
            <div class="animate-on-scroll delay-4">
                <div class="relative hover-zoom">
                    <div class="absolute -inset-0.5 bg-gradient-to-r from-purple-600 to-blue-500 rounded-xl blur opacity-30 transition-opacity duration-300 hover:opacity-50"></div>
                    <div class="relative bg-white rounded-xl shadow-xl overflow-hidden">
                        <Image
                                src={heroImage}
                                alt="Laravel mail is a self hosted email marketing platform that delivers"
                                class="w-full h-auto transition-all duration-500"
                                width={700}
                                height={500}
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

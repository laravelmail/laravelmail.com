---
import { Image } from "astro:assets";
import heroImage from "../assets/logo.svg";
---

<section
    class="pt-20 pb-16 md:pt-28 md:pb-24 overflow-hidden relative"
    itemscope
    itemtype="https://schema.org/WebPageElement"
>
    <!-- Subtle background pattern with parallax effect -->
    <div class="absolute inset-0 opacity-5 parallax" data-speed="0.2">
        <div
            class="absolute inset-0 bg-repeat"
            style="background-image: url('/grid-pattern.svg');"
        >
        </div>
    </div>

    <div class="container-custom relative">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <!-- LEFT: Hero Text -->
            <div>
                <div
                    class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-brand-primary text-xs font-bold uppercase tracking-widest mb-6 animate-pulse"
                >
                    🔥 Early Bird Offer: Save 90% Today
                </div>
                <h1
                    class="animate-on-scroll text-white delay-0 text-4xl md:text-5xl lg:text-6xl font-black leading-tight"
                    itemprop="headline"
                >
                    <span class="gradient-text">Laravel Mail</span> - Self-Hosted Email Marketing Platform with Templates & Automation
                </h1>
                <h2
                    class="text-2xl md:text-3xl font-bold text-gray-300 mt-2 mb-6"
                >
                    The Ultimate Self-Hosted Email Marketing Solution with Email Templates, Newsletter Templates & Marketing Automation
                </h2>
                <p
                    class="animate-on-scroll delay-1 mt-6 text-xl text-gray-200 max-w-lg"
                    itemprop="description"
                >
                    The <strong class="text-white"
                        >only platform in the world</strong
                    > that combines self-hosted <strong class="text-white">email marketing</strong> with <strong
                        class="text-white">Local AI Marketing Agents</strong
                    > powered by Ollama. Includes <strong class="text-white">email templates</strong>, <strong class="text-white">newsletter templates</strong>, built-in <strong class="text-white">email checker</strong>, and enterprise-grade <strong class="text-white">marketing automation</strong>. Complete data privacy with 
                    <a href="/solutions" class="text-brand-primary hover:text-brand-accent transition-colors underline decoration-dotted underline-offset-4">Laravel email marketing services</a>.
                </p>
                <div
                    class="animate-on-scroll delay-2 mt-8 flex flex-col sm:flex-row items-center gap-6"
                >
                    <a
                        href="/buy"
                        class="btn btn-primary w-full sm:w-auto text-center"
                        aria-label="Start your own marketing campaign today"
                        title="Start your lead generation journey"
                        >Purchase Now - £10.00</a
                    >
                    <a
                        href="https://laravelmail.com/privacy"
                        class="text-gray-400 hover:text-white transition-colors underline decoration-dotted underline-offset-4"
                    >
                        Privacy Policy
                    </a>
                </div>
            </div>

            <!-- RIGHT: Hero Image -->
            <div class="animate-on-scroll delay-4">
                <div
                    title="email marketing and lead management software"
                    class="relative hover-zoom"
                >
                    <div
                        class="absolute -inset-0.5 bg-gradient-to-r from-brand-primary to-brand-blue rounded-xl blur opacity-30 transition-opacity duration-300 hover:opacity-50"
                    >
                    </div>
                    <div class="relative rounded-xl shadow-xl overflow-hidden">
                        <Image
                            src={heroImage}
                            alt="Laravel Mail Logo"
                            class="w-full max-w-md mx-auto h-auto transition-all duration-500 hover:scale-110"
                            loading="eager"
                            fetchpriority="high"
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

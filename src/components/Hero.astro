---
import { Image } from "astro:assets";
import heroImage from "../assets/dashboard-2.png";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="pt-20 pb-16 md:pt-28 md:pb-24 relative" itemscope itemtype="https://schema.org/WebPageElement">
    <div class="container-custom">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <!-- LEFT: Hero Text -->
            <div>
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-brand-primary text-xs font-bold uppercase tracking-widest mb-6">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                    Product Hunt #1 of the Day
                </div>
                <h1 class="text-white delay-0 text-4xl md:text-5xl lg:text-6xl font-black leading-tight" itemprop="headline">
                    {t('hero.pill')}
                </h1>
                <p class="delay-1 mt-6 text-xl text-gray-200 max-w-lg" itemprop="description">
                    {t('hero.subtitle')}
                </p>
                <div class="delay-2 mt-8 flex flex-col sm:flex-row items-center gap-4">
                    <a
                        href="/buy"
                        class="btn btn-primary w-full sm:w-auto text-center"
                        aria-label="Get started with Laravel Mail"
                    >{t('hero.buy_button')}</a>
                    <a
                        href="#demo-video"
                        title="Watch Laravel Mail demo video"
                        class="inline-flex items-center gap-2 px-5 py-3 rounded-lg border border-white/20 text-white hover:bg-white/10 font-medium"
                    >
                        <svg class="w-5 h-5 text-brand-primary" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M8 5v14l11-7z"></path>
                        </svg>
                        {t('hero.watch_demo')}
                    </a>
                </div>
                <div class="mt-6 flex items-center gap-4 text-sm text-gray-400">
                    <span class="flex items-center gap-1">
                        <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                        4,600+ users
                    </span>
                    <span class="flex items-center gap-1">
                        <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                        No credit card
                    </span>
                    <span class="flex items-center gap-1">
                        <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                        Cancel anytime
                    </span>
                </div>
            </div>

            <!-- RIGHT: Hero Image -->
            <div class="delay-4">
                <div title="email marketing and lead management software" class="relative">
                    <div class="absolute -inset-0.5 bg-gradient-to-r from-brand-primary to-brand-blue rounded-xl opacity-30"></div>
                    <div class="relative rounded-xl shadow-xl overflow-hidden">
                         <Image 
                            src={heroImage} 
                            alt="Laravel Mail Dashboard" 
                            loading="eager" 
                            fetchpriority="high" 
                            class="w-full max-w-md mx-auto h-auto" 
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

---
import { Image } from "astro:assets";
import heroImage from "../assets/logo.svg";
---

<section
    class="pt-20 pb-16 md:pt-28 md:pb-24 overflow-hidden relative"
    itemscope
    itemtype="https://schema.org/WebPageElement"
>
    <!-- Subtle background pattern with parallax effect -->
    <div class="absolute inset-0 opacity-5 parallax" data-speed="0.2">
        <div
            class="absolute inset-0 bg-repeat"
            style="background-image: url('/grid-pattern.svg');"
        >
        </div>
    </div>

    <div class="container-custom relative">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <!-- LEFT: Hero Text -->
            <div>
                <h1
                    class="animate-on-scroll text-white delay-0 text-4xl md:text-5xl lg:text-6xl font-bold leading-tight"
                    itemprop="headline"
                >
                    Self hosted <strong class="gradient-text">marketing platform</strong>
                </h1>
                <p
                    class="animate-on-scroll delay-1 mt-6 text-xl text-gray-200 max-w-lg"
                    itemprop="description"
                >
                    Open source marketing platform for developers
                    <span class="font-semibold text-white">No fluff, just real use cases.</span>
                </p>
                <div
                    class="animate-on-scroll delay-2 mt-8 flex flex-col sm:flex-row gap-4"
                >
                    <a
                        href="https://app.laravelmail.com/"
                        target="_blank"
                        class="btn btn-primary"
                        aria-label="Start your own marketing campaign today"
                        title="Start your lead generation journey"
                        >Get Started</a
                    >
                </div>

            </div>

            <!-- RIGHT: Hero Image -->
            <div class="animate-on-scroll delay-4">
                <div
                    title="email marketing and lead management software"
                    class="relative hover-zoom"
                >
                    <div
                        class="absolute -inset-0.5 bg-gradient-to-r from-purple-600 to-blue-500 rounded-xl blur opacity-30 transition-opacity duration-300 hover:opacity-50"
                    >
                    </div>
                    <div
                        class="relative rounded-xl shadow-xl overflow-hidden"
                    >
                        <Image
                            src="/screens/dashboard.png"
                            alt=" provides marketing automation software available to everyone"
                            class="w-full h-auto transition-all duration-500"
                            width={700}
                            height={500}
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

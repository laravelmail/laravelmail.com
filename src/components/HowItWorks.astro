---

<!-- Section 1: Introduction & Quick Start -->
<section class="py-20 bg-brand-bg-darker/40 relative overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 opacity-5">
        <div class="absolute inset-0 bg-repeat"></div>
    </div>

    <div class="container-custom relative">
        <div class="max-w-3xl mx-auto text-center">
            <h2
                class="animate-on-scroll delay-0 text-3xl md:text-4xl font-bold text-white"
            >
                How <strong
                    ><a
                        href="https://laravelmail.com"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-white hover:text-brand-primary transition-colors"
                        >Laravel Mail Marketing</a
                    ></strong
                > Works – Self-Hosted Email Solution
            </h2>
            <p class="animate-on-scroll delay-1 mt-4 text-xl text-gray-400">
                Set up your <b class="text-white"
                    ><a
                        href="https://laravelmail.com"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-white hover:text-brand-primary transition-colors"
                        >self-hosted Laravel Mail marketing solution</a
                    ></b
                > in just three simple steps – connect, configure, and launch high-converting
                email campaigns with full control over your data and infrastructure.
            </p>
        </div>

        <!-- Quick Start: Purchase & Activation Process -->
        <div class="mt-20">
            <h3 class="text-2xl font-bold text-white mb-8 flex items-center">
                <span class="mr-2">🛒</span> Quick Start: Purchase & Activation Process
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                {
                    purchaseSteps.map((step, index) => (
                        <div
                            class={`bg-brand-bg-card/40 backdrop-blur-md rounded-xl p-6 border border-white/10 animate-on-scroll delay-${index + 1}`}
                        >
                            <div class="flex items-center justify-center w-10 h-10 rounded-full bg-brand-primary/20 text-brand-primary font-bold mb-4">
                                {step.step}
                            </div>
                            <h4
                                class="text-lg font-semibold text-white mb-2"
                                set:html={step.title}
                            />
                            <p
                                class="text-sm text-gray-400"
                                set:html={step.description}
                            />
                        </div>
                    ))
                }
            </div>
            <div
                class="mt-8 p-6 bg-brand-bg-card/20 rounded-lg border border-white/5"
            >
                <p class="text-gray-300">
                    <span class="font-bold text-white"
                        >✅ Why This Process?</span
                    > This secure, manual activation ensures license authenticity,
                    prevents unauthorized distribution, and allows our team to provide
                    personalized onboarding support for your self-hosted deployment.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Section 2: Detailed 3-Step Setup -->
<section class="py-24 bg-brand-bg-darker/60 relative overflow-hidden">
    <!-- Subtle animated background -->
    <div class="absolute inset-0 opacity-10">
        <div
            class="absolute top-20 left-10 w-96 h-96 bg-brand-primary/20 rounded-full blur-3xl animate-pulse"
        >
        </div>
        <div
            class="absolute bottom-20 right-10 w-96 h-96 bg-brand-accent/20 rounded-full blur-3xl animate-pulse delay-1000"
        >
        </div>
    </div>

    <div class="container-custom relative">
        <div class="text-center max-w-4xl mx-auto mb-20">
            <h2 class="text-5xl md:text-6xl font-black text-white mb-6">
                <span
                    class="text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-brand-accent"
                    >3-Step Setup</span
                >
            </h2>
            <p class="text-xl md:text-2xl text-gray-400 leading-relaxed">
                From API connection to full-scale automation — here's how <strong
                    ><a
                        href="https://laravelmail.com"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-white hover:text-brand-primary transition-colors"
                        >Laravel Mail Marketing</a
                    ></strong
                > powers your email campaigns.
            </p>
        </div>

        <div class="grid lg:grid-cols-3 gap-10 max-w-7xl mx-auto">
            {
                setupSteps.map((step, index) => (
                    <div
                        class={`group relative bg-brand-bg-card/40 backdrop-blur-sm rounded-3xl p-8 shadow-xl hover:shadow-2xl transition-all duration-500 border border-white/10 hover:border-brand-primary/30 hover:-translate-y-3 animate-on-scroll delay-${index + 2}`}
                    >
                        <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-brand-primary/5 to-brand-accent/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
                        <div class="relative z-10">
                            <div class="flex items-center justify-between mb-6">
                                <div class="flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-r from-brand-primary to-brand-accent text-white text-3xl font-black shadow-2xl">
                                    {step.icon}
                                </div>
                                <span class="text-6xl font-black text-white/10">
                                    {step.number}
                                </span>
                            </div>
                            <h3
                                class="text-2xl font-bold text-white mb-3"
                                set:html={step.title}
                            />
                            <p class="text-gray-400 mb-4">{step.description}</p>
                            <ul class="space-y-2 text-sm text-gray-400">
                                {step.bullets.map((bullet) => (
                                    <li class="flex items-start">
                                        <span class="text-brand-primary mr-2">
                                            •
                                        </span>
                                        <span>{bullet}</span>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    </div>
                ))
            }
        </div>

        <!-- CTA -->
        <div class="text-center mt-20">
            <a
                href="/buy"
                class="inline-flex items-center px-10 py-5 text-xl font-bold text-white bg-gradient-to-r from-brand-primary to-brand-accent rounded-2xl shadow-2xl hover:shadow-brand-primary/50 transform hover:scale-105 transition-all duration-300 group"
            >
                Purchase Now - £10.00
                <svg
                    class="w-7 h-7 ml-3 group-hover:translate-x-2 transition-transform"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="3"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </a>
            <p class="mt-4 text-gray-500">
                One-time purchase • Full access to source code • Lifetime access
                to our leads database, which are email verified leads of
                customers that have purchased products in the past
            </p>
        </div>
    </div>
</section>

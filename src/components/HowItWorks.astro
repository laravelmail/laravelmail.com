---
const steps = [
    {
        number: "01",
        title: "Connect with Laravel Mail API",
        description:
            "Easily integrate with our Laravel Mail API to power your self-hosted email marketing campaigns and manage your email infrastructure at scale.",
    },
    {
        number: "02",
        title: "Configure your Email Marketing Experience",
        description:
            "Customize the Laravel-based interface to match your brand, marketing goals, and automation workflows.",
    },
    {
        number: "03",
        title: "Launch, Automate & Scale",
        description:
            "Go live with your self-hosted email marketing platform, automate campaigns, and scale with growing customer demand.",
    },
];
---

<section class="py-20 bg-payflo-gray relative overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 opacity-5">
        <div
            class="absolute inset-0 bg-repeat"

        >
        </div>
    </div>

    <div class="container-custom relative">
        <div class="max-w-3xl mx-auto text-center">
            <h2
                class="animate-on-scroll delay-0 text-3xl md:text-4xl font-bold"
            >
                How Laravel Mail Marketing Works
            </h2>
            <p class="animate-on-scroll delay-1 mt-4 text-xl text-gray-600">
                Set up your <b
                    title="self hosted laravel mail marketing platform"
                    >self-hosted Laravel Mail marketing solution</b
                > in just three steps – connect, configure, and launch your campaigns.
            </p>
        </div>

        <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8 relative">
            <div
                class="hidden md:block absolute top-16 left-1/6 right-1/6 h-0.5 bg-gradient-to-r from-payflo-purple to-payflo-blue"
            >
            </div>

            {
                steps.map((step, index) => (
                    <article
                        class={`bg-white rounded-xl p-8 shadow-lg border border-gray-100 animate-on-scroll delay-${index + 2} group hover:shadow-xl transition-all duration-300 hover:-translate-y-2`}
                    >
                        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-payflo-purple/10 text-payflo-dark font-semibold transition-all duration-300 group-hover:bg-payflo-purple group-hover:text-white group-hover:scale-110">
                            {step.number}
                        </div>
                        <h3
                            title={step.title}
                            class="mt-6 text-xl font-semibold transition-colors duration-300 group-hover:text-payflo-purple"
                        >
                            {step.title}
                        </h3>
                        <p class="mt-3 text-gray-600">{step.description}</p>

                        {index < steps.length - 1 && (
                            <div class="flex justify-center mt-4 md:hidden">
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-6 w-6 text-payflo-purple animate-bounce"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 14l-7 7m0 0l-7-7m7 7V3"
                                    />
                                </svg>
                            </div>
                        )}
                    </article>
                ))
            }
        </div>

        <div class="mt-16 text-center">
            <div class="animate-on-scroll delay-5">
                <a
                    href="https://app.laravelmail.com/register"
                    class="btn btn-primary group"
                    target="_blank"
                    title="Try Laravel Mail Marketing Platform"
                >
                    <span class="inline-flex items-center">
                        Try Laravel Mail Now
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-5 w-5 ml-2 transition-transform duration-300 group-hover:translate-x-1"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                    </span>
                </a>
            </div>
        </div>
    </div>
</section>
<section class="py-24 bg-gradient-to-b from-white via-purple-50/30 to-white relative overflow-hidden">
    <!-- Subtle animated background -->
    <div class="absolute inset-0 opacity-30">
        <div class="absolute top-20 left-10 w-96 h-96 bg-purple-400/20 rounded-full blur-3xl animate-pulse"></div>
        <div class="absolute bottom-20 right-10 w-96 h-96 bg-pink-400/20 rounded-full blur-3xl animate-pulse delay-1000"></div>
    </div>

    <div class="container mx-auto px-6 lg:px-8 relative">
        <!-- Headline -->
        <div class="text-center max-w-4xl mx-auto mb-20">
            <h2 class="text-5xl md:text-6xl font-black text-gray-900 mb-6">
                Go Live in <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-pink-600">3 Simple Steps</span>
            </h2>
            <p class="text-xl md:text-2xl text-gray-600 leading-relaxed">
                From WhatsApp broadcasts to Instagram DM automation, Google Marketplace listings, and product-driven campaigns —
                launch your full-stack marketing engine in minutes.
            </p>
        </div>

        <!-- Steps -->
        <div class="grid lg:grid-cols-3 gap-10 max-w-7xl mx-auto relative">
            <!-- Connecting Line (Desktop) -->
            <div class="hidden lg:block absolute top-24 left-1/3 right-1/3 h-0.5 bg-gradient-to-r from-purple-400 via-pink-500 to-purple-400 opacity-50"></div>

            <!-- Step 1 -->
            <div class="group relative bg-white/80 backdrop-blur-sm rounded-3xl p-10 shadow-xl hover:shadow-2xl transition-all duration-500 border border-purple-100 hover:border-purple-300 hover:-translate-y-3">
                <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-purple-500/5 to-pink-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="relative z-10">
                    <div class="flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-r from-purple-500 to-pink-600 text-white text-3xl font-black shadow-2xl mb-8">
                        01
                    </div>
                    <h3 class="text-3xl font-bold text-gray-900 mb-4">Connect Your Channels</h3>
                    <p class="text-lg text-gray-600 leading-relaxed">
                        One-click <strong>Facebook Partner Login</strong> for WhatsApp Business API + Instagram.<br><br>
                        Connect your <strong>Google Workspace Marketplace</strong> app.<br><br>
                        Link your product catalog and payment gateways.
                    </p>
                </div>
            </div>

            <!-- Step 2 -->
            <div class="group relative bg-white/80 backdrop-blur-sm rounded-3xl p-10 shadow-xl hover:shadow-2xl transition-all duration-500 border border-purple-100 hover:border-purple-300 hover:-translate-y-3">
                <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-purple-500/5 to-pink-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="relative z-10">
                    <div class="flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-r from-purple-500 to-pink-600 text-white text-3xl font-black shadow-2xl mb-8">
                        02
                    </div>
                    <h3 class="text-3xl font-bold text-gray-900 mb-4">Design Your Flows</h3>
                    <p class="text-lg text-gray-600 leading-relaxed">
                        Use our <strong>drag-and-drop visual automation builder</strong> (the most beautiful one ever built).<br><br>
                        Create WhatsApp sequences, Instagram DM funnels, email journeys, and product-driven campaigns — all in one canvas.
                    </p>
                </div>
            </div>

            <!-- Step 3 -->
            <div class="group relative bg-white/80 backdrop-blur-sm rounded-3xl p-10 shadow-xl hover:shadow-2xl transition-all duration-500 border border-purple-100 hover:border-purple-300 hover:-translate-y-3">
                <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-purple-500/5 to-pink-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="relative z-10">
                    <div class="flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-r from-purple-500 to-pink-600 text-white text-3xl font-black shadow-2xl mb-8">
                        03
                    </div>
                    <h3 class="text-3xl font-bold text-gray-900 mb-4">Launch & Dominate</h3>
                    <p class="text-lg text-gray-600 leading-relaxed">
                        Go live instantly.<br><br>
                        Watch real-time analytics across Email, WhatsApp, Instagram, and Google Marketplace.<br><br>
                        Scale to millions of messages — zero third-party limits.
                    </p>
                </div>
            </div>
        </div>

        <!-- CTA -->
        <div class="text-center mt-20">
            <a
                    href="https://app.laravelmail.com/register"
                    class="inline-flex items-center px-10 py-5 text-xl font-bold text-white bg-gradient-to-r from-purple-600 to-pink-600 rounded-2xl shadow-2xl hover:shadow-purple-500/50 transform hover:scale-105 transition-all duration-300"
            >
                Start Your 14-Day Free Trial
                <svg class="w-7 h-7 ml-3 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
            </a>
            <p class="mt-4 text-gray-500">No credit card required • Unlimited contacts • Full access</p>
        </div>
    </div>
</section>
---
const steps = [
    {
        number: "01",
        title: "Connect with Laravel Mail API",
        description:
            "Easily integrate with our Laravel Mail API to power your self-hosted email marketing campaigns and manage your email infrastructure at scale.",
    },
    {
        number: "02",
        title: "Configure your Email Marketing Experience",
        description:
            "Customize the Laravel-based interface to match your brand, marketing goals, and automation workflows.",
    },
    {
        number: "03",
        title: "Launch, Automate & Scale",
        description:
            "Go live with your self-hosted email marketing platform, automate campaigns, and scale with growing customer demand.",
    },
];
---

<section class="py-20 bg-payflo-gray relative overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 opacity-5">
        <div
            class="absolute inset-0 bg-repeat"
            style="background-image: url('/grid-pattern.svg');"
        >
        </div>
    </div>

    <div class="container-custom relative">
        <div class="max-w-3xl mx-auto text-center">
            <h2
                class="animate-on-scroll delay-0 text-3xl md:text-4xl font-bold"
            >
                How Laravel Mail Marketing Works
            </h2>
            <p class="animate-on-scroll delay-1 mt-4 text-xl text-gray-600">
                Set up your <b
                    title="self hosted laravel mail marketing platform"
                    >self-hosted Laravel Mail marketing solution</b
                > in just three steps – connect, configure, and launch your campaigns.
            </p>
        </div>

        <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8 relative">
            <div
                class="hidden md:block absolute top-16 left-1/6 right-1/6 h-0.5 bg-gradient-to-r from-payflo-purple to-payflo-blue"
            >
            </div>

            {
                steps.map((step, index) => (
                    <article
                        class={`bg-white rounded-xl p-8 shadow-lg border border-gray-100 animate-on-scroll delay-${index + 2} group hover:shadow-xl transition-all duration-300 hover:-translate-y-2`}
                    >
                        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-payflo-purple/10 text-payflo-dark font-semibold transition-all duration-300 group-hover:bg-payflo-purple group-hover:text-white group-hover:scale-110">
                            {step.number}
                        </div>
                        <h3
                            title={step.title}
                            class="mt-6 text-xl font-semibold transition-colors duration-300 group-hover:text-payflo-purple"
                        >
                            {step.title}
                        </h3>
                        <p class="mt-3 text-gray-600">{step.description}</p>

                        {index < steps.length - 1 && (
                            <div class="flex justify-center mt-4 md:hidden">
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-6 w-6 text-payflo-purple animate-bounce"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 14l-7 7m0 0l-7-7m7 7V3"
                                    />
                                </svg>
                            </div>
                        )}
                    </article>
                ))
            }
        </div>

        <div class="mt-16 text-center">
            <div class="animate-on-scroll delay-5">
                <a
                    href="https://app.laravelmail.com/register"
                    class="btn btn-primary group"
                    target="_blank"
                    title="Try Laravel Mail Marketing Platform"
                >
                    <span class="inline-flex items-center">
                        Try Laravel Mail Now
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-5 w-5 ml-2 transition-transform duration-300 group-hover:translate-x-1"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                    </span>
                </a>
            </div>
        </div>
    </div>
</section>

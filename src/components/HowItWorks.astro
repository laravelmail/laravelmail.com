---
const steps = [
    {
        number: "01",
        title: "Connect with Laravel Mail API",
        description:
            "Easily integrate with our Laravel Mail API to power your self-hosted email marketing campaigns and manage your email infrastructure at scale.",
    },
    {
        number: "02",
        title: "Configure your Email Marketing Experience",
        description:
            "Customize the Laravel-based interface to match your brand, marketing goals, and automation workflows.",
    },
    {
        number: "03",
        title: "Launch, Automate & Scale",
        description:
            "Go live with your self-hosted email marketing platform, automate campaigns, and scale with growing customer demand.",
    },
];
---

<section class="py-20 bg-brand-bg-darker/40 relative overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 opacity-5">
        <div class="absolute inset-0 bg-repeat"></div>
    </div>

    <div class="container-custom relative">
        <div class="max-w-3xl mx-auto text-center">
            <h2
                class="animate-on-scroll delay-0 text-3xl md:text-4xl font-bold text-white"
            >
                How Laravel Mail Marketing Works
            </h2>
            <p class="animate-on-scroll delay-1 mt-4 text-xl text-gray-400">
                Set up your <b
                    title="self hosted laravel mail marketing platform"
                    class="text-white"
                    >self-hosted Laravel Mail marketing solution</b
                > in just three steps – connect, configure, and launch your campaigns.
            </p>
        </div>

        <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8 relative">
            <div
                class="hidden md:block absolute top-16 left-1/6 right-1/6 h-0.5 bg-gradient-to-r from-brand-primary to-brand-blue"
            >
            </div>

            {
                steps.map((step, index) => (
                    <article
                        class={`bg-brand-bg-card/40 backdrop-blur-md rounded-xl p-8 shadow-lg border border-white/10 animate-on-scroll delay-${index + 2} group hover:shadow-xl transition-all duration-300 hover:-translate-y-2`}
                    >
                        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-brand-primary/10 text-white font-semibold transition-all duration-300 group-hover:bg-brand-primary group-hover:text-white group-hover:scale-110">
                            {step.number}
                        </div>
                        <h3
                            title={step.title}
                            class="mt-6 text-xl font-semibold text-white transition-colors duration-300 group-hover:text-brand-primary"
                        >
                            {step.title}
                        </h3>
                        <p class="mt-3 text-gray-400">{step.description}</p>

                        {index < steps.length - 1 && (
                            <div class="flex justify-center mt-4 md:hidden">
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-6 w-6 text-brand-primary animate-bounce"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 14l-7 7m0 0l-7-7m7 7V3"
                                    />
                                </svg>
                            </div>
                        )}
                    </article>
                ))
            }
        </div>

        <div class="mt-16 text-center">
            <div class="animate-on-scroll delay-5">
                <a
                    href="/buy"
                    class="btn btn-primary group"
                    title="Get Laravel Mail Marketing Platform"
                >
                    <span class="inline-flex items-center">
                        Purchase Now - £10.00
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-5 w-5 ml-2 transition-transform duration-300 group-hover:translate-x-1"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                    </span>
                </a>
            </div>
        </div>
    </div>
</section>
<section class="py-24 bg-brand-bg-darker/60 relative overflow-hidden">
    <!-- Subtle animated background -->
    <div class="absolute inset-0 opacity-10">
        <div
            class="absolute top-20 left-10 w-96 h-96 bg-brand-primary/20 rounded-full blur-3xl animate-pulse"
        >
        </div>
        <div
            class="absolute bottom-20 right-10 w-96 h-96 bg-brand-accent/20 rounded-full blur-3xl animate-pulse delay-1000"
        >
        </div>
    </div>

    <div class="container-custom relative">
        <!-- Headline -->
        <div class="text-center max-w-4xl mx-auto mb-20">
            <h2 class="text-5xl md:text-6xl font-black text-white mb-6">
                Go Live in <span
                    class="text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-brand-accent"
                    >3 Simple Steps</span
                >
            </h2>
            <p class="text-xl md:text-2xl text-gray-400 leading-relaxed">
                From WhatsApp broadcasts to Instagram DM automation, Google
                Marketplace listings, and product-driven campaigns — launch your
                full-stack marketing engine in minutes.
            </p>
        </div>

        <!-- Steps -->
        <div class="grid lg:grid-cols-3 gap-10 max-w-7xl mx-auto relative">
            <!-- Connecting Line (Desktop) -->
            <div
                class="hidden lg:block absolute top-24 left-1/3 right-1/3 h-0.5 bg-gradient-to-r from-brand-primary/40 via-brand-accent/50 to-brand-primary/40 opacity-50"
            >
            </div>

            <!-- Step 1 -->
            <div
                class="group relative bg-brand-bg-card/40 backdrop-blur-sm rounded-3xl p-10 shadow-xl hover:shadow-2xl transition-all duration-500 border border-white/10 hover:border-brand-primary/30 hover:-translate-y-3"
            >
                <div
                    class="absolute inset-0 rounded-3xl bg-gradient-to-br from-brand-primary/5 to-brand-accent/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                >
                </div>
                <div class="relative z-10">
                    <div
                        class="flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-r from-brand-primary to-brand-accent text-white text-3xl font-black shadow-2xl mb-8"
                    >
                        01
                    </div>
                    <h3 class="text-3xl font-bold text-white mb-4">
                        Connect Your Channels
                    </h3>
                    <p class="text-lg text-gray-400 leading-relaxed">
                        One-click <strong class="text-white"
                            >Facebook Partner Login</strong
                        > for WhatsApp Business API + Instagram.<br /><br />
                        Connect your <strong class="text-white"
                            >Google Workspace Marketplace</strong
                        > app.<br /><br />
                        Link your product catalog and payment gateways.
                    </p>
                </div>
            </div>

            <!-- Step 2 -->
            <div
                class="group relative bg-brand-bg-card/40 backdrop-blur-sm rounded-3xl p-10 shadow-xl hover:shadow-2xl transition-all duration-500 border border-white/10 hover:border-brand-primary/30 hover:-translate-y-3"
            >
                <div
                    class="absolute inset-0 rounded-3xl bg-gradient-to-br from-brand-primary/5 to-brand-accent/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                >
                </div>
                <div class="relative z-10">
                    <div
                        class="flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-r from-brand-primary to-brand-accent text-white text-3xl font-black shadow-2xl mb-8"
                    >
                        02
                    </div>
                    <h3 class="text-3xl font-bold text-white mb-4">
                        Design Your Flows
                    </h3>
                    <p class="text-lg text-gray-400 leading-relaxed">
                        Use our <strong class="text-white"
                            >drag-and-drop visual automation builder</strong
                        > (the most beautiful one ever built).<br /><br />
                        Create WhatsApp sequences, Instagram DM funnels, email journeys,
                        and product-driven campaigns — all in one canvas.
                    </p>
                </div>
            </div>

            <!-- Step 3 -->
            <div
                class="group relative bg-brand-bg-card/40 backdrop-blur-sm rounded-3xl p-10 shadow-xl hover:shadow-2xl transition-all duration-500 border border-white/10 hover:border-brand-primary/30 hover:-translate-y-3"
            >
                <div
                    class="absolute inset-0 rounded-3xl bg-gradient-to-br from-brand-primary/5 to-brand-accent/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                >
                </div>
                <div class="relative z-10">
                    <div
                        class="flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-r from-brand-primary to-brand-accent text-white text-3xl font-black shadow-2xl mb-8"
                    >
                        03
                    </div>
                    <h3 class="text-3xl font-bold text-white mb-4">
                        Launch & Dominate
                    </h3>
                    <p class="text-lg text-gray-400 leading-relaxed">
                        Go live instantly.<br /><br />
                        Watch real-time analytics across Email, WhatsApp, Instagram,
                        and Google Marketplace.<br /><br />
                        Scale to millions of messages — zero third-party limits.
                    </p>
                </div>
            </div>
        </div>

        <!-- CTA -->
        <div class="text-center mt-20">
            <a
                href="/buy"
                class="inline-flex items-center px-10 py-5 text-xl font-bold text-white bg-gradient-to-r from-brand-primary to-brand-accent rounded-2xl shadow-2xl hover:shadow-brand-primary/50 transform hover:scale-105 transition-all duration-300"
            >
                Purchase Now - £10.00
                <svg
                    class="w-7 h-7 ml-3 group-hover:translate-x-2 transition-transform"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="3"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </a>
            <p class="mt-4 text-gray-500">
                One-time purchase • Full access to source code • 10,000 email
                credits included
            </p>
        </div>
    </div>
</section>

---
const partners = [
  { name: "Laravel Company", logo: "/partners/company.png" },
  { name: "Laravel GPT", logo: "/partners/gpt.png" },
];
---

<!-- Stats Section - Social Proof & Trust Signals -->
<section class="py-16 bg-transparent">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-3 md:grid-cols-3 gap-8 text-center">
      <div class="space-y-2">
        <div class="text-4xl md:text-5xl font-bold text-brand-blue">100%</div>
        <div class="text-gray-400">Free</div>
      </div>

      <div class="space-y-2">
        <div class="text-4xl md:text-5xl font-bold text-brand-blue">2K+</div>
        <div class="text-gray-400">Installations</div>
      </div>
      <div class="space-y-2">
        <div class="text-4xl md:text-5xl font-bold text-brand-blue">2M+</div>
        <div class="text-gray-400">Messages Sent Daily</div>
      </div>
    </div>
  </div>
</section>

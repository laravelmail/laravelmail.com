---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const screenshots = [
    {
        src: "/screens/dashboard.png",
        title: "Omnichannel Dashboard",
        description: "View all your marketing metrics, recent activity, and campaign performance in one unified, high-performance dashboard."
    },
    {
        src: "/screens/automation.png",
        title: "Visual Automations",
        description: "Build complex localized customer journeys with our drag-and-drop workflow builder. Connect triggers to actions across any channel."
    },
    {
        src: "/screens/ai-email-marketing.png",
        title: "AI-Powered Content",
        description: "Leverage local AI models via Ollama to generate high-converting email copy and personalize content without external API costs."
    },
    {
        src: "/screens/campaigns-2.png",
        title: "Campaign Management",
        description: "Coordinate multi-platform campaigns with precision. Track every click, open, and conversion with enterprise-grade analytics."
    },
    {
        src: "/screens/inbox-2.png",
        title: "Unified Team Inbox",
        description: "Manage all your customer conversations from Gmail, WhatsApp, and Facebook Messenger in a single, collaborative workspace."
    },
    {
        src: "/screens/subscribers.png",
        title: "Smart Segmentation",
        description: "Target the right audience with surgical precision. Create dynamic segments based on behavior, tags, and lead intelligence."
    },
    {
        src: "/screens/templates.png",
        title: "Beautiful Templates",
        description: "Choose from a library of professionally designed, responsive email templates or build your own with our visual editor."
    },
    {
        src: "/screens/intelligence.png",
        title: "Lead Intelligence",
        description: "Enrich your contacts with data from our 18M+ B2B leads database. Scale your outreach with verified information."
    },
    {
        src: "/screens/workflows-2.png",
        title: "Advanced Logic",
        description: "Implement sophisticated marketing logic with ease. Define wait steps, split paths, and conditional triggers."
    }
];
---

<section class="py-24 bg-transparent relative overflow-hidden">
    <!-- Decorative background elements -->
    <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-[500px] h-[500px] bg-brand-primary/10 blur-[120px] rounded-full pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-brand-blue/10 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="container-custom relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-20">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-brand-primary text-xs font-bold uppercase tracking-widest mb-6">
                ✨ Visual Tour
            </div>
            <h2 class="text-4xl md:text-5xl font-black text-white mb-6 animate-on-scroll">
                Experience the <span class="gradient-text">Platform Interface</span>
            </h2>
            <p class="text-xl text-gray-400 animate-on-scroll delay-1">
                Take a closer look at the tools designed to revolutionize your marketing workflow and scale your business.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {screenshots.map((screen, index) => (
                <div 
                    class={`group relative animate-on-scroll delay-${(index % 3) + 1}`}
                >
                    <div class="absolute -inset-0.5 bg-gradient-to-r from-brand-primary to-brand-blue rounded-2xl blur opacity-0 group-hover:opacity-30 transition-opacity duration-500"></div>
                    <div class="relative h-full bg-[#1e293b]/40 backdrop-blur-md rounded-2xl border border-white/10 overflow-hidden shadow-2xl transition-all duration-500 group-hover:-translate-y-2 group-hover:border-brand-primary/30">
                        <div class="aspect-video overflow-hidden">
                            <img 
                                src={screen.src} 
                                alt={screen.title}
                                class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-105"
                                loading="lazy"
                            />
                            <div class="absolute inset-0 bg-gradient-to-t from-[#0a0e27] via-transparent to-transparent opacity-60"></div>
                        </div>
                        <div class="p-8">
                            <h3 class="text-xl font-bold text-white mb-3 group-hover:text-brand-primary transition-colors cursor-default">{screen.title}</h3>
                            <p class="text-gray-400 text-sm leading-relaxed cursor-default">{screen.description}</p>
                        </div>
                        
                        <!-- Corner Accent -->
                        <div class="absolute top-0 right-0 w-16 h-16 pointer-events-none overflow-hidden">
                            <div class="absolute top-[-20px] right-[-20px] w-10 h-10 bg-brand-primary/20 rotate-45 transform translate-x-5 -translate-y-5"></div>
                        </div>
                    </div>
                </div>
            ))}
        </div>
        
        <div class="mt-20 text-center animate-on-scroll delay-3">
             <a
                href="/buy"
                title="Get started with Laravel Mail today - £40 Setup + £10/mo"
                class="btn btn-primary px-10 py-4 text-lg font-bold shadow-lg shadow-brand-primary/20 hover:scale-[1.05] active:scale-[0.95] transition-all"
            >
                Get Started with Laravel Mail Today
            </a>
            <p class="mt-4 text-gray-500 text-sm italic">
                Self-hosted. Unlimited contacts. Total control.
            </p>
        </div>
    </div>
</section>

<style>
    .gradient-text {
        @apply bg-clip-text text-transparent bg-gradient-to-r from-brand-primary to-brand-blue;
    }
    
    .animate-on-scroll {
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    }
    
    .animate-on-scroll.is-visible {
        opacity: 1;
        transform: translateY(0);
    }
    
    .delay-1 { transition-delay: 0.1s; }
    .delay-2 { transition-delay: 0.2s; }
    .delay-3 { transition-delay: 0.3s; }
</style>

<script>
    const observerOptions = {
        threshold: 0.1
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
            }
        });
    }, observerOptions);

    document.addEventListener('astro:page-load', () => {
        document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
    });
</script>

---
const testimonials = [
  {
    quote:
      "The Laravel Mail Platform crew walked us through setup step by step. Their playbook on nurturing and converting leads has been a total game-changer.",
    author: "David",
    role: "Product Manager at SalesBridge",
    avatar: "/partners/company.png",
  },
  {
    quote:
      "We used to bleed leads in hand-offs. Now with Laravel Mail, we retain, track, and convert like pros. Feels like we built a sales engine in-house.",
    author: "Maria",
    role: "CEO at Moldova",
    avatar: "/partners/gpt.png",
  },
];
---

<section class="py-24 bg-brand-bg-darker relative overflow-hidden">
  <!-- Subtle Background Glows -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-1/4 w-[500px] h-[500px] bg-brand-primary/5 blur-[120px] rounded-full animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-brand-accent/5 blur-[120px] rounded-full animate-pulse" style="animation-delay: 2s;"></div>
  </div>

  <div class="container-custom relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-20 animate-on-scroll">
      <h2
        class="text-4xl md:text-5xl font-black text-white mb-6 leading-tight"
        title="trusted email marketing platform"
      >
        Trusted by <span class="bg-gradient-to-r from-brand-primary to-brand-accent bg-clip-text text-transparent">Industry Leaders</span>
      </h2>
      <p class="text-xl text-gray-400">
        See why developers and marketing teams worldwide choose Laravel Mail for their infrastructure.
      </p>
    </div>

    <!-- Text Testimonials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      {
        testimonials.map((testimonial, index) => (
          <div
            class="testimonial-card p-10 rounded-[2.5rem] bg-[#0f172a]/80 backdrop-blur-xl border border-white/5 hover:border-brand-primary/30 transition-all duration-500 group relative overflow-hidden shadow-2xl"
            style={`animation-delay: ${index * 0.15}s`}
          >
            <!-- Hover Glow Effect -->
            <div class="absolute -top-32 -right-32 w-64 h-64 bg-brand-primary/10 blur-[80px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
            
            <div class="flex items-center mb-8 relative z-10">
              <div class="relative mr-6">
                <!-- Avatar Ring -->
                <div class="absolute inset-0 bg-gradient-to-br from-brand-primary to-brand-accent rounded-2xl blur opacity-20 group-hover:opacity-40 transition-opacity duration-500"></div>
                <img
                  src={testimonial.avatar}
                  alt={testimonial.author}
                  class="relative w-16 h-16 rounded-2xl object-cover border border-white/10 transition-transform duration-500 group-hover:scale-105"
                />
              </div>
              <div>
                <h4 class="text-xl font-bold text-white group-hover:text-brand-primary transition-colors duration-300">
                  {testimonial.author}
                </h4>
                <p class="text-gray-400 font-medium tracking-wide uppercase text-xs">{testimonial.role}</p>
              </div>
            </div>
            
            <div class="relative z-10">
              <svg class="absolute -top-6 -left-3 w-10 h-10 text-brand-primary/10 group-hover:text-brand-primary/20 transition-colors" fill="currentColor" viewBox="0 0 32 32">
                <path d="M10 8v8H6c0 2.2 1.8 4 4 4v4c-4.4 0-8-3.6-8-8V8h8zm14 0v8h-4c0 2.2 1.8 4 4 4v4c-4.4 0-8-3.6-8-8V8h8z"></path>
              </svg>
              <p class="text-gray-300 text-xl leading-relaxed italic pl-8">
                "{testimonial.quote}"
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .testimonial-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.5);
  }
</style>

---
import { Image } from "astro:assets";
import dashboardImage from "../assets/dashboard.png";

const improvements = [
    "Unified omnichannel dashboard",
    "Optimized performance",
    "Enhanced analytics & reporting",
];
---

<div class="max-w-6xl mx-auto">
    <div
        class="bg-gradient-to-r from-purple-900/40 via-pink-900/40 to-purple-900/40 border border-purple-500/30 rounded-xl p-12"
    >
        <div
            class="flex flex-col md:flex-row items-center justify-between gap-8"
        >
            <div class="md:flex-1">
                <h3 class="text-2xl md:text-3xl font-bold mb-3 text-white">
                    Redesigned User Interface
                </h3>
                <p class="text-gray-300 text-lg mb-6">
                    Experience a completely revamped dashboard with intuitive
                    navigation, faster load times, dark mode optimization, and
                    responsive design that works seamlessly across all devices.
                    Manage all your campaigns from a unified, beautiful
                    interface.
                </p>
                <ul class="space-y-3">
                    {
                        improvements.map((improvement) => (
                            <li class="flex items-center text-gray-300">
                                <svg
                                    class="w-5 h-5 mr-3 text-pink-500"
                                    fill="currentColor"
                                    viewBox="0 0 20 20"
                                >
                                    <path
                                        fill-rule="evenodd"
                                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                        clip-rule="evenodd"
                                    />
                                </svg>
                                {improvement}
                            </li>
                        ))
                    }
                </ul>
            </div>

            <div class="md:flex-1">
                <div class="relative group">
                    <div
                        class="absolute -inset-1 bg-gradient-to-r from-purple-500 to-pink-500 rounded-2xl blur opacity-25 group-hover:opacity-40 transition duration-1000"
                    >
                    </div>
                    <div
                        class="relative bg-gray-900 rounded-xl overflow-hidden border border-white/10 shadow-2xl"
                    >
                        <Image
                            src={dashboardImage}
                            alt="Laravel Mail Redesigned UI"
                            class="w-full h-auto transform transition duration-500 hover:scale-105"
                            width={800}
                            height={600}
                            loading="lazy"
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

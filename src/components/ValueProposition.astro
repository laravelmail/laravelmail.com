---
// src/components/MarketingAutomation.astro
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { getRelativeLocaleUrl } from "astro:i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = t('value.title'),
  description = t('value.description')
} = Astro.props;

const solutions = [
  {
    id: "whatsapp-instagram",
    icon: "whatsapp",
    title: t('value.sol1_title'),
    subtitle: t('value.sol1_subtitle'),
    description: t('value.sol1_desc'),
    gradient: "from-green-500 to-emerald-600",
    accentGradient: "from-green-500/10 to-emerald-600/10",
    badgeColor: "bg-green-500/20 text-green-400",
    features: [
      t('demo.coming_soon')
    ],
  },
  {
    id: "google-marketplace",
    icon: "chart",
    title: t('value.sol2_title'),
    subtitle: t('value.sol2_subtitle'),
    description: t('value.sol2_desc'),
    gradient: "from-blue-500 to-indigo-600",
    accentGradient: "from-blue-500/10 to-indigo-600/10",
    badgeColor: "bg-blue-500/20 text-blue-400",
    features: [
      t('demo.coming_soon')
    ],
  },
  {
    id: "saas-agencies",
    icon: "lightning",
    title: t('value.sol3_title'),
    subtitle: t('value.sol3_subtitle'),
    description: t('value.sol3_desc'),
    gradient: "from-purple-500 to-pink-500",
    accentGradient: "from-purple-500/10 to-pink-500/10",
    badgeColor: "bg-purple-500/20 text-purple-400",
    features: [
      t('demo.coming_soon')
    ],
  },
  {
    id: "education-nonprofits",
    icon: "academic",
    title: t('value.sol4_title'),
    subtitle: t('value.sol4_subtitle'),
    description: t('value.sol4_desc'),
    gradient: "from-orange-500 to-red-600",
    accentGradient: "from-orange-500/10 to-red-600/10",
    badgeColor: "bg-orange-500/20 text-orange-400",
    features: [
      t('demo.coming_soon')
    ],
  },
  {
    id: "ai-marketing-agents",
    icon: "robot",
    title: t('value.sol5_title'),
    subtitle: t('value.sol5_subtitle'),
    description: t('value.sol5_desc'),
    gradient: "from-cyan-500 to-blue-600",
    accentGradient: "from-cyan-500/10 to-blue-600/10",
    badgeColor: "bg-cyan-500/20 text-cyan-400",
    features: [
      t('demo.coming_soon')
    ],
  }
];

const iconMap: Record<string, string> = {
  whatsapp: `<svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.884 3.488"></path>
  </svg>`,
  chart: `<svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24">
    <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
  </svg>`,
  lightning: `<svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
  </svg>`,
  academic: `<svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path>
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422A12.083 12.083 0 0112 21.5c-2.694 0-5.092-.884-7.16-2.422L12 14z"></path>
  </svg>`,
  robot: `<svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"></path>
  </svg>`
};
---

<section class="py-24 bg-[#0a0e27]/40 overflow-hidden">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center max-w-4xl mx-auto mb-20">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-brand-primary text-xs font-bold uppercase tracking-widest mb-5">
        {t('value.badge')}
      </div>
      <h2 class="text-4xl md:text-5xl font-black text-white mb-6 leading-tight">
        {title}
        <span class="block text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-pink-500">
          {t('value.title_accent')}
        </span>
      </h2>
      <p class="text-xl text-gray-400 leading-relaxed">
        {description} <a href={getRelativeLocaleUrl(lang, "/solutions")} class="text-brand-primary hover:text-brand-accent transition-colors underline decoration-dotted underline-offset-4">{t('value.see_how')}</a>
      </p>
    </div>

    <!-- Solutions Grid -->
    <div class="grid lg:grid-cols-2 gap-10 max-w-7xl mx-auto">
      {solutions.map((solution) => (
        <div
          class="group relative bg-brand-bg-card/40 backdrop-blur-md rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-500 border border-white/10 overflow-hidden"
          id={solution.id}
        >
          <!-- Gradient Overlay on Hover -->
          <div
            class={`absolute inset-0 bg-gradient-to-br ${solution.accentGradient} opacity-0 group-hover:opacity-100 transition-opacity duration-500`}
          />
          
          <div class="relative p-10">
            <!-- Icon Header -->
            <div class="flex items-center gap-4 mb-6">
              <div class={`p-4 bg-gradient-to-br ${solution.gradient} rounded-2xl shadow-lg`}>
                <Fragment set:html={iconMap[solution.icon]} />
              </div>
              <div>
                <h3 class="text-3xl font-bold text-white">{solution.title}</h3>
                <p class="text-sm text-gray-400 font-medium">{solution.subtitle}</p>
              </div>
            </div>

            <!-- Description -->
            <p class="text-lg text-gray-400 mb-8">
              {solution.description}
            </p>

            <!-- Features List -->
            <ul class="space-y-4">
              {solution.features.map((feature) => (
                <li class="flex items-center text-gray-300">
                  <span class={`w-8 h-8 ${solution.badgeColor} rounded-full flex items-center justify-center font-bold mr-3 flex-shrink-0`}>
                    ✓
                  </span>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>


          </div>
        </div>
      ))}
    </div>

    <!-- The Self-Hosted Advantage -->
    <div class="mt-20 max-w-5xl mx-auto">
      <div class="grid md:grid-cols-3 gap-8">
        <div class="p-8 bg-white/5 rounded-2xl border border-white/10 hover:border-brand-primary/30 transition-colors">
          <div class="text-3xl mb-4">🔒</div>
          <h3 class="text-xl font-bold text-white mb-2">{t('value.adv_privacy_title')}</h3>
          <p class="text-gray-400">{t('value.adv_privacy_desc')}</p>
        </div>
        <div class="p-8 bg-white/5 rounded-2xl border border-white/10 hover:border-brand-primary/30 transition-colors">
          <div class="text-3xl mb-4">💰</div>
          <h3 class="text-xl font-bold text-white mb-2">{t('value.adv_tax_title')}</h3>
          <p class="text-gray-400">{t('value.adv_tax_desc')}</p>
        </div>
        <div class="p-8 bg-white/5 rounded-2xl border border-white/10 hover:border-brand-primary/30 transition-colors">
          <div class="text-3xl mb-4">🛠️</div>
          <h3 class="text-xl font-bold text-white mb-2">{t('value.adv_control_title')}</h3>
          <p class="text-gray-400">{t('value.adv_control_desc')}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  section {
    animation: fadeIn 0.6s ease-in;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .group:hover {
    transform: translateY(-8px);
  }
</style>
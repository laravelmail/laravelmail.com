---
import { ViewTransitions } from "astro:transitions";
import { fade } from "astro:transitions";
import { getImage } from "astro:assets";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BetaModal from "../components/BetaModal.astro";
import UrgencyBanner from "../components/UrgencyBanner.astro";
import PurchaseToast from "../components/PurchaseToast.astro";
import "../styles/global.css";
import "@fontsource/nunito/400.css";
import "@fontsource/nunito/500.css";
import "@fontsource/nunito/600.css";
import "@fontsource/nunito/700.css";
import favIcon from "../assets/favicon.png";

interface Props {
  title: string;
  description?: string;
}

const {
  title = "Laravel Mail & Email Marketing Solutions | Self-Hosted Platform",
  description = "Discover Laravel Mail - the ultimate self-hosted email marketing platform. Send automated campaigns, manage leads, and access a verified B2B database. Perfect for Laravel developers.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <meta name="keywords" content="laravel mail, laravel email, laravel marketing, email marketing platform, self-hosted email, laravel automation" />
    <meta name="author" content="Laravel Mail Team" />
    <meta name="robots" content="index, follow" />
    <meta name="language" content="English" />
    <meta name="revisit-after" content="7 days" />

    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(Astro.url.pathname, Astro.site)}
    />
    <meta name="robots" content="index, follow" />

    <!-- Enhanced View Transitions with fallback -->
    <ViewTransitions fallback="none" />

    <!-- Preconnect to critical third-party domains -->
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://analytics.ahrefs.com" crossorigin />
    <link rel="dns-prefetch" href="https://analytics.ahrefs.com" />
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://static.hotjar.com" crossorigin />
    <link rel="dns-prefetch" href="https://static.hotjar.com" />
    <!-- Preload critical fonts -->
    <link rel="preload" href="/fonts/nunito-v27-latin-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/nunito-v27-latin-700.woff2" as="font" type="font/woff2" crossorigin />
    <!-- Preload critical assets -->
    <link rel="preload" href="/logo.svg" as="image" type="image/svg+xml" />
    <link rel="preload" href="/og-image.png" as="image" type="image/png" />
    <meta
      name="facebook-domain-verification"
      content="decnmc05wnft14fdjzsonqefn3vgos"
    />
    <meta name="author" content="Laravel Mail Team" />

    <!-- Structured data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "@id": "https://laravelmail.com#application",
        "name": "Laravel Mail",
        "description": "The ultimate self-hosted email marketing platform combining Laravel email marketing with Local AI Marketing Agents. Complete data privacy with enterprise-grade automation.",
        "operatingSystem": "Web",
        "applicationCategory": "BusinessApplication",
        "keywords": "laravel mail, laravel email, laravel marketing, email marketing platform, self-hosted email, laravel automation, marketing automation, lead generation",
        "offers": {
          "@type": "Offer",
          "price": "10.00",
          "priceCurrency": "GBP",
          "availability": "https://schema.org/InStock"
        },
        "hasPart": {
          "@type": "SoftwareApplication",
          "name": "Local AI Marketing Agents",
          "description": "AI-powered marketing agents for automated campaigns"
        },
        "hasPart": {
          "@type": "SoftwareApplication",
          "name": "Verified B2B Leads Database",
          "description": "Access to a comprehensive verified leads database"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.8",
          "reviewCount": "1000+",
          "bestRating": "5",
          "worstRating": "1"
        },
        "screenshot": "https://laravelmail.com/og-image.png",
        "url": "https://laravelmail.com",
        "datePublished": "2023-10-01",
        "publisher": {
          "@type": "Organization",
          "name": "Laravel Mail Team",
          "logo": "https://laravelmail.com/logo.svg"
        },
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": "https://laravelmail.com#webpage",
          "name": "Laravel Mail - Self-Hosted Email Marketing & Laravel Marketing Platform",
          "description": "Own your email marketing with Laravel Mail. Self-hosted platform with local AI agents, automated campaigns, and lifetime access to a verified B2B leads database. No monthly fees."
        }
      }
    </script>

    <!-- Organization schema (kept for compatibility) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Laravel Company",
        "url": "https://laravelmail.com",
        "logo": "logo.svg"
      }
    </script>

    <!-- Open Graph -->
    <meta property="og:title" content="Laravel Mail & Email Marketing Solutions | Self-Hosted Platform" />
    <meta property="og:description" content="Discover Laravel Mail - the ultimate self-hosted email marketing platform. Send automated campaigns, manage leads, and access a verified B2B database. Perfect for Laravel developers." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content={new URL("/og-image.png", Astro.site)} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Laravel Mail & Email Marketing Solutions | Self-Hosted Platform" />
    <meta name="twitter:description" content="Discover Laravel Mail - the ultimate self-hosted email marketing platform. Send automated campaigns, manage leads, and access a verified B2B database. Perfect for Laravel developers." />
    <meta
      name="twitter:image"
      content={new URL("/twitter-image.png", Astro.site)}
    />

    <!-- View Transitions CSS Animations -->
    <style is:global>
      /* Smooth fade transition for page changes */
      @keyframes fade-in {
        from {
          opacity: 0;
        }
      }

      @keyframes fade-out {
        to {
          opacity: 0;
        }
      }

      @keyframes slide-from-right {
        from {
          transform: translateX(30px);
        }
      }

      @keyframes slide-to-left {
        to {
          transform: translateX(-30px);
        }
      }

      ::view-transition-old(root) {
        animation:
          180ms cubic-bezier(0.4, 0, 1, 1) both fade-out,
          300ms cubic-bezier(0.4, 0, 0.2, 1) both slide-to-left;
      }

      ::view-transition-new(root) {
        animation:
          320ms cubic-bezier(0, 0, 0.2, 1) 90ms both fade-in,
          300ms cubic-bezier(0.4, 0, 0.2, 1) both slide-from-right;
      }

      /* Smooth transitions for specific elements */
      ::view-transition-old(header),
      ::view-transition-new(header) {
        animation-duration: 200ms;
      }

      /* Reduce motion for accessibility */
      @media (prefers-reduced-motion: reduce) {
        ::view-transition-old(root),
        ::view-transition-new(root) {
          animation: none;
        }
      }

      /* Loading indicator during transitions */
      html.astro-transitioning {
        cursor: wait;
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col bg-brand-bg text-white">
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-N3N6ZKFN"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->

    <UrgencyBanner />
    <Header transition:persist="header" />

    <main
      id="main-content"
      class="flex-grow"
      transition:animate={fade({ duration: "0.3s" })}
    >
      <slot />
    </main>

    <Footer transition:persist="footer" />
    <BetaModal />
    <PurchaseToast />

    <!-- Enhanced Intersection Observer for animations -->
    <script>
      document.addEventListener("astro:page-load", () => {
        const animatedElements =
          document.querySelectorAll(".animate-on-scroll");

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("animated");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
        );

        animatedElements.forEach((element) => {
          observer.observe(element);
        });
      });

      // Handle view transition events
      document.addEventListener("astro:before-preparation", () => {
        // Preparing for navigation...
      });

      document.addEventListener("astro:after-swap", () => {
        // Content swapped!
      });

      // Smooth scroll restoration
      document.addEventListener("astro:page-load", () => {
        if ("scrollRestoration" in history) {
          history.scrollRestoration = "manual";
        }
      });
    </script>

    <!-- Performance Optimizations Script -->
    <script
      async
      src="/scripts/performance-optimizations.js"
      type="module"
    ></script>

    <!-- Hotjar Tracking Code -->
    <script is:inline>
      (function (h, o, t, j, a, r) {
        h.hj =
          h.hj ||
          function () {
            (h.hj.q = h.hj.q || []).push(arguments);
          };
        h._hjSettings = { hjid: 5321464, hjsv: 6 };
        a = o.getElementsByTagName("head")[0];
        r = o.createElement("script");
        r.async = 1;
        r.src = t + h._hjSettings.hjid + j + h._hjSettings.hjsv;
        a.appendChild(r);
      })(window, document, "https://static.hotjar.com/c/hotjar-", ".js?sv=");
    </script>

    <script
      async
      src="/scripts/performance-optimizations.js"
      type="module"
    ></script>

    <script
      async
      src="https://analytics.ahrefs.com/analytics.js"
      data-key="VVrN3f8rO7LVfHMX67813A"
      crossorigin="anonymous"></script>
  </body>
</html>

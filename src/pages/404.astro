---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="404 - Page Not Found | Laravel Mail"
  description="The page you are looking for does not exist. Return to the Laravel Mail homepage to explore our self-hosted marketing platform and leads database."
>
  <section class="py-20 md:py-32 flex items-center min-h-[60vh]">
    <div class="container-custom text-center">
      <h1 class="text-4xl md:text-6xl font-bold mb-6">404</h1>
      <h2 class="text-2xl md:text-3xl font-bold mb-6">Page Not Found</h2>
      <p class="text-xl text-gray-600 mb-10 max-w-xl mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a href="/" class="btn btn-primary"> Back to Home </a>
    </div>
  </section>
</Layout>

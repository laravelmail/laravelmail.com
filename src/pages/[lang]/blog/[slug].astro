---
import { getCollection } from 'astro:content';
import Layout from "../../../layouts/Layout.astro";
import CTASection from "../../../components/CTASection.astro";
import { injectSeoLinks } from "../../../scripts/seo-utils";
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";

import { languages } from "../../../i18n/ui";

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const langs = Object.keys(languages).filter(l => l !== 'en');
  
  const paths = [];
  for (const lang of langs) {
    for (const post of posts) {
      paths.push({
        params: { lang, slug: post.id.replace('.json', '') },
        props: { post },
      });
    }
  }
  return paths;
}

const { post } = Astro.props;
const { lang } = Astro.params;
const t = useTranslations(lang as any);

let { title, date, author, authorRole, authorAvatar, excerpt, content, image, tags } = post.data;

// Inject internal SEO links
content = injectSeoLinks(content);
---

<Layout title={`${title} | Laravel Mail Blog`} description={excerpt}>
    <article class="pt-32 pb-20 bg-brand-bg">
        <div class="container-custom">
            <!-- Header -->
            <div class="max-w-4xl mx-auto mb-12 text-center">
                <div class="flex items-center justify-center gap-4 mb-6">
                    {tags.map(tag => (
                        <span class="text-xs font-bold uppercase tracking-wider text-brand-primary px-3 py-1 bg-brand-primary/10 rounded-full border border-brand-primary/20">
                            {tag}
                        </span>
                    ))}
                    <span class="text-xs text-gray-500">{date}</span>
                </div>
                <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-8 leading-tight">
                    {title}
                </h1>
                <div class="flex items-center justify-center gap-4">
                    <img src={authorAvatar} alt={author} class="w-12 h-12 rounded-full border-2 border-brand-primary" />
                    <div class="text-left">
                        <p class="text-white font-bold">{author}</p>
                        <p class="text-gray-400 text-sm">{authorRole}</p>
                    </div>
                </div>
            </div>

            <!-- Featured Image -->
            <div class="max-w-5xl mx-auto mb-16 rounded-3xl overflow-hidden shadow-2xl shadow-brand-primary/20">
                <img src={image} alt={title} class="w-full h-auto" />
            </div>

            <!-- Content -->
            <div class="max-w-3xl mx-auto">
                <div class="prose prose-invert prose-lg max-w-none 
                    prose-headings:text-white prose-headings:font-bold
                    prose-p:text-gray-300 prose-p:leading-relaxed
                    prose-li:text-gray-300
                    prose-strong:text-white prose-strong:font-bold
                    prose-a:text-brand-primary prose-a:no-underline hover:prose-a:underline
                    prose-img:rounded-2xl
                    prose-blockquote:border-l-brand-primary prose-blockquote:bg-white/5 prose-blockquote:py-2 prose-blockquote:px-8 prose-blockquote:rounded-r-xl">
                    <Fragment set:html={content} />
                </div>

                <p class="text-gray-400 italic mt-12">Note: Blog content is currently available in English.</p>

                <!-- Footer / Tags -->
                <div class="mt-16 pt-8 border-t border-white/10 flex flex-wrap gap-2">
                    <span class="text-white font-bold mr-2">Tags:</span>
                    {tags.map(tag => (
                        <span class="text-sm text-gray-400">#{tag}</span>
                    ))}
                </div>
            </div>
        </div>
    </article>

    <CTASection />
</Layout>

<style is:global>
    /* Custom styles for the injected HTML content */
    .prose .lead-paragraph p {
        @apply text-xl text-gray-200 leading-relaxed italic border-l-4 border-brand-primary pl-6 mb-8;
    }
    
    .prose .highlight-box {
        @apply bg-brand-primary/10 p-8 rounded-2xl my-10 border border-brand-primary/20;
    }

    .prose .feature-box {
        @apply bg-white/5 p-8 rounded-2xl my-10 border border-white/10 shadow-xl;
    }

    .prose .feature-grid {
        display: grid;
        @apply grid-cols-1 md:grid-cols-2 gap-6 my-10;
    }

    .prose .feature-card {
        @apply bg-white/5 p-6 rounded-xl border border-white/10 hover:border-brand-primary/30 transition-colors;
    }

    .prose .security-box {
        @apply bg-brand-primary/5 p-8 rounded-2xl my-10 border border-brand-primary/20;
    }

    .prose .approach-section .grid {
        display: grid;
        @apply grid-cols-1 md:grid-cols-3 gap-6 my-10;
    }

    .prose .approach-section .bg-white {
        @apply bg-white/5 border border-white/10 p-6 rounded-xl text-gray-300;
    }

    .prose .metrics-section ul {
        @apply space-y-4 list-none pl-0;
    }
</style>

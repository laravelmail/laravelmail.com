---
import Layout from "../../layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { languages } from "../../i18n/ui";

export async function getStaticPaths() {
  return Object.keys(languages)
    .filter(lang => lang !== 'en')
    .map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);

const title = t('buy.page_title') || "B2B Lead Packs | Verified Leads Starting at $5 | Laravel Mail";
const description = t('buy.page_description') || "Purchase verified B2B leads in packs. Starting at $5 for 100 leads. No subscription required. Email-verified leads delivered instantly.";
---

<Layout title={title} description={description}>
    <div class="relative overflow-hidden pt-32 pb-20 lg:pt-48 lg:pb-32">
        <!-- Background Decor -->
        <div
            class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10 opacity-30 pointer-events-none"
        >
            <div
                class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-payflo-purple/20 blur-[120px] rounded-full"
            >
            </div>
            <div
                class="absolute bottom-[10%] right-[-10%] w-[30%] h-[30%] bg-payflo-blue/20 blur-[100px] rounded-full"
            >
            </div>
        </div>

        <div class="container-custom">
            <div class="max-w-5xl mx-auto">
                <!-- Header -->
                <div class="text-center mb-12 animate-on-scroll">
                    <!-- Urgency Triggers -->
                    <div
                        class="flex flex-col items-center gap-4 mb-8 animate-on-scroll"
                    >
                        <div
                            class="inline-flex items-center gap-2 px-6 py-2 rounded-full bg-brand-primary/10 border border-brand-primary/30"
                        >
                            <span class="relative flex h-3 w-3">
                                <span
                                    class="animate-pulse absolute inline-flex h-full w-full rounded-full bg-brand-primary opacity-75"
                                ></span>
                                <span
                                    class="relative inline-flex rounded-full h-3 w-3 bg-brand-primary"
                                ></span>
                            </span>
                            <span
                                class="text-sm font-bold text-brand-primary uppercase tracking-wider"
                            >
                                ✓ Trusted by 4,200+ Businesses
                            </span>
                        </div>
                        <p class="text-white/60 text-sm">
                            Most flexible B2B leads + AI agents platform
                        </p>
                    </div>

                    <h1
                        class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight"
                    >
                        B2B Leads & <span class="gradient-text"
                            >AI Marketing</span
                        > in One Platform
                    </h1>
                    <p
                        class="text-xl text-white/70 max-w-3xl mx-auto leading-relaxed"
                    >
                        Access verified B2B leads monthly + deploy AI marketing
                        agents. Self-hosted platform with
                        <strong class="text-white">no per-contact fees</strong>
                        — <strong class="text-white">£40 setup fee</strong> (includes
                        platform & custom server) + <strong class="text-white"
                            >£10/month</strong
                        > rolling (for leads API). Cancel anytime, but you lose access
                        to the leads API.
                    </p>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
                    <!-- Left Column: Pricing & Value -->
                    <div
                        class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8 shadow-2xl animate-on-scroll delay-1"
                    >
                        <div class="flex items-center gap-3 mb-8">
                            <span class="text-3xl">💎</span>
                            <h2 class="text-2xl font-bold m-0 text-white">
                                Subscription Details
                            </h2>
                        </div>

                        <div class="space-y-6">
                            <!-- Price -->
                            <div
                                class="bg-gradient-to-br from-payflo-purple/20 to-payflo-blue/10 rounded-2xl p-6 border border-payflo-purple/30"
                            >
                                <p class="text-white/70 text-sm mb-2">
                                    Starting at
                                </p>
                                <div class="flex items-baseline gap-2">
                                    <span class="text-5xl font-black text-white"
                                        >£40</span
                                    >
                                    <span class="text-white/60 text-lg"
                                        >setup fee</span
                                    >
                                </div>
                                <div class="flex items-baseline gap-2 mt-2">
                                    <span class="text-2xl font-black text-white"
                                        >+ £10</span
                                    >
                                    <span class="text-white/60 text-lg"
                                        >/month (cancel anytime)</span
                                    >
                                </div>
                                <p class="text-white/60 text-sm mt-3">
                                    Cancel anytime • No contracts • No refunds
                                    due to the digital nature of the product
                                </p>
                            </div>

                            <!-- What's Included -->
                            <div class="space-y-4 text-white">
                                <h3 class="text-lg font-semibold">
                                    What You Get Monthly:
                                </h3>
                                <p>• Full Platform Access</p>
                                <p>• 18M+ Verified B2B Leads</p>
                                <p>• AI Marketing Agents</p>
                                <p>• Unlimited Campaigns</p>
                                <p>• Priority Support</p>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Payment & Trust -->
                    <div class="space-y-6 animate-on-scroll delay-2 text-white">
                        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8 shadow-2xl">
                             <h2 class="text-2xl font-bold mb-4">Get Started</h2>
                             <p>Self-hosting and leads platform are currently available in English.</p>
                             <div class="mt-8">
                                <a href="/buy" class="btn btn-primary w-full text-center">Go to English Checkout</a>
                             </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

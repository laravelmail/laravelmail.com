---
import Layout from "../../layouts/Layout.astro";
import CTASection from "../../components/CTASection.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { languages } from "../../i18n/ui";

export async function getStaticPaths() {
  return Object.keys(languages)
    .filter(lang => lang !== 'en')
    .map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);

const team = [
    {
        name: "Wez Furlong",
        role: "Co-Founder",
        bio: "With 25 years of experience in distributed and large-scale systems engineering, including as lead engineer and architect on a top-performing commercial MTA, Wez brings his depth of experience at building high-performance, scalable systems to architect and develop KumoMTA.",
        linkedin: "https://www.linkedin.com/in/wezfurlong/",
    },
    {
        name: "Mike Hillyer",
        role: "Co-Founder",
        bio: "Mike has been working in on-prem email infrastructure since 2006 across multiple organizations including EmailNinjas, an on-prem email infrastructure consulting firm that he founded and successfully exited.",
        linkedin: "https://www.linkedin.com/in/mikehillyer/",
    },
    {
        name: "Tom Mairs",
        role: "Co-Founder",
        bio: "Tom has over thirty years of experience in technology as a leader, consultant, administrator, and Customer Success expert, with the last fifteen years spent in the on-prem and cloud email infrastructure industry.",
        linkedin: "https://www.linkedin.com/in/tommairs/",
    },
];

const pillars = [
    {
        title: "Fair & Transparent Pricing",
        description: "No sudden renewal hikes. No hidden fees. We believe in predictable, fair pricing that scales with your business, not against it.",
    },
    {
        title: "Open Source Foundation",
        description: "Built on open-source principles to directly address industry pain points while ensuring performance, resilience, and security. Your implementation stays yours.",
    },
    {
        title: "Business Continuity",
        description: "No matter what changes occur in our product roadmap, partnerships, or corporate structure, you will always retain full access to and complete control over your implementation.",
    },
];
---

<Layout
    title="KumoMTA - Open Source Email Infrastructure | Laravel Mail"
    description="Discover KumoMTA, an enterprise-grade open source MTA built for high-volume sending. 45+ years of collective email experience behind your deliverability."
>
    <!-- Hero Section -->
    <section class="relative pt-20 pb-16 md:pt-32 md:pb-28 overflow-hidden">
        <div class="absolute inset-0 opacity-10">
            <div
                class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_50%_50%,#7c3aed_0%,transparent_50%)]"
            >
            </div>
        </div>

        <div class="container-custom relative z-10">
            <div class="max-w-4xl mx-auto text-center mb-16">
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-brand-primary text-sm font-medium mb-6">
                    <span>🚀</span>
                    <span>Open Source MTA</span>
                </div>
                <h1
                    class="text-5xl md:text-7xl text-white font-extrabold leading-[1.1] tracking-tight animate-on-scroll"
                >
                    Meet <span class="gradient-text">KumoMTA</span>
                </h1>
                <p
                    class="mt-8 text-xl text-gray-400 leading-relaxed max-w-2xl mx-auto animate-on-scroll delay-1"
                >
                    An entirely new approach to email infrastructure, built on the principles that customers value most: fair pricing, trust-based partnership, and long-term stewardship of mission-critical infrastructure.
                </p>
                <div
                    class="mt-10 flex flex-col sm:flex-row gap-5 justify-center animate-on-scroll delay-2"
                >
                    <a
                        href="https://kumomta.com"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn btn-primary px-10 py-4 text-lg font-bold shadow-lg shadow-brand-primary/20 hover:scale-[1.02] active:scale-[0.98] transition-all"
                    >
                        Learn More
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- What Kumo Stands For -->
    <section class="py-24 bg-brand-bg-darker/40">
        <div class="container-custom">
            <div class="max-w-4xl mx-auto">
                <h2 class="text-4xl md:text-5xl font-bold text-white text-center mb-12">
                    What KumoMTA Stands For
                </h2>
                <div class="bg-brand-bg-card/40 backdrop-blur-md rounded-2xl p-10 shadow-lg border border-white/10">
                    <p class="text-xl text-gray-300 leading-relaxed mb-8">
                        KumoMTA is an entirely new approach to email infrastructure, built on the principles that customers value most: fair and transparent pricing, a durable, trust-based partnership, and the long-term stewardship of mission-critical infrastructure.
                    </p>
                    <p class="text-lg text-gray-400 leading-relaxed">
                        We prioritize delivering lasting value, not competing to be the cheapest option, and will never subject customers to the sudden renewal hikes that are all too common in the market. Our choice of open source was a pragmatic one, allowing us to directly address industry pain points while ensuring performance, resilience, and security.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Core Pillars -->
    <section class="py-24 bg-brand-bg-darker">
        <div class="container-custom">
            <h2 class="text-4xl md:text-5xl font-bold text-white text-center mb-4">
                Core Values
            </h2>
            <p class="text-xl text-gray-400 text-center mb-16 max-w-2xl mx-auto">
                The principles that drive everything we do
            </p>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {
                    pillars.map((pillar, index) => (
                        <div
                            class="bg-brand-bg-card/40 backdrop-blur-md rounded-2xl p-8 shadow-lg border border-white/10 hover:border-brand-primary/30 transition-all animate-on-scroll"
                        >
                            <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-brand-primary to-brand-blue flex items-center justify-center mb-6">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <h3 class="text-2xl font-bold text-white mb-4">
                                {pillar.title}
                            </h3>
                            <p class="text-gray-400 leading-relaxed">
                                {pillar.description}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Team Section -->
    <section class="py-24 bg-brand-bg-darker/40">
        <div class="container-custom">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
                    Meet the Team
                </h2>
                <p class="text-xl text-gray-400">
                    45 Years Of Collective Email Experience
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
                {
                    team.map((member, index) => (
                        <div
                            class="bg-brand-bg-card/40 backdrop-blur-md rounded-2xl p-8 shadow-lg border border-white/10 hover:border-brand-primary/30 transition-all animate-on-scroll"
                        >
                            <div class="w-20 h-20 rounded-full bg-gradient-to-br from-brand-primary to-brand-blue flex items-center justify-center mb-6 mx-auto">
                                <span class="text-3xl font-bold text-white">
                                    {member.name.split(' ').map(n => n[0]).join('')}
                                </span>
                            </div>
                            <h3 class="text-xl font-bold text-white text-center mb-2">
                                {member.name}
                            </h3>
                            <p class="text-brand-primary text-center mb-4 font-medium">
                                {member.role}
                            </p>
                            <p class="text-gray-400 leading-relaxed text-sm">
                                {member.bio}
                            </p>
                            <div class="mt-6 text-center">
                                <a
                                    href={member.linkedin}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors"
                                >
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                                    </svg>
                                    <span class="text-sm">LinkedIn</span>
                                </a>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Experience Section -->
    <section class="py-24 bg-brand-bg-darker">
        <div class="container-custom">
            <div class="max-w-4xl mx-auto text-center">
                <div class="inline-flex items-center gap-3 px-6 py-3 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-brand-primary font-bold text-lg mb-8">
                    <span>45+</span>
                    <span>Years Combined Experience</span>
                </div>
                <h2 class="text-4xl md:text-5xl font-bold text-white mb-8">
                    Founded on 45 Years of Collective Email Experience
                </h2>
                <p class="text-xl text-gray-400 leading-relaxed mb-10">
                    We've been building, deploying, and supporting high-performance MTAs for years. Our roots are in Open-Source, and we know from experience that an Open-Source business model is better for users, the product, and the community.
                </p>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-16">
                    <div class="bg-brand-bg-card/40 backdrop-blur-md rounded-2xl p-6 border border-white/10">
                        <div class="text-4xl font-bold text-brand-primary mb-2">16th</div>
                        <div class="text-gray-400">Release</div>
                    </div>
                    <div class="bg-brand-bg-card/40 backdrop-blur-md rounded-2xl p-6 border border-white/10">
                        <div class="text-4xl font-bold text-brand-primary mb-2">100%</div>
                        <div class="text-gray-400">Open Source</div>
                    </div>
                    <div class="bg-brand-bg-card/40 backdrop-blur-md rounded-2xl p-6 border border-white/10">
                        <div class="text-4xl font-bold text-brand-primary mb-2">∞</div>
                        <div class="text-gray-400">Business Continuity</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <CTASection />
</Layout>

<style>
    .gradient-text {
        @apply bg-clip-text text-transparent bg-gradient-to-r from-brand-primary to-brand-blue;
    }
</style>

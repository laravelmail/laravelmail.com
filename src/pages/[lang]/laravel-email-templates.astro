---
import Layout from "../../layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { languages } from "../../i18n/ui";

export async function getStaticPaths() {
  return Object.keys(languages)
    .filter(lang => lang !== 'en')
    .map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);

const title = "Laravel Email Templates: Design Beautiful Emails with AI | templates.laravelmail.com";
const description = "Design, customize, and export high-converting email templates with AI assistance. Built for Laravel developers with MJML and Blade support.";
---

<Layout
  title={title}
  description={description}
>
  <section class="relative min-h-screen flex items-center pt-24 overflow-hidden bg-grid" style="background-color: #0a0e1a;">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0ea5e9]/5 via-transparent to-transparent" />
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 relative">
      <div class="text-center max-w-4xl mx-auto">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold text-[#0ea5e9] border border-[#0ea5e9]/20 mb-8" style="background-color: rgba(14,165,233,0.1);">
          NEW: AI Content Assistant v2.0
        </span>
        <h1 class="text-4xl md:text-7xl font-black leading-tight mb-6 text-white">
          Design The Future<br />
          <span class="gradient-text">Of Email.</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
          The ultimate template engine for Laravel developers. Create high-converting, responsive emails with AI-driven copy and seamless MJML exports.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="https://templates.laravelmail.com/templates" class="px-8 py-3 gradient-bg rounded-xl text-white font-bold hover:opacity-90 transition-opacity">
            Browse Templates
          </a>
          <a href="https://templates.laravelmail.com/studio" class="px-8 py-3 border border-white/10 rounded-xl text-white font-bold hover:bg-white/10 transition-colors" style="background-color: rgba(255,255,255,0.05);">
            Open Studio

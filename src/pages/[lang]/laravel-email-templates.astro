    </div>
  </section>

  <section class="py-24" style="background-color: #0a0e1a;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-5xl font-black mb-6 text-white">Ready to Transform Your Email Game?</h2>

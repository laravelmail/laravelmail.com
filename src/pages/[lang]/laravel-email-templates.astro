        </div>
      </div>
    </div>
  </section>

  <section class="py-24" style="background-color: #0d1225;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-black mb-4 text-white">Powerful by <span class="gradient-text">Design</span></h2>
        <p class="text-gray-400 text-lg">Everything you need to ship world-class emails in minutes, not hours.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-8 rounded-2xl border border-white/[0.06] hover:border-[#0ea5e9]/30 transition-all" style="background-color: rgba(255,255,255,0.02);">
          <div class="w-12 h-12 rounded-xl gradient-bg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">AI Co-pilot</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Let AI refine your copy, suggests subject lines, and generate dynamic variations for A/B testing.</p>
        </div>
        <div class="p-8 rounded-2xl border border-white/[0.06] hover:border-[#0ea5e9]/30 transition-all" style="background-color: rgba(255,255,255,0.02);">
          <div class="w-12 h-12 rounded-xl gradient-bg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>

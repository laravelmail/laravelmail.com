        <div><div class="text-4xl font-black gradient-text mb-1">500+</div><div class="text-gray-500 text-sm">Email Templates</div></div>
        <div><div class="text-4xl font-black gradient-text mb-1">50K+</div><div class="text-gray-500 text-sm">Developers</div></div>
        <div><div class="text-4xl font-black gradient-text mb-1">10M+</div><div class="text-gray-500 text-sm">Emails Sent</div></div>

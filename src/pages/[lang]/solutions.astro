---
import Layout from "../../layouts/Layout.astro";
import CTASection from "../../components/CTASection.astro";
import UseCases from "../../components/UseCases.astro";
import PlatformShowcase from "../../components/PlatformShowcase.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { languages } from "../../i18n/ui";

export async function getStaticPaths() {
  return Object.keys(languages)
    .filter(lang => lang !== 'en')
    .map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);

const solutions = [
    {
        title: "E-commerce & Retail",
        description:
            "Drive sales with automated cart recovery, personalized product recommendations, and multi-channel post-purchase sequences.",
        icon: "🛍️",
    },
    {
        title: "SaaS & Tech",
        description:
            "Scale your user onboarding, feature adoption, and retention strategies with behavioral triggers and unified team inboxes.",
        icon: "💻",
    },
    {
        title: "Agencies",
        description:
            "Manage multiple client brands from a single dashboard with workspace isolation and white-label reporting.",
        icon: "🏢",
    },
];
---

<Layout
    title={t('nav.solutions') + " | Laravel Mail"}
    description="Tailored email marketing automation for high-growth startups, scaling agencies, and e-commerce brands. Scale your outreach with full data sovereignty."
>
    <!-- Header -->
    <section
        class="pt-20 pb-16 md:pt-32 md:pb-24 bg-brand-bg-darker relative overflow-hidden"
    >
        <div class="absolute inset-0 opacity-5">
            <div
                class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-brand-primary to-transparent"
            >
            </div>
        </div>

        <div class="container-custom relative">
            <div class="text-center max-w-4xl mx-auto">
                <h1
                    class="animate-on-scroll delay-0 text-5xl md:text-7xl font-extrabold leading-tight text-white mb-8"
                >
                    Smart <span class="gradient-text">Solutions</span> for Growth
                </h1>
                <p
                    class="animate-on-scroll delay-1 mt-6 text-xl text-gray-400 max-w-2xl mx-auto"
                >
                    Whether you're a high-growth startup, a scaling agency, or
                    an established e-commerce brand, Laravel Mail provides the
                    infrastructure to dominate your market.
                </p>
            </div>
        </div>
    </section>

    <!-- Industry Grid -->
    <section class="py-24 bg-brand-bg-darker/40">
        <div class="container-custom">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                {
                    solutions.map((solution, index) => (
                        <div
                            class={`bg-brand-bg-card/40 backdrop-blur-md rounded-2xl p-10 shadow-lg border border-white/10 animate-on-scroll delay-${index + 2} hover:border-brand-primary/30 transition-all`}
                        >
                            <div class="text-5xl mb-6">{solution.icon}</div>
                            <h3 class="text-2xl font-bold text-white mb-4">
                                {solution.title}
                            </h3>
                            <p class="text-gray-400 leading-relaxed">
                                {solution.description}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>
    <PlatformShowcase />
    <CTASection />
    <!-- Detailed Use Cases -->
    <UseCases />
</Layout>

<style>
    .gradient-text {
        @apply bg-clip-text text-transparent bg-gradient-to-r from-brand-primary to-brand-blue;
    }
</style>

---
import Layout from "../../layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { getRelativeLocaleUrl } from 'astro:i18n';
import { languages } from "../../i18n/ui";

export async function getStaticPaths() {
  return Object.keys(languages)
    .filter(lang => lang !== 'en')
    .map(lang => ({ params: { lang } }));
}

interface Template {
    name: string;
    thumbnail_url?: string;
    category?: string;
    description?: string;
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);

// Fetch templates from the API
let templatesData: Template[] | null = null;
let error: string | null = null;

try {
    const response = await fetch(
        "https://app.laravelmail.com/api/v1/templates",
    );
    if (!response.ok) {
        throw new Error("Failed to fetch templates");
    }
    const json = await response.json();
    templatesData = json.data;
} catch (e: any) {
    error = e.message;
    console.error(e);
}
---

<Layout
    title={t('templates.title')}
    description={t('templates.description')}
>
    <main class="min-h-screen pt-24 pb-16 bg-brand-bg-darker">
        <div class="container-custom">
            <div class="max-w-4xl mx-auto text-center mb-16 animate-on-scroll">
                <h1 class="text-4xl md:text-5xl font-black text-white mb-6">
                    {t('templates.hero_1')} <span class="gradient-text">{t('templates.hero_2')}</span> {t('templates.hero_3')}
                </h1>
                <p
                    class="text-xl text-gray-400 mb-6 lg:max-w-2xl mx-auto leading-relaxed"
                >
                    {t('templates.hero_subtitle_1')} <strong class="text-white"
                        >{t('templates.hero_subtitle_2')}</strong
                    > {t('templates.hero_subtitle_3')} <strong class="text-white"
                        >{t('templates.hero_subtitle_4')}</strong
                    > {t('templates.hero_subtitle_5')} <strong class="text-white">{t('templates.hero_subtitle_6')}</strong> {t('templates.hero_subtitle_7')}
                </p>
                <div class="flex items-center justify-center space-x-4">
                    <a
                        href="https://github.com/laravelmail"
                        target="_blank"
                        class="inline-flex items-center px-4 py-2 bg-white/5 hover:bg-white/10 border border-white/10 rounded-full text-sm text-gray-300 transition-all"
                    >
                        <svg
                            class="w-4 h-4 mr-2"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
                            ></path></svg
                        >
                        {t('templates.github_cta')}
                    </a>
                </div>
            </div>

            {
                error ? (
                    <div class="max-w-2xl mx-auto p-8 bg-red-500/10 border border-red-500/20 rounded-2xl text-center">
                        <p class="text-red-400 font-semibold">
                            {t('templates.error_loading')}: {error}
                        </p>
                        <p class="mt-2 text-gray-400">
                            {t('templates.try_again')}
                        </p>
                    </div>
                ) : (
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        {templatesData &&
                            templatesData.map((template) => (
                                <div class="group bg-brand-bg-card/40 backdrop-blur-md rounded-2xl border border-white/10 overflow-hidden hover:border-brand-primary/50 transition-all duration-500 hover:-translate-y-2">
                                    <div class="aspect-video relative overflow-hidden bg-gray-900/50">
                                        <img
                                            src={
                                                template.thumbnail_url ||
                                                "/placeholder-template.png"
                                            }
                                            alt={template.name}
                                            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                                            loading="lazy"
                                        />
                                        <div class="absolute inset-0 bg-gradient-to-t from-gray-900 to-transparent opacity-60" />
                                    </div>
                                    <div class="p-6">
                                        <div class="flex justify-between items-start mb-4">
                                            <h3 class="text-xl font-bold text-white group-hover:text-brand-primary transition-colors">
                                                {template.name}
                                            </h3>
                                            <span class="px-2 py-1 bg-brand-primary/20 text-brand-primary text-xs font-bold rounded uppercase tracking-wider">
                                                {template.category || t('templates.cat_basic')}
                                            </span>
                                        </div>
                                        <p class="text-gray-400 text-sm mb-6 line-clamp-2">
                                            {template.description || t('templates.default_desc')}
                                        </p>
                                        <div class="flex items-center justify-between">
                                            <a
                                                href={getRelativeLocaleUrl(lang as string, "/buy")}
                                                class="inline-flex items-center text-brand-primary font-bold hover:underline group-hover:translate-x-1 transition-transform"
                                            >
                                                {t('templates.use_template')}
                                                <svg
                                                    class="w-4 h-4 ml-2"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    viewBox="0 0 24 24"
                                                >
                                                    <path
                                                        stroke-linecap="round"
                                                        stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M17 8l4 4m0 0l-4 4m4-4H3"
                                                    />
                                                </svg>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            ))}
                    </div>
                )
            }
        </div>
    </main>
</Layout>

<style>
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

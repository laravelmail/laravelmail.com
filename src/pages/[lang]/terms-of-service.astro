---
import Layout from "../../layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { languages } from "../../i18n/ui";

export async function getStaticPaths() {
  return Object.keys(languages)
    .filter(lang => lang !== 'en')
    .map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);
---

<Layout
    title={t('footer.terms') + " | Laravel Mail"}
    description="Review the terms of service and usage license for Laravel Mail."
>
    <main class="py-20 px-6 sm:px-8 lg:px-12 max-w-7xl mx-auto">
        <div class="prose prose-slate max-w-3xl mx-auto prose-invert">
            <h1 class="text-4xl font-bold mb-8 text-white">{t('footer.terms')}</h1>

            <p class="text-gray-400 mb-6">
                Last updated: {new Date().toLocaleDateString()}
            </p>

            <section class="mb-8">
                <h2 class="text-2xl font-semibold mb-4 text-white">
                    1. Agreement to Terms
                </h2>
                <p class="text-gray-300">
                    By accessing and using Laravel Mail’s platform and services,
                    you agree to be bound by these Terms of Use and all
                    applicable laws and regulations.
                </p>
            </section>

             <p class="text-gray-400 italic">Note: Content is currently available in English as per legal requirements.</p>
        </div>
    </main>
</Layout>

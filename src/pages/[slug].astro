---
import Layout from "../layouts/Layout.astro";
import CTASection from "../components/CTASection.astro";
import seoData from "../data/seo-variations.json";

export async function getStaticPaths() {
  return seoData.map(page => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
---

<Layout title={page.title} description={page.description}>
    <section class="pt-32 pb-20 bg-brand-bg relative overflow-hidden">
        <div class="container-custom relative">
            <div class="max-w-4xl mx-auto">
                <nav class="mb-12 flex items-center gap-2 text-sm text-gray-500">
                    <a href="/" class="hover:text-brand-primary">Home</a>
                    <span>/</span>
                    <a href="/digital-marketing" class="hover:text-brand-primary">Digital Marketing</a>
                    <span>/</span>
                    <span class="text-white">{page.header}</span>
                </nav>

                <h1 class="text-4xl md:text-6xl font-black text-white mb-8">
                    {page.header}
                </h1>
                
                <div class="prose prose-invert prose-xl max-w-none text-gray-300 mb-16">
                    <p class="text-2xl font-light italic text-brand-primary/80 mb-10 leading-relaxed">
                        Part of our comprehensive <strong>digital marketing</strong> series.
                    </p>
                    <div class="space-y-6">
                        {page.content.split('\n\n').map(para => (
                            <p>{para}</p>
                        ))}
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
                    <div class="p-8 rounded-2xl bg-white/5 border border-white/10">
                        <h2 class="text-2xl font-bold text-white mb-4">Why it matters for Digital Marketing</h2>
                        <p class="text-gray-400">
                            In the competitive world of <strong>marketing digital</strong>, having a specialized approach to {page.header.toLowerCase()} 
                            can set you apart from the competition. Our tools ensure your <strong>digital marketing marketing</strong> 
                            is data-driven and scalable.
                        </p>
                    </div>
                    <div class="p-8 rounded-2xl bg-white/5 border border-white/10">
                        <h2 class="text-2xl font-bold text-white mb-4">How Laravel Mail Helps</h2>
                        <p class="text-gray-400">
                            We provide the infrastructure required to implement a world-class <strong>digital marketing</strong> strategy. 
                            From automation to analytics, we've got your <strong>marketing digital</strong> covered.
                        </p>
                    </div>
                </div>

                <div class="text-center py-12 px-8 rounded-3xl bg-brand-primary/10 border border-brand-primary/20">
                    <h3 class="text-2xl font-bold text-white mb-6">Want to learn more about Digital Marketing?</h3>
                    <a href="/digital-marketing" class="btn btn-primary">Back to Pillar Page</a>
                </div>
            </div>
        </div>
    </section>

    <CTASection />
</Layout>

---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Affiliate Program | Laravel Mail"
    description="Join Laravel Mail's affiliate program and earn 50% commission on every sale. Get paid immediately for referring customers to our B2B lead generation services."
>
    <main class="py-20 px-6 sm:px-8 lg:px-12 max-w-7xl mx-auto">
        <div class="prose prose-slate max-w-3xl mx-auto">
            <h1 class="text-4xl font-bold mb-8">Affiliate Program</h1>

            <p class="text-gray-600 mb-6">
                Last updated: {new Date().toLocaleDateString()}
            </p>

            <section class="mb-8">
                <h2 class="text-2xl font-semibold mb-4">
                    Earn 50% Commission on Every Sale
                </h2>
                <p>
                    Join Laravel Mail's affiliate program and start earning immediate commissions for every customer you refer. We offer an industry-leading 50% commission on all sales made through your referral link.
                </p>
            </section>

            <section class="mb-8">
                <h2 class="text-2xl font-semibold mb-4">How It Works</h2>
                <ol class="list-decimal pl-6 mt-4 space-y-4">
                    <li>
                        <strong>Sign Up</strong> - Apply to join our affiliate program and get your unique referral link.
                    </li>
                    <li>
                        <strong>Share</strong> - Promote Laravel Mail to your audience through your website, blog, social media, or email list.
                    </li>
                    <li>
                        <strong>Earn</strong> - Receive 50% of every sale made through your referral link.
                    </li>
                    <li>
                        <strong>Get Paid Immediately</strong> - No waiting for payouts. You get paid immediately when your referral makes a purchase.
                    </li>
                </ol>
            </section>

            <section class="mb-8">
                <h2 class="text-2xl font-semibold mb-4">Why Promote Laravel Mail?</h2>
                <ul class="list-disc pl-6 mt-4 space-y-2">
                    <li>50% commission - highest in the industry</li>
                    <li>Instant payouts - no minimum thresholds</li>
                    <li>High conversion rates on B2B leads</li>
                    <li>Trusted by 500+ companies worldwide</li>
                    <li>90-day cookie tracking window</li>
                </ul>
            </section>

            <section class="mb-8">
                <h2 class="text-2xl font-semibold mb-4">Contact Us</h2>
                <p>
                    Ready to start earning? Get in touch to learn more about our affiliate program and how you can maximize your commissions.
                </p>
                <p class="mt-4">
                    <a href="/contact" class="text-purple-600 hover:text-purple-700 underline">Contact us</a> to apply for our affiliate program.
                </p>
            </section>
        </div>
    </main>
</Layout>

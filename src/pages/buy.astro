                                    <p class="text-sm text-white/80 mb-2">
                                        Instant Access
                                    </p>
                                    <p class="text-lg font-bold text-white">
                                        £10/month • Cancel Anytime
                                    </p>
                                    <p class="text-xs text-white/60 mt-2">
                                        Start immediately after purchase
                                    </p>
                                </div>

                                <div
                                    id="paypal-button-container-P-5JV683893N289793BNGMDYGA"
                                    class="min-h-[200px]"
                                >
                                </div>
                                <script
                                    src="https://www.paypal.com/sdk/js?client-id=AddiC5z5vZl2wDBLbYo5Ef1a-1U48vvlDeTo1iIHvvrV-J3GgOHMaqwnDWmeCYVIhk3bodChdvIulLmb&vault=true&intent=subscription"
                                    data-sdk-integration-source="button-factory"
                                ></script>
                                <script>
                                    paypal
                                        .Buttons({
                                            style: {
                                                shape: "rect",
                                                color: "gold",
                                                layout: "vertical",
                                                label: "subscribe",
                                            },
                                            createSubscription: function (
                                                data,
                                                actions,
                                            ) {
                                                return actions.subscription.create(
                                                    {
                                                        plan_id:
                                                            "P-5JV683893N289793BNGMDYGA",
                                                    },
                                                );
                                            },
                                            onApprove: function (
                                                data,
                                                actions,
                                            ) {
                                                alert(data.subscriptionID);
                                            },
                                        })
                                        .render(
                                            "#paypal-button-container-P-5JV683893N289793BNGMDYGA",
                                        );
                                </script>

                                <p
                                    class="text-sm text-white/50 text-center px-4 leading-relaxed"
                                >
                                    Secure PayPal checkout • Money-back
                                    guarantee
                                </p>

                                <!-- Trust Badges -->
                                <div
                                    class="flex items-center justify-center gap-3 pt-2"
                                >
                                    <svg
                                        class="h-5 w-5 text-white/50"
                                        fill="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                                        ></path>
                                    </svg>
                                    <span class="text-xs text-white/60"
                                        >SSL Encrypted</span
                                    >
                                </div>
                            </div>
                        </div>

                        <!-- Benefits Grid -->
                        <div class="grid grid-cols-2 gap-4">
                            <div
                                class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6"
                            >
                                <div class="text-3xl mb-3">🚀</div>
                                <h4
                                    class="text-white font-semibold text-sm mb-2"
                                >
                                    Deploy in Minutes
                                </h4>
                                <p class="text-xs text-white/60">
                                    Docker setup + full docs
                                </p>
                            </div>
                            <div
                                class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6"
                            >
                                <div class="text-3xl mb-3">📊</div>

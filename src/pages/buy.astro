---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";

const title = "Buy Email Credits - Laravel Mail | Self-Hosted Platform";
const description =
    "Purchase 10,000 email credits and get full access to the platform source code.";
---

<Layout title={title} description={description}>
    <div class="relative overflow-hidden pt-32 pb-20 lg:pt-48 lg:pb-32">
        <!-- Background Decor -->
        <div
            class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10 opacity-30 pointer-events-none"
        >
            <div
                class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-payflo-purple/20 blur-[120px] rounded-full"
            >
            </div>
            <div
                class="absolute bottom-[10%] right-[-10%] w-[30%] h-[30%] bg-payflo-blue/20 blur-[100px] rounded-full"
            >
            </div>
        </div>

        <div class="container-custom">
            <div class="max-w-4xl mx-auto">
                <!-- Header -->
                <div class="text-center mb-12 animate-on-scroll">
                    <!-- Urgency Triggers -->
                    <div
                        class="flex flex-col items-center gap-4 mb-8 animate-on-scroll"
                    >
                        <div
                            class="inline-flex items-center gap-2 px-6 py-2 rounded-full bg-red-500/10 border border-red-500/20"
                        >
                            <span class="relative flex h-3 w-3">
                                <span
                                    class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-75"
                                ></span>
                                <span
                                    class="relative inline-flex rounded-full h-3 w-3 bg-red-500"
                                ></span>
                            </span>
                            <span
                                class="text-sm font-bold text-red-500 uppercase tracking-wider"
                            >
                                Only <span id="spots-left">7</span> Spots Left at
                                £10.00
                            </span>
                        </div>
                        <p class="text-white/60 text-sm">
                            Introductory price ends in: <span
                                id="page-countdown"
                                class="font-mono text-white font-bold ml-1"
                                >00:00:00</span
                            >
                        </p>
                    </div>

                    <script is:inline>
                        function initUrgency() {
                            // Spots remaining logic
                            const spotsEl =
                                document.getElementById("spots-left");
                            let spots = 7;
                            const interval = setInterval(() => {
                                if (spots > 2 && Math.random() > 0.7) {
                                    spots--;
                                    if (spotsEl) spotsEl.innerText = spots;
                                }
                                if (spots <= 2) clearInterval(interval);
                            }, 45000);

                            // Countdown logic
                            const countdownEl =
                                document.getElementById("page-countdown");
                            const target = new Date();
                            target.setHours(target.getHours() + 4);
                            target.setMinutes(32);

                            function updateCountdown() {
                                const now = new Date();
                                const diff = target - now;
                                if (diff <= 0) return;

                                const h = Math.floor(diff / 3600000)
                                    .toString()
                                    .padStart(2, "0");
                                const m = Math.floor((diff % 3600000) / 60000)
                                    .toString()
                                    .padStart(2, "0");
                                const s = Math.floor((diff % 60000) / 1000)
                                    .toString()
                                    .padStart(2, "0");

                                if (countdownEl)
                                    countdownEl.innerText = `${h}:${m}:${s}`;
                            }
                            setInterval(updateCountdown, 1000);
                            updateCountdown();
                        }

                        document.addEventListener(
                            "astro:page-load",
                            initUrgency,
                        );
                    </script>

                    <h1
                        class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6"
                    >
                        Buy <span class="gradient-text">Credits</span>
                    </h1>
                    <p class="text-xl text-white/70 max-w-2xl mx-auto">
                        Purchase 10,000 email credits for just <span
                            class="text-white font-bold">£10.00</span
                        >
                    </p>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
                    <!-- Left Column: Order Summary -->
                    <div
                        class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8 shadow-2xl animate-on-scroll delay-1"
                    >
                        <div class="flex items-center gap-3 mb-8">
                            <span class="text-3xl">🛒</span>
                            <h2 class="text-2xl font-bold m-0 text-white">
                                Order Summary
                            </h2>
                        </div>

                        <div class="space-y-6">
                            <!-- Item 1 -->
                            <div
                                class="flex justify-between items-start pb-4 border-b border-white/5"
                            >
                                <div>
                                    <h3
                                        class="text-lg font-semibold text-white m-0"
                                    >
                                        Full Platform Source Code Access
                                    </h3>
                                    <p class="text-sm text-white/50 mt-1">
                                        Self-hosted marketing automation
                                    </p>
                                </div>
                                <span class="text-brand-success font-bold"
                                    >Included</span
                                >
                            </div>

                            <!-- Item 2 -->
                            <div
                                class="flex justify-between items-start pb-4 border-b border-white/5"
                            >
                                <div>
                                    <h3
                                        class="text-lg font-semibold text-white m-0"
                                    >
                                        10,000 Email Credits
                                    </h3>
                                    <p class="text-sm text-white/50 mt-1">
                                        Use across any of your agents
                                    </p>
                                </div>
                                <span class="text-white font-bold font-mono"
                                    >£10.00</span
                                >
                            </div>

                            <!-- Item 3 -->
                            <div
                                class="flex justify-between items-start pb-4 border-b border-white/5"
                            >
                                <div>
                                    <h3
                                        class="text-lg font-semibold text-white m-0"
                                    >
                                        Introductory Offer
                                    </h3>
                                    <p class="text-sm text-white/50 mt-1">
                                        Purchase now
                                    </p>
                                </div>
                                <span class="text-brand-success font-bold"
                                    >Included</span
                                >
                            </div>

                            <!-- Total -->
                            <div class="pt-4 flex justify-between items-center">
                                <span class="text-xl font-bold text-white"
                                    >Total</span
                                >
                                <span
                                    class="text-3xl font-black text-white font-mono"
                                    >£10.00</span
                                >
                            </div>
                        </div>

                        <div
                            class="mt-8 p-4 bg-payflo-purple/10 border border-payflo-purple/20 rounded-2xl"
                        >
                            <p
                                class="text-sm text-white/70 leading-relaxed italic"
                            >
                                Credits never expire and can be used across any
                                of your Laravel Mail agents. Future top-ups are
                                billed at a flat rate of £1 per 1,000 credits.
                            </p>
                        </div>
                    </div>

                    <!-- Right Column: Payment Method -->
                    <div class="space-y-6 animate-on-scroll delay-2">
                        <div
                            class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8 shadow-2xl"
                        >
                            <div class="flex items-center gap-3 mb-8">
                                <span class="text-3xl">💳</span>
                                <h2 class="text-2xl font-bold m-0 text-white">
                                    Payment Method
                                </h2>
                            </div>

                            <div class="space-y-6">
                                <a
                                    href="https://www.paypal.com/ncp/links/R2MN2C7WVVNW8"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="w-full bg-[#ffc439] hover:bg-[#f4bb36] text-[#003087] font-bold py-4 px-6 rounded-xl transition-all flex items-center justify-center gap-3 shadow-lg shadow-yellow-500/10 active:scale-[0.98] no-underline"
                                >
                                    <svg
                                        class="h-6 w-auto"
                                        viewBox="0 0 24 24"
                                        fill="currentColor"
                                    >
                                        <path
                                            d="M20.067 8.178c-.622-2.316-2.583-3.611-5.322-3.611H7.88c-.538 0-.986.388-1.07.915L4.037 19.34c-.056.347.21.66.562.66h3.403c.484 0 .887-.35.962-.824l.034-.216.711-4.524.04-.216a.972.972 0 0 1 .962-.823h1.365c3.153 0 5.613-1.284 6.326-4.8c.32-1.579.167-2.784-.335-3.421zM11.77 12.355H9.667l.344-2.186h2.103c.962 0 1.638.169 2.01.503.243.218.375.568.303 1.018-.119.75-.688 1.411-1.638 1.411-1.019 0-1.019-.746-1.019-.746z"
                                        ></path>
                                    </svg>
                                    Pay with PayPal
                                </a>

                                <p
                                    class="text-sm text-white/50 text-center px-4 leading-relaxed"
                                >
                                    Clicking the button will open PayPal's
                                    secure checkout page in a new window.
                                </p>

                                <div
                                    class="flex items-center justify-center gap-6 pt-4 grayscale opacity-50"
                                >
                                    <svg
                                        class="h-6 w-auto"
                                        fill="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            d="M2 4h20v16H2V4zm2 2v12h16V6H4zm1 1h2v2H5V7zm4 0h6v2H9V7zm8 0h2v2h-2V7zM5 11h2v2H5v-2zm4 0h6v2H9v-2zm8 0h2v2h-2v-2zM5 15h2v2H5v-2zm4 0h6v2H9v-2zm8 0h2v2h-2v-2z"
                                        ></path></svg
                                    >
                                    <svg
                                        class="h-6 w-auto"
                                        fill="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"
                                        ></path></svg
                                    >
                                    <svg
                                        class="h-8 w-auto"
                                        viewBox="0 0 32 32"
                                        fill="none"
                                        ><rect
                                            width="32"
                                            height="32"
                                            rx="4"
                                            fill="#1434CB"></rect><path
                                            d="M11 11h2v10h-2V11zm4 0h6v2h-4v2h4v2h-4v2h4v2h-6V11z"
                                            fill="#fff"></path></svg
                                    >
                                </div>
                            </div>
                        </div>

                        <!-- Trust Badge -->
                        <div
                            class="flex items-center gap-4 p-6 bg-white/5 border border-white/10 rounded-2xl animate-on-scroll delay-3"
                        >
                            <div class="p-3 bg-brand-success/10 rounded-full">
                                <svg
                                    class="w-6 h-6 text-brand-success"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-white font-bold m-0">
                                    Secure Transaction
                                </h3>
                                <p class="text-sm text-white/50 m-0">
                                    Bank-grade 256-bit SSL encryption
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Fair Pricing Philosophy Section -->
    <section class="py-24 relative overflow-hidden border-t border-white/5">
        <div class="container-custom">
            <div class="max-w-4xl mx-auto">
                <div
                    class="bg-gradient-to-br from-brand-primary/10 to-brand-blue/10 rounded-[2.5rem] border border-white/10 p-10 md:p-16 text-center animate-on-scroll"
                >
                    <h2
                        class="text-3xl md:text-5xl font-black text-white mb-8 tracking-tight"
                    >
                        "Why is it <span class="text-brand-primary"
                            >so cheap?</span
                        >"
                    </h2>
                    <p
                        class="text-2xl md:text-3xl text-gray-300 leading-relaxed font-medium italic mb-10"
                    >
                        "Because we believe in a <span
                            class="text-white border-b-2 border-brand-primary"
                            >fair price</span
                        > for high-quality core technology."
                    </p>
                    <div
                        class="text-left space-y-6 text-gray-400 text-lg max-w-2xl mx-auto border-t border-white/10 pt-10"
                    >
                        <p>
                            We often get asked why we charge just <b>£10</b> when
                            most competitors charge hundreds per month. The answer
                            is simple: We aren't building a bloated SaaS platform
                            with thousands of overheads.
                        </p>
                        <p>
                            By providing the <strong class="text-white"
                                >source code and Docker infrastructure</strong
                            > directly to you, we eliminate our own hosting and management
                            costs. We pass those massive savings directly to you.
                        </p>
                        <p>
                            We think <b>£10</b> is a fair entry point for developers
                            and businesses to own their core tech, allowing you to
                            scale without being "taxed" based on the number of contacts
                            you have.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- User Reviews Section -->
    <section class="py-24 bg-[#0f172a]/40 relative overflow-hidden">
        <div class="container-custom relative z-10">
            <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll">
                <h2 class="text-4xl font-bold text-white mb-4">
                    What Our Users Say
                </h2>
                <p class="text-xl text-gray-400">
                    Join 4,200+ developers and marketing teams worldwide.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                <div

<script>
    declare global {
        function gtag(...args: any[]): void;
        interface Window {
            paypal: any;
            trackPurchase: (transactionId: string, plan: string, price: number, leads: number) => void;
        }
    }

    interface LeadPlan {
        name: string;
        price: number;
        leads: number;
    }

    const plans: Record<string, LeadPlan> = {
        entry: { name: "Entry", price: 5, leads: 100 },
        growth: { name: "Growth", price: 19, leads: 500 },
        scale: { name: "Scale", price: 49, leads: 2000 },
        pro: { name: "Pro", price: 99, leads: 5000 },
    };

    let currentPlan = "growth";

    function updateSelectedPlanDisplay(planKey: string) {
        const plan = plans[planKey];
        if (!plan) return;

        currentPlan = planKey;
        const planNameEl = document.getElementById("plan-name");
        const planPriceEl = document.getElementById("plan-price");

        if (planNameEl) {
            planNameEl.textContent = `${plan.name} (${plan.leads.toLocaleString()} leads)`;
        }
        if (planPriceEl) {
            planPriceEl.textContent = `$${plan.price}`;
        }

        if (typeof gtag !== "undefined") {
            gtag("event", "select_item", {
                currency: "USD",
                value: plan.price,
                items: [
                    {
                        item_id: `lead_pack_${planKey}`,
                        item_name: `${plan.name} Lead Pack`,
                        item_category: "Lead Packs",
                        item_variant: `${plan.leads} leads`,
                        price: plan.price,
                        quantity: 1,
                    },
                ],
            });
        }
    }

    function initPayPal() {
        const container = document.querySelector("#paypal-button-container");
        if (!container || !window.paypal) {
            console.warn("PayPal SDK not loaded yet, retrying...");
            setTimeout(initPayPal, 500);
            return;
        }

        container.innerHTML = "";

        window.paypal
            .Buttons({
                style: {
                    shape: "rect",
                    color: "gold",
                    layout: "vertical",
                    label: "pay",
                },
                createOrder: function (data: any, actions: any) {
                    const plan = plans[currentPlan];

                    if (typeof gtag !== "undefined") {
                        gtag("event", "add_to_cart", {
                            currency: "USD",
                            value: plan.price,
                            items: [
                                {
                                    item_id: `lead_pack_${currentPlan}`,
                                    item_name: `${plan.name} Lead Pack`,
                                    item_category: "Lead Packs",
                                    item_variant: `${plan.leads} leads`,
                                    price: plan.price,
                                    quantity: 1,
                                },
                            ],
                        });

                        gtag("event", "begin_checkout", {
                            currency: "USD",
                            value: plan.price,
                            items: [
                                {
                                    item_id: `lead_pack_${currentPlan}`,
                                    item_name: `${plan.name} Lead Pack`,
                                    item_category: "Lead Packs",
                                    item_variant: `${plan.leads} leads`,
                                    price: plan.price,
                                    quantity: 1,
                                },
                            ],
                        });
                    }

                    return actions.order.create({
                        purchase_units: [
                            {
                                amount: {
                                    currency_code: "USD",
                                    value: plan.price.toString(),
                                },
                                description: `${plan.name} Lead Pack - ${plan.leads} B2B Leads`,
                            },
                        ],
                    });
                },
                onApprove: function (data: any, actions: any) {
                    return actions.order.capture().then(function (details: any) {
                        const plan = plans[currentPlan];
                        console.log("Lead delivery integration pending for:", plan);

                        window.trackPurchase(
                            details.id,
                            currentPlan,
                            plan.price,
                            plan.leads,
                        );

                        window.location.href = `/thanks?id=${details.id}&plan=${currentPlan}`;
                    });
                },
            })
            .render("#paypal-button-container");
    }

    function trackPurchase(transactionId: string, plan: string, price: number, leads: number) {
        if (typeof gtag !== "undefined") {
            gtag("event", "purchase", {
                transaction_id: transactionId,
                value: price,
                currency: "USD",
                items: [
                    {
                        item_id: `lead_pack_${plan}`,
                        item_name: `${plans[plan]?.name || plan} Lead Pack`,
                        item_category: "Lead Packs",
                        item_variant: `${leads} leads`,
                        price: price,
                        quantity: 1,
                    },
                ],
            });

            gtag("event", "lead_purchase", {
                plan: plan,
                leads: leads,
                value: price,
            });
        }
    }

    window.trackPurchase = trackPurchase;

    document.addEventListener("astro:page-load", () => {
        document.querySelectorAll(".select-plan").forEach((card: Element) => {
            card.addEventListener("click", function (this: Element) {
                const planKey = this.getAttribute("data-plan");
                if (planKey) {
                    document
                        .querySelectorAll(".select-plan")
                        .forEach((c) => c.classList.remove("ring-2", "ring-brand-primary"));
                    this.classList.add("ring-2", "ring-brand-primary");
                    updateSelectedPlanDisplay(planKey);

                    const paypalContainer = document.querySelector("#paypal-button-container");
                    if (paypalContainer) {
                        initPayPal();
                    }
                }
            });
        });

        document.querySelectorAll(".select-plan[data-plan='growth']")[0]?.classList.add("ring-2", "ring-brand-primary");

        initPayPal();

        if (typeof gtag === "undefined") return;

        const planList = ["entry", "growth", "scale", "pro"];
        gtag("event", "view_item_list", {
            currency: "USD",
            value: 19,
            item_list_id: "lead_packs",
            item_list_name: "Lead Packs",
            items: planList.map((key) => {
                const plan = plans[key];
                return {
                    item_id: `lead_pack_${key}`,
                    item_name: `${plan.name} Lead Pack`,
                    item_category: "Lead Packs",
                    item_variant: `${plan.leads} leads`,
                    price: plan.price,
                    quantity: 1,
                    index: planList.indexOf(key),
                };
            }),
        });

        const sections = [
            {
                id: "comparison-section",
                name: "Comparison Table",
                el: document.querySelector("section:has(table)"),
            },
            {
                id: "reviews-section",
                name: "User Reviews",
                el: document.querySelector(
                    "section:has(.grid-cols-1.md\\:grid-cols-2)",
                ),
            },
            {
                id: "faq-section",
                name: "FAQ Section",
                el: document.querySelector("details")?.closest("div.mb-16"),
            },
            {
                id: "final-cta",
                name: "Final CTA",
                el: document.querySelector(
                    ".bg-gradient-to-r.from-payflo-purple",
                ),
            },
        ];

        const observerOptions = { threshold: 0.5 };
        const visibilityObserver = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    const section = sections.find((s) => s.el === entry.target);
                    if (section) {
                        gtag("event", "section_view", {
                            section_id: section.id,
                            section_name: section.name,
                        });
                        visibilityObserver.unobserve(entry.target);
                    }
                }
            });
        }, observerOptions);

        sections.forEach((s) => s.el && visibilityObserver.observe(s.el));

        document.querySelectorAll("details").forEach((faq) => {
            faq.addEventListener("toggle", (e) => {
                if (faq.open) {
                    const question =
                        faq.querySelector("summary span")?.textContent;
                    gtag("event", "faq_open", {
                        question: question,
                    });
                }
            });
        });

        const timeMilestones = [30, 60, 120, 300];
        timeMilestones.forEach((seconds) => {
            setTimeout(() => {
                gtag("event", "time_on_page", {
                    seconds: seconds,
                });
            }, seconds * 1000);
        });

        document
            .querySelectorAll(
                ".flex.items-start.gap-4 .text-white.font-semibold",
            )
            .forEach((benefit) => {
                benefit.parentElement?.addEventListener("click", () => {
                    gtag("event", "benefit_click", {
                        benefit_name: benefit.textContent?.trim(),
                    });
                });
            });
    });
</script>

<style>
    .gradient-text {
        @apply bg-clip-text text-transparent bg-gradient-to-r from-payflo-purple via-payflo-pink to-payflo-blue;
        background-size: 200% auto;
        animation: gradient-x 3s linear infinite;
    }

    @keyframes gradient-x {
        0% {
            background-position: 0% 50%;
        }
        50% {
            background-position: 100% 50%;
        }
        100% {
            background-position: 0% 50%;
        }
    }

    details summary::-webkit-details-marker {
        display: none;
    }

    table {
        @apply w-full;
    }

    th,
    td {
        @apply text-left py-4 px-4;
    }

    th {
        @apply border-b border-white/10;
    }
</style>

<script>
    // Google Analytics 4 Ecommerce Tracking for Buy Page
    document.addEventListener("astro:page-load", () => {
        // Track page view with ecommerce data
        if (typeof gtag !== "undefined") {
            // View item event
            gtag("event", "view_item", {
                currency: "GBP",
                value: 10.0,
                items: [
                    {
                        item_id: "leads_database_lifetime",
                        item_name: "Lifetime Leads Database Access",
                        item_category: "Leads Database",
                        item_variant: "Introductory Offer",
                        price: 10.0,
                        quantity: 1,
                    },
                ],
            });

            // Begin checkout event when page loads
            gtag("event", "begin_checkout", {
                currency: "GBP",
                value: 10.0,
                items: [
                    {
                        item_id: "leads_database_lifetime",
                        item_name: "Lifetime Leads Database Access",
                        item_category: "Leads Database",
                        item_variant: "Introductory Offer",
                        price: 10.0,
                        quantity: 1,
                    },
                ],
            });

            // GA4 Ecommerce: begin_checkout event sent
        }

        // Track PayPal button clicks
        const paypalButtons = document.querySelectorAll(
            'a[href*="paypal.com"]',
        );
        paypalButtons.forEach((button) => {
            button.addEventListener("click", function (e) {
                if (typeof gtag !== "undefined") {
                    // Add to cart event
                    gtag("event", "add_to_cart", {
                        currency: "GBP",
                        value: 10.0,
                        items: [
                            {
                                item_id: "leads_database_lifetime",
                                item_name: "Lifetime Leads Database Access",
                                item_category: "Leads Database",
                                item_variant: "Introductory Offer",
                                price: 10.0,
                                quantity: 1,
                            },
                        ],
                    });

                    // Track click to PayPal
                    gtag("event", "click", {
                        event_category: "ecommerce",
                        event_label: "PayPal Checkout Button",
                        value: 10.0,
                    });

                    // GA4 Ecommerce: add_to_cart and click events sent
                }
            });
        });
    });

    // Optional: Track purchase completion (call this from a success page or webhook)
    function trackPurchase(transactionId) {
        if (typeof gtag !== "undefined") {
            gtag("event", "purchase", {
                transaction_id: transactionId,
                value: 10.0,
                currency: "GBP",
                tax: 0,
                shipping: 0,
                items: [
                    {
                        item_id: "leads_database_lifetime",
                        item_name: "Lifetime Leads Database Access",
                        item_category: "Leads Database",
                        item_variant: "Introductory Offer",
                        price: 10.0,
                        quantity: 1,
                    },
                ],
            });
            // GA4 Ecommerce: purchase event sent
        }
    }

    // Make trackPurchase available globally for webhook/success page callbacks
    window.trackPurchase = trackPurchase;
</script>


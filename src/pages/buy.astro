                                >🤖</span
                            >
                            <div>
                                <p class="font-semibold text-white mb-1">
                                    {t('value.sol5_title')}
                                </p>
                                <p>
                                    {t('value.sol5_desc')}
                                </p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <span

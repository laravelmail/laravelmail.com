                                class="p-3 bg-brand-success/10 rounded-full flex-shrink-0"
                            >
                                <svg
                                    class="w-6 h-6 text-brand-success"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-white font-bold m-0 text-sm">
                                    Bank-Grade Security
                                </h3>
                                <p class="text-xs text-white/50 m-0">
                                    256-bit SSL encryption • Secure PayPal
                                    checkout
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Why Subscription Model Section -->
    <section

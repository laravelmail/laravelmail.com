                                </p>
                                <p>
                                    {t('value.adv_automation_desc')}
                                </p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <span
                                class="text-2xl text-brand-primary flex-shrink-0"
                                >💰</span
                            >
                            <div>
                                <p class="font-semibold text-white mb-1">
                                    {t('value.adv_cost_title')}
                                </p>
                                <p>
                                    {t('value.adv_cost_desc')}
                                </p>
                            </div>

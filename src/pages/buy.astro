            ],
        });

        gtag("event", "begin_checkout", {
            currency: "GBP",
            value: 10.0,
            items: [
                {
                    item_id: "b2b_leads_subscription",
                    item_name: "B2B Leads + AI Agents Monthly Subscription",
                    item_category: "Subscription",
                    item_variant: "Monthly £10",

---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";

const title =
    "B2B Leads Platform & AI Marketing Agents | £10/month | Laravel Mail";
const description =
    "Access verified B2B leads + AI marketing agents monthly. Start automating your outreach with our self-hosted platform. £10/month, cancel anytime. No setup fees.";
const keywords =
    "B2B leads, email marketing, AI agents, marketing automation, verified leads, self-hosted email";
---

<Layout title={title} description={description}>
    <div class="relative overflow-hidden pt-32 pb-20 lg:pt-48 lg:pb-32">
        <!-- Background Decor -->
        <div
            class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10 opacity-30 pointer-events-none"
        >
            <div
                class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-payflo-purple/20 blur-[120px] rounded-full"
            >
            </div>
            <div
                class="absolute bottom-[10%] right-[-10%] w-[30%] h-[30%] bg-payflo-blue/20 blur-[100px] rounded-full"
            >
            </div>
        </div>

        <div class="container-custom">
            <div class="max-w-5xl mx-auto">
                <!-- Header -->
                <div class="text-center mb-12 animate-on-scroll">
                    <!-- Urgency Triggers -->
                    <div
                        class="flex flex-col items-center gap-4 mb-8 animate-on-scroll"
                    >
                        <div
                            class="inline-flex items-center gap-2 px-6 py-2 rounded-full bg-brand-primary/10 border border-brand-primary/30"
                        >
                            <span class="relative flex h-3 w-3">
                                <span
                                    class="animate-pulse absolute inline-flex h-full w-full rounded-full bg-brand-primary opacity-75"
                                ></span>
                                <span
                                    class="relative inline-flex rounded-full h-3 w-3 bg-brand-primary"
                                ></span>
                            </span>
                            <span
                                class="text-sm font-bold text-brand-primary uppercase tracking-wider"
                            >
                                ✓ Trusted by 4,200+ Businesses
                            </span>
                        </div>
                        <p class="text-white/60 text-sm">
                            Most flexible B2B leads + AI agents platform
                        </p>
                    </div>

                    <h1
                        class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight"
                    >
                        B2B Leads & <span class="gradient-text"
                            >AI Marketing</span
                        > in One Platform
                    </h1>
                    <p
                        class="text-xl text-white/70 max-w-3xl mx-auto leading-relaxed"
                    >
                        Access verified B2B leads monthly + deploy AI marketing
                        agents. Self-hosted platform with
                        <strong class="text-white">no per-contact fees</strong>
                        —just <strong class="text-white">£10/month</strong>,
                        cancel anytime.
                    </p>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
                    <!-- Left Column: Pricing & Value -->
                    <div
                        class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8 shadow-2xl animate-on-scroll delay-1"
                    >
                        <div class="flex items-center gap-3 mb-8">
                            <span class="text-3xl">💎</span>
                            <h2 class="text-2xl font-bold m-0 text-white">
                                Subscription Details
                            </h2>
                        </div>

                        <div class="space-y-6">
                            <!-- Price -->
                            <div
                                class="bg-gradient-to-br from-payflo-purple/20 to-payflo-blue/10 rounded-2xl p-6 border border-payflo-purple/30"
                            >
                                <p class="text-white/70 text-sm mb-2">
                                    Starting at
                                </p>
                                <div class="flex items-baseline gap-2">
                                    <span class="text-5xl font-black text-white"
                                        >£10</span
                                    >
                                    <span class="text-white/60 text-lg"
                                        >/month</span
                                    >
                                </div>
                                <p class="text-white/60 text-sm mt-3">
                                    Cancel anytime • No contracts • Full refund
                                    if unhappy
                                </p>
                            </div>

                            <!-- What's Included -->
                            <div class="space-y-4">
                                <h3 class="text-lg font-semibold text-white">
                                    What You Get Monthly:
                                </h3>

                                <div class="flex items-start gap-3">
                                    <span
                                        class="text-2xl text-brand-success flex-shrink-0"
                                        >✓</span
                                    >
                                    <div>
                                        <h4 class="text-white font-semibold">
                                            Full Platform Access
                                        </h4>
                                        <p class="text-sm text-white/60 mt-1">
                                            Complete Laravel Mail source code
                                            with all features
                                        </p>
                                    </div>
                                </div>

                                <div class="flex items-start gap-3">
                                    <span
                                        class="text-2xl text-brand-success flex-shrink-0"
                                        >✓</span
                                    >
                                    <div>
                                        <h4 class="text-white font-semibold">
                                            Verified B2B Leads
                                        </h4>
                                        <p class="text-sm text-white/60 mt-1">
                                            Fresh email-verified prospects added
                                            monthly
                                        </p>
                                    </div>
                                </div>

                                <div class="flex items-start gap-3">
                                    <span
                                        class="text-2xl text-brand-success flex-shrink-0"
                                        >✓</span
                                    >
                                    <div>
                                        <h4 class="text-white font-semibold">
                                            AI Marketing Agents
                                        </h4>
                                        <p class="text-sm text-white/60 mt-1">
                                            Local AI agents (Ollama) for smart
                                            outreach automation
                                        </p>
                                    </div>
                                </div>

                                <div class="flex items-start gap-3">
                                    <span
                                        class="text-2xl text-brand-success flex-shrink-0"
                                        >✓</span
                                    >
                                    <div>
                                        <h4 class="text-white font-semibold">
                                            Unlimited Campaigns
                                        </h4>
                                        <p class="text-sm text-white/60 mt-1">
                                            Send to unlimited contacts—no
                                            per-contact pricing
                                        </p>
                                    </div>
                                </div>

                                <div class="flex items-start gap-3">
                                    <span
                                        class="text-2xl text-brand-success flex-shrink-0"
                                        >✓</span
                                    >
                                    <div>
                                        <h4 class="text-white font-semibold">
                                            Analytics & Tracking
                                        </h4>
                                        <p class="text-sm text-white/60 mt-1">
                                            Open rates, clicks, bounces,
                                            conversions, and more
                                        </p>
                                    </div>
                                </div>

                                <div class="flex items-start gap-3">
                                    <span
                                        class="text-2xl text-brand-success flex-shrink-0"
                                        >✓</span
                                    >
                                    <div>
                                        <h4 class="text-white font-semibold">
                                            1,900+ Email Templates
                                        </h4>
                                        <p class="text-sm text-white/60 mt-1">
                                            Pre-built Blade & MJML templates
                                            ready to customize
                                        </p>
                                    </div>
                                </div>

                                <div class="flex items-start gap-3">
                                    <span
                                        class="text-2xl text-brand-success flex-shrink-0"
                                        >✓</span
                                    >
                                    <div>
                                        <h4 class="text-white font-semibold">
                                            Priority Support
                                        </h4>
                                        <p class="text-sm text-white/60 mt-1">

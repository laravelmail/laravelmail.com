---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { getRelativeLocaleUrl } from "astro:i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const title = t('buy.hero_title');
const description = t('buy.hero_subtitle');
const keywords =
    "B2B leads, email marketing, AI agents, marketing automation, verified leads, self-hosted email";
import CommunitySlack from "../components/CommunitySlack.astro";
---

<Layout title={title} description={description} lang={lang}>
    <div class="relative overflow-hidden pt-32 pb-20 lg:pt-48 lg:pb-32">
        <!-- Background Decor -->
        <div
            class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10 opacity-30 pointer-events-none"
        >
            <div
                class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-payflo-purple/20 blur-[120px] rounded-full"
            >
            </div>
            <div
                class="absolute bottom-[10%] right-[-10%] w-[30%] h-[30%] bg-payflo-blue/20 blur-[100px] rounded-full"
            >
            </div>
        </div>

        <div class="container-custom">
            <div class="max-w-5xl mx-auto">
                <!-- Header -->
                <div class="text-center mb-12 animate-on-scroll">
                    <!-- Urgency Triggers -->
                    <div
                        class="flex flex-col items-center gap-4 mb-8 animate-on-scroll"
                    >
                        <div
                            class="inline-flex items-center gap-2 px-6 py-2 rounded-full bg-brand-primary/10 border border-brand-primary/30"
                        >
                            <span class="relative flex h-3 w-3">
                                <span
                                    class="animate-pulse absolute inline-flex h-full w-full rounded-full bg-brand-primary opacity-75"
                                ></span>
                                <span
                                    class="relative inline-flex rounded-full h-3 w-3 bg-brand-primary"
                                ></span>
                            </span>
                            <span
                                class="text-sm font-bold text-brand-primary uppercase tracking-wider"
                            >
                                ✓ {t('buy.trusted_by')}
                            </span>
                        </div>
                        <p class="text-white/60 text-sm">
                            {t('value.sol5_subtitle')}
                        </p>
                    </div>

                    <h1
                        class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight"
                    >
                        {t('buy.hero_title')}
                    </h1>
                    <p
                        class="text-xl text-white/70 max-w-3xl mx-auto leading-relaxed"
                    >
                        {t('buy.hero_subtitle')}
                    </p>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
                    <!-- Left Column: Pricing & Value -->
                    <div
                        class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8 shadow-2xl animate-on-scroll delay-1"
                    >
                        <div class="flex items-center gap-3 mb-8">
                            <span class="text-3xl">💎</span>
                            <h2 class="text-2xl font-bold m-0 text-white">
                                {t('buy.sub_title')}
                            </h2>
                        </div>

                        <div class="space-y-6">
                            <!-- Price -->
                            <div
                                class="bg-gradient-to-br from-payflo-purple/20 to-payflo-blue/10 rounded-2xl p-6 border border-payflo-purple/30"
                            >
                                <p class="text-white/70 text-sm mb-2">
                                    {t('buy.price_setup_full')}
                                </p>
                                <div class="flex items-baseline gap-2">
                                    <span class="text-5xl font-black text-white"
                                        >{t('buy.price_setup_amount')}</span
                                    >
                                    <span class="text-white/60 text-lg"
                                        >{t('buy.price_setup')}</span
                                    >
                                </div>
                                <div class="flex items-baseline gap-2 mt-2">
                                    <span class="text-2xl font-black text-white"
                                        >{t('buy.price_monthly_amount')}</span
                                    >
                                    <span class="text-white/60 text-lg"
                                        >{t('buy.price_monthly')}</span
                                    >
                                </div>
                                <p class="text-white/60 text-sm mt-3">
                                    {t('buy.price_disclaimer')}
                                </p>
                            </div>

                            <!-- What's Included -->
                            <div class="space-y-4">
                                <h3 class="text-lg font-semibold text-white">
                                    {t('buy.includes_title')}
                                </h3>

                                <div class="flex items-start gap-3">
                                    <span
                                        class="text-2xl text-brand-success flex-shrink-0"
                                        >✓</span
                                    >
                                    <div>
                                        <h4 class="text-white font-semibold">
                                            {t('buy.inc_platform')}
                                        </h4>
                                        <p class="text-sm text-white/60 mt-1">
                                            {t('deploy.docker_subtitle')}
                                        </p>
                                    </div>
                                </div>

                                <div class="flex items-start gap-3">
                                    <span
                                        class="text-2xl text-brand-success flex-shrink-0"
                                        >✓</span
                                    >
                                    <div>
                                        <h4 class="text-white font-semibold">
                                            {t('buy.inc_leads')}
                                        </h4>
                                        <p class="text-sm text-white/60 mt-1">
                                            {t('value.sol1_desc')}
                                        </p>
                                    </div>
                                </div>

                                <div class="flex items-start gap-3">
                                    <span
                                        class="text-2xl text-brand-success flex-shrink-0"
                                        >✓</span
                                    >
                                    <div>
                                        <h4 class="text-white font-semibold">
                                            {t('buy.inc_ai')}
                                        </h4>
                                        <p class="text-sm text-white/60 mt-1">
                                            {t('value.sol5_desc')}
                                        </p>
                                    </div>
                                </div>

                                <div class="flex items-start gap-3">
                                    <span
                                        class="text-2xl text-brand-success flex-shrink-0"
                                        >✓</span
                                    >
                                    <div>
                                        <h4 class="text-white font-semibold">
                                            {t('value.adv_control_title')}
                                        </h4>
                                        <p class="text-sm text-white/60 mt-1">
                                            {t('value.adv_control_desc')}
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div
                            class="mt-8 p-4 bg-payflo-purple/10 border border-payflo-purple/20 rounded-2xl"
                        >
                            <p
                                class="text-sm text-white/70 leading-relaxed italic"
                            >
                                <strong class="text-white"
                                    >{t('buy.why_title')}</strong
                                > {t('buy.why_subtitle')}
                            </p>
                        </div>
                    </div>

                    <!-- Right Column: Payment & Trust -->
                    <div class="space-y-6 animate-on-scroll delay-2">
                        <!-- Payment Card -->
                        <div
                            class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8 shadow-2xl"
                        >
                            <div class="flex items-center gap-3 mb-8">
                                <span class="text-3xl">💳</span>
                                <h2 class="text-2xl font-bold m-0 text-white">
                                    {t('buy.get_started_today')}
                                </h2>
                            </div>

                            <div class="space-y-6">
                                <div
                                    class="bg-brand-primary/10 border border-brand-primary/30 rounded-xl p-4 text-center"
                                >
                                    <p class="text-sm text-white/80 mb-2">
                                        {t('buy.instant_access')}
                                    </p>
                                    <p class="text-lg font-bold text-white">
                                        {t('buy.price_desc')}
                                    </p>
                                    <p class="text-xs text-white/60 mt-2">
                                        {t('buy.start_immediately')}
                                    </p>
                                </div>

                                <div
                                    id="paypal-button-container-P-5JV683893N289793BNGMDYGA"
                                    class="min-h-[200px]"
                                >
                                </div>
                                <script>
                                    function initPayPal() {
                                        const containerId =
                                            "#paypal-button-container-P-5JV683893N289793BNGMDYGA";
                                        const container =
                                            document.querySelector(containerId);

                                        if (container && window.paypal) {
                                            // Clear the container in case it was already rendered
                                            container.innerHTML = "";

                                            window.paypal
                                                .Buttons({
                                                    style: {
                                                        shape: "rect",
                                                        color: "gold",
                                                        layout: "vertical",
                                                        label: "subscribe",
                                                    },
                                                    createSubscription:
                                                        function (
                                                            data: any,
                                                            actions: any,
                                                        ) {
                                                            return actions.subscription.create(
                                                                {
                                                                    plan_id:
                                                                        "P-5JV683893N289793BNGMDYGA",
                                                                },
                                                            );
                                                        },
                                                    onApprove: function (
                                                        data: any,
                                                        actions: any,
                                                    ) {
                                                        if (
                                                            typeof window.trackPurchase ===
                                                            "function"
                                                        ) {
                                                            window.trackPurchase(
                                                                data.subscriptionID,
                                                            );
                                                        }
                                                        window.location.href =
                                                            "/thanks?id=" +
                                                            data.subscriptionID;
                                                    },
                                                })
                                                .render(containerId);
                                        } else if (container) {
                                            // Handle case where paypal is not yet defined
                                            console.warn(
                                                "PayPal SDK not loaded yet, retrying...",
                                            );
                                            setTimeout(initPayPal, 500);
                                        }
                                    }

                                    document.addEventListener(
                                        "astro:page-load",
                                        initPayPal,
                                    );
                                </script>

                                <p
                                    class="text-sm text-white/50 text-center px-4 leading-relaxed"
                                >
                                    {t('buy.secure_paypal')}
                                </p>

                                <!-- Trust Badges -->
                                <div
                                    class="flex items-center justify-center gap-3 pt-2"
                                >
                                    <svg
                                        class="h-5 w-5 text-white/50"
                                        fill="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                                        ></path>
                                    </svg>
                                    <span class="text-xs text-white/60"
                                        >{t('buy.ssl_encrypted')}</span
                                    >
                                </div>
                            </div>
                        </div>

                        <!-- Benefits Grid -->
                        <div class="grid grid-cols-2 gap-4">
                            <div
                                class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6"
                            >
                                <div class="text-3xl mb-3">🚀</div>
                                <h4
                                    class="text-white font-semibold text-sm mb-2"
                                >
                                    {t('buy.feat_deploy_title')}
                                </h4>
                                <p class="text-xs text-white/60">
                                    {t('buy.feat_deploy_desc')}
                                </p>
                            </div>
                            <div
                                class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6"
                            >
                                <div class="text-3xl mb-3">📊</div>
                                <h4
                                    class="text-white font-semibold text-sm mb-2"
                                >
                                    {t('buy.feat_analytics_title_short')}
                                </h4>
                                <p class="text-xs text-white/60">
                                    {t('buy.feat_analytics_desc_short')}
                                </p>
                            </div>
                            <div
                                class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6"
                            >
                                <div class="text-3xl mb-3">🔒</div>
                                <h4
                                    class="text-white font-semibold text-sm mb-2"
                                >
                                    {t('buy.feat_control_title_short')}
                                </h4>
                                <p class="text-xs text-white/60">
                                    {t('buy.feat_control_desc_short')}
                                </p>
                            </div>
                            <div
                                class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6"
                            >
                                <div class="text-3xl mb-3">♾️</div>
                                <h4
                                    class="text-white font-semibold text-sm mb-2"
                                >
                                    {t('buy.feat_limits_title_short')}
                                </h4>
                                <p class="text-xs text-white/60">
                                    {t('buy.feat_limits_desc_short')}
                                </p>
                            </div>
                        </div>

                        <!-- Security Badge -->
                        <div
                            class="flex items-center gap-4 p-6 bg-white/5 border border-white/10 rounded-2xl"
                        >
                            <div
                                class="p-3 bg-brand-success/10 rounded-full flex-shrink-0"
                            >
                                <svg
                                    class="w-6 h-6 text-brand-success"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-white font-bold m-0 text-sm">
                                    {t('buy.bank_grade_security')}
                                </h3>
                                <p class="text-xs text-white/50 m-0">
                                    {t('buy.bank_grade_desc')}
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Why Subscription Model Section -->
    <section
        class="py-24 relative overflow-hidden border-t border-white/5 bg-white/2"
    >
        <div class="container-custom">
            <div class="max-w-4xl mx-auto">
                <div
                    class="bg-gradient-to-br from-brand-primary/10 to-brand-blue/10 rounded-[2.5rem] border border-white/10 p-10 md:p-16 text-center"
                >
                    <h2
                        class="text-3xl md:text-5xl font-black text-white mb-8 tracking-tight"
                    >
                        {t('buy.why_title_1')} <span class="text-brand-primary">{t('buy.why_title_2')}</span>
                    </h2>
                    <p
                        class="text-xl md:text-2xl text-gray-300 leading-relaxed font-medium italic mb-10"
                    >
                        {t('buy.why_subtitle')}
                    </p>
                    <div
                        class="text-left space-y-6 text-gray-400 text-lg max-w-2xl mx-auto border-t border-white/10 pt-10"
                    >
                        <div class="flex gap-4">
                            <span

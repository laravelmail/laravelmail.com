                                >
                            </tr>
                            <tr class="hover:bg-white/5 transition">
                                <td class="py-4 px-4 text-white">AI Agents</td>
                                <td
                                    class="py-4 px-4 text-center text-brand-success"
                                    >✓ Included</td

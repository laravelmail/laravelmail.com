    // Google Analytics 4 Ecommerce & Interaction Tracking
    document.addEventListener("astro:page-load", () => {
        if (typeof gtag === "undefined") return;

        // --- Core Ecommerce Events ---
        gtag("event", "view_item", {
            currency: "GBP",
            value: 10.0,

---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { getRelativeLocaleUrl } from "astro:i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const title = t('buy.hero_title');
const description = t('buy.hero_subtitle');
const keywords =
    "B2B leads, email marketing, AI agents, marketing automation, verified leads, self-hosted email";
---

<Layout title={title} description={description} lang={lang}>
    <div class="relative overflow-hidden pt-32 pb-20 lg:pt-48 lg:pb-32">
        <!-- Background Decor -->
        <div
            class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10 opacity-30 pointer-events-none"
        >
            <div
                class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-payflo-purple/20 blur-[120px] rounded-full"
            >
            </div>
            <div
                class="absolute bottom-[10%] right-[-10%] w-[30%] h-[30%] bg-payflo-blue/20 blur-[100px] rounded-full"
            >
            </div>
        </div>

        <div class="container-custom">
            <div class="max-w-5xl mx-auto">
                <!-- Header -->
                <div class="text-center mb-12 animate-on-scroll">
                    <!-- Urgency Triggers -->
                    <div
                        class="flex flex-col items-center gap-4 mb-8 animate-on-scroll"
                    >
                        <div
                            class="inline-flex items-center gap-2 px-6 py-2 rounded-full bg-brand-primary/10 border border-brand-primary/30"
                        >
                            <span class="relative flex h-3 w-3">
                                <span
                                    class="animate-pulse absolute inline-flex h-full w-full rounded-full bg-brand-primary opacity-75"
                                ></span>
                                <span
                                    class="relative inline-flex rounded-full h-3 w-3 bg-brand-primary"
                                ></span>
                            </span>
                            <span
                                class="text-sm font-bold text-brand-primary uppercase tracking-wider"
                            >
                                ✓ {t('buy.trusted_by')}
                            </span>
                        </div>
                        <p class="text-white/60 text-sm">
                            {t('value.sol5_subtitle')}
                        </p>
                    </div>

                    <h1
                        class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight"
                    >
                        {t('buy.hero_title')}
                    </h1>
                    <p
                        class="text-xl text-white/70 max-w-3xl mx-auto leading-relaxed"
                    >
                        {t('buy.hero_subtitle')}
                    </p>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start" id="pricing">
                    <!-- Left Column: Lead Packs Pricing -->
                    <div
                        class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8 shadow-2xl animate-on-scroll delay-1"
                    >
                        <div class="flex items-center gap-3 mb-6">
                            <span class="text-3xl">📦</span>
                            <h2 class="text-2xl font-bold m-0 text-white">
                                {t('buy.lead_packs_title')}
                            </h2>
                        </div>

                        <p class="text-white/70 mb-6 text-sm">
                            {t('buy.lead_packs_subtitle')}
                        </p>

                        <div class="space-y-4">
                            <!-- Entry Plan -->
                            <div
                                class="group relative bg-white/5 border border-white/10 rounded-2xl p-5 hover:border-white/20 hover:scale-[1.02] transition-all duration-300 cursor-pointer select-plan"
                                data-plan="entry"
                                data-price="5"
                                data-leads="100"
                            >
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-3">
                                        <span class="text-2xl">🟢</span>
                                        <div>
                                            <h4 class="text-white font-bold text-lg">
                                                Entry
                                            </h4>
                                            <p class="text-white/60 text-xs">
                                                100 leads
                                            </p>
                                        </div>
                                    </div>
                                    <div class="text-right">
                                        <span class="text-2xl font-black text-white"
                                            >$5</span
                                        >
                                        <p class="text-white/50 text-xs">
                                            $0.050/lead
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <!-- Growth Plan (Featured) -->
                            <div
                                class="group relative bg-gradient-to-br from-payflo-purple/20 to-brand-primary/10 border-2 border-brand-primary/50 rounded-2xl p-5 hover:scale-[1.02] transition-all duration-300 cursor-pointer shadow-lg shadow-brand-primary/10 select-plan ring-1 ring-brand-primary/30"
                                data-plan="growth"
                                data-price="19"
                                data-leads="500"
                            >
                                <div
                                    class="absolute -top-3 left-1/2 -translate-x-1/2 bg-gradient-to-r from-payflo-purple to-brand-primary text-white text-xs font-bold px-3 py-1 rounded-full"
                                >
                                    ⭐ Most Popular
                                </div>
                                <div class="flex items-center justify-between mt-2">
                                    <div class="flex items-center gap-3">
                                        <span class="text-2xl">🔵</span>
                                        <div>
                                            <h4 class="text-white font-bold text-lg">
                                                Growth
                                            </h4>
                                            <p class="text-white/60 text-xs">
                                                500 leads
                                            </p>
                                        </div>
                                    </div>
                                    <div class="text-right">
                                        <span class="text-3xl font-black text-white"
                                            >$19</span
                                        >
                                        <p class="text-brand-primary text-xs font-semibold">
                                            $0.038/lead
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <!-- Scale Plan -->
                            <div
                                class="group relative bg-white/5 border border-white/10 rounded-2xl p-5 hover:border-white/20 hover:scale-[1.02] transition-all duration-300 cursor-pointer select-plan"
                                data-plan="scale"
                                data-price="49"
                                data-leads="2000"
                            >
                                <div
                                    class="absolute -top-2 right-4 bg-gradient-to-r from-payflo-purple to-payflo-pink text-white text-xs font-bold px-2 py-1 rounded-full"
                                >
                                    💰 Best Value
                                </div>
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-3">
                                        <span class="text-2xl">🟣</span>
                                        <div>
                                            <h4 class="text-white font-bold text-lg">
                                                Scale
                                            </h4>
                                            <p class="text-white/60 text-xs">
                                                2,000 leads
                                            </p>
                                        </div>
                                    </div>
                                    <div class="text-right">
                                        <span class="text-2xl font-black text-white"
                                            >$49</span
                                        >
                                        <p class="text-white/50 text-xs">
                                            $0.0245/lead
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <!-- Pro Plan -->
                            <div
                                class="group relative bg-white/5 border border-white/10 rounded-2xl p-5 hover:border-white/20 hover:scale-[1.02] transition-all duration-300 cursor-pointer select-plan"
                                data-plan="pro"
                                data-price="99"
                                data-leads="5000"
                            >
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-3">
                                        <span class="text-2xl">🔴</span>
                                        <div>
                                            <h4 class="text-white font-bold text-lg">
                                                Pro
                                            </h4>
                                            <p class="text-white/60 text-xs">
                                                5,000 leads
                                            </p>
                                        </div>
                                    </div>
                                    <div class="text-right">
                                        <span class="text-2xl font-black text-white"
                                            >$99</span
                                        >
                                        <p class="text-white/50 text-xs">
                                            $0.0198/lead
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div
                            class="mt-6 p-4 bg-payflo-purple/10 border border-payflo-purple/20 rounded-2xl"
                        >
                            <p
                                class="text-sm text-white/70 leading-relaxed"
                            >
                                <strong class="text-white"
                                    >{t('buy.verified_leads_title')}</strong
                                > {t('buy.verified_leads_subtitle')}
                            </p>
                        </div>
                    </div>

                    <!-- Right Column: Payment & Trust -->
                    <div class="space-y-6 animate-on-scroll delay-2">
                        <!-- Payment Card -->
                        <div
                            class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8 shadow-2xl"
                        >
                            <div class="flex items-center gap-3 mb-6">
                                <span class="text-3xl">💳</span>
                                <h2 class="text-2xl font-bold m-0 text-white">
                                    {t('buy.checkout_title')}
                                </h2>
                            </div>

                            <div class="space-y-4">
                                <!-- Selected Plan Display -->
                                <div
                                    id="selected-plan-display"
                                    class="bg-brand-primary/10 border border-brand-primary/30 rounded-xl p-4 text-center"
                                >
                                    <p class="text-sm text-white/80 mb-1">
                                        {t('buy.selected_plan')}
                                    </p>
                                    <p
                                        class="text-2xl font-bold text-white"
                                        id="plan-name"
                                    >
                                        Growth (500 leads)
                                    </p>
                                    <p
                                        class="text-xl font-black text-brand-primary"
                                        id="plan-price"
                                    >
                                        $19
                                    </p>
                                </div>

                                <!-- PayPal Button -->
                                <div
                                    id="paypal-button-container"
                                    class="min-h-[150px]"
                                >
                                </div>

                                <p
                                    class="text-sm text-white/50 text-center px-4 leading-relaxed"
                                >
                                    {t('buy.secure_paypal')}
                                </p>

                                <!-- Trust Badges -->
                                <div
                                    class="flex items-center justify-center gap-3 pt-2"
                                >
                                    <svg
                                        class="h-5 w-5 text-white/50"
                                        fill="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                                        ></path>
                                    </svg>
                                    <span class="text-xs text-white/60"
                                        >{t('buy.ssl_encrypted')}</span
                                    >
                                </div>
                            </div>
                        </div>

                        <!-- Benefits Grid -->
                        <div class="grid grid-cols-2 gap-4">
                            <div
                                class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6"
                            >
                                <div class="text-3xl mb-3">🚀</div>
                                <h4
                                    class="text-white font-semibold text-sm mb-2"
                                >
                                    {t('buy.feat_deploy_title')}
                                </h4>
                                <p class="text-xs text-white/60">
                                    {t('buy.feat_deploy_desc')}
                                </p>
                            </div>
                            <div
                                class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6"
                            >
                                <div class="text-3xl mb-3">📊</div>
                                <h4
                                    class="text-white font-semibold text-sm mb-2"
                                >
                                    {t('buy.feat_analytics_title_short')}
                                </h4>
                                <p class="text-xs text-white/60">
                                    {t('buy.feat_analytics_desc_short')}
                                </p>
                            </div>
                            <div
                                class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6"
                            >
                                <div class="text-3xl mb-3">🔒</div>
                                <h4
                                    class="text-white font-semibold text-sm mb-2"
                                >
                                    {t('buy.feat_control_title_short')}
                                </h4>
                                <p class="text-xs text-white/60">
                                    {t('buy.feat_control_desc_short')}
                                </p>
                            </div>
                            <div
                                class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6"
                            >
                                <div class="text-3xl mb-3">♾️</div>
                                <h4
                                    class="text-white font-semibold text-sm mb-2"
                                >
                                    {t('buy.feat_limits_title_short')}
                                </h4>
                                <p class="text-xs text-white/60">
                                    {t('buy.feat_limits_desc_short')}
                                </p>
                            </div>
                        </div>

                        <!-- Security Badge -->
                        <div
                            class="flex items-center gap-4 p-6 bg-white/5 border border-white/10 rounded-2xl"
                        >
                            <div
                                class="p-3 bg-brand-success/10 rounded-full flex-shrink-0"
                            >
                                <svg
                                    class="w-6 h-6 text-brand-success"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-white font-bold m-0 text-sm">
                                    {t('buy.bank_grade_security')}
                                </h3>
                                <p class="text-xs text-white/50 m-0">
                                    {t('buy.bank_grade_desc')}
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    

    <!-- Comparison Section -->
    <section class="py-24 relative overflow-hidden">
        <div class="container-custom">
            <div class="max-w-5xl mx-auto">
                <div class="text-center mb-16">
                    <h2 class="text-4xl font-bold text-white mb-4">
                        {t('buy.compare_title')}
                    </h2>
                    <p class="text-xl text-gray-400 max-w-2xl mx-auto">
                        {t('buy.compare_subtitle')}
                    </p>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm md:text-base">
                        <thead>
                            <tr class="border-b border-white/10">
                                <th
                                    class="text-left py-4 px-4 text-white font-bold"
                                    >{t('buy.table_feature')}</th
                                >
                                <th
                                    class="text-center py-4 px-4 text-white font-bold"
                                    >{t('buy.table_lm')}</th
                                >
                                <th
                                    class="text-center py-4 px-4 text-white/60 font-bold"
                                    >{t('buy.table_mc')}</th
                                >
                                <th
                                    class="text-center py-4 px-4 text-white/60 font-bold"
                                    >{t('buy.table_hs')}</th
                                >
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5">
                            <tr class="hover:bg-white/5 transition">
                                <td class="py-4 px-4 text-white">{t('buy.table_price')}</td>
                                <td class="py-4 px-4 text-center"
                                    ><span class="text-brand-primary font-bold"
                                        >{t('buy.table_lm_price')}</span
                                    ></td
                                >
                                <td class="py-4 px-4 text-center text-white/60"
                                    >{t('buy.table_mc_price')}</td
                                >
                                <td class="py-4 px-4 text-center text-white/60"
                                    >{t('buy.table_hs_price')}</td
                                >
                            </tr>
                            <tr class="hover:bg-white/5 transition">
                                <td class="py-4 px-4 text-white"
                                    >{t('buy.table_per_contact')}</td
                                >
                                <td
                                    class="py-4 px-4 text-center text-brand-success"
                                    >{t('buy.table_none')}</td
                                >
                                <td class="py-4 px-4 text-center text-red-400"
                                    >{t('buy.table_yes')}</td
                                >
                                <td class="py-4 px-4 text-center text-red-400"
                                    >{t('buy.table_yes')}</td
                                >
                            </tr>
                            <tr class="hover:bg-white/5 transition">
                                <td class="py-4 px-4 text-white"
                                    >{t('buy.table_self_hosted')}</td
                                >
                                <td
                                    class="py-4 px-4 text-center text-brand-success"
                                    >{t('buy.table_full_control')}</td
                                >
                                <td class="py-4 px-4 text-center text-red-400"
                                    >✗</td
                                >
                                <td class="py-4 px-4 text-center text-red-400"
                                    >✗</td
                                >
                            </tr>
                            <tr class="hover:bg-white/5 transition">
                                <td class="py-4 px-4 text-white">{t('buy.table_ai')}</td>
                                <td
                                    class="py-4 px-4 text-center text-brand-success"
                                    >{t('buy.table_included')}</td
                                >
                                <td class="py-4 px-4 text-center text-red-400"
                                    >✗</td
                                >
                                <td class="py-4 px-4 text-center">{t('buy.table_limited')}</td>
                            </tr>
                            <tr class="hover:bg-white/5 transition">
                                <td class="py-4 px-4 text-white"
                                    >{t('buy.table_leads')}</td
                                >
                                <td
                                    class="py-4 px-4 text-center text-brand-success"
                                    >{t('buy.table_monthly')}</td
                                >
                                <td class="py-4 px-4 text-center text-red-400"
                                    >✗</td
                                >
                                <td class="py-4 px-4 text-center text-red-400"
                                    >✗</td
                                >
                            </tr>
                            <tr class="hover:bg-white/5 transition">
                                <td class="py-4 px-4 text-white"
                                    >{t('buy.table_source')}</td
                                >
                                <td
                                    class="py-4 px-4 text-center text-brand-success"
                                    >{t('buy.table_full')}</td
                                >
                                <td class="py-4 px-4 text-center text-red-400"
                                    >✗</td
                                >
                                <td class="py-4 px-4 text-center text-red-400"
                                    >✗</td
                                >
                            </tr>
                            <tr class="hover:bg-white/5 transition">
                                <td class="py-4 px-4 text-white"
                                    >{t('buy.table_privacy')}</td
                                >
                                <td
                                    class="py-4 px-4 text-center text-brand-success"
                                    >{t('buy.table_100_control')}</td
                                >
                                <td class="py-4 px-4 text-center text-white/60"
                                    >{t('buy.table_their_servers')}</td
                                >
                                <td class="py-4 px-4 text-center text-white/60"
                                    >{t('buy.table_their_servers')}</td
                                >
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>

    <!-- User Reviews Section -->
    <section class="py-24 bg-[#0f172a]/40 relative overflow-hidden">
        <div class="container-custom relative z-10">
            <div class="text-center max-w-3xl mx-auto mb-16">
                <h2 class="text-4xl font-bold text-white mb-4">
                    {t('buy.reviews_title')}
                </h2>
                <p class="text-xl text-gray-400">
                    {t('buy.reviews_subtitle')}
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                <div
                    class="bg-brand-bg-card/40 backdrop-blur-xl border border-white/10 p-10 rounded-[2rem] hover:border-brand-primary/30 transition-all duration-500 group"
                >
                    <div class="flex items-center mb-6">
                        <div class="flex gap-1 mb-4">
                            <span class="text-xl">⭐</span>
                            <span class="text-xl">⭐</span>
                            <span class="text-xl">⭐</span>
                            <span class="text-xl">⭐</span>
                            <span class="text-xl">⭐</span>
                        </div>
                    </div>
                    <div class="flex items-center mb-4">
                        <div
                            class="w-12 h-12 bg-brand-primary/20 rounded-xl flex items-center justify-center text-brand-primary text-xl font-bold mr-4 group-hover:scale-110 transition-transform"
                        >
                            JD
                        </div>
                        <div>
                            <h4 class="text-white font-bold text-lg m-0">
                                {t('buy.review1_author')}
                            </h4>
                            <p class="text-gray-500 text-sm m-0">
                                {t('buy.review1_role')}
                            </p>
                        </div>
                    </div>
                    <p class="text-gray-300 italic leading-relaxed">
                        {t('buy.review1_text')}
                    </p>
                </div>

                <div
                    class="bg-brand-bg-card/40 backdrop-blur-xl border border-white/10 p-10 rounded-[2rem] hover:border-brand-primary/30 transition-all duration-500 group"
                >
                    <div class="flex items-center mb-6">
                        <div class="flex gap-1 mb-4">
                            <span class="text-xl">⭐</span>
                            <span class="text-xl">⭐</span>
                            <span class="text-xl">⭐</span>
                            <span class="text-xl">⭐</span>
                            <span class="text-xl">⭐</span>
                        </div>
                    </div>
                    <div class="flex items-center mb-4">
                        <div
                            class="w-12 h-12 bg-brand-blue/20 rounded-xl flex items-center justify-center text-brand-blue text-xl font-bold mr-4 group-hover:scale-110 transition-transform"
                        >
                            SM
                        </div>
                        <div>
                            <h4 class="text-white font-bold text-lg m-0">
                                {t('buy.review2_author')}
                            </h4>
                            <p class="text-gray-500 text-sm m-0">
                                {t('buy.review2_role')}
                            </p>
                        </div>
                    </div>
                    <p class="text-gray-300 italic leading-relaxed">
                        {t('buy.review2_text')}
                    </p>
                </div>

                <div
                    class="bg-brand-bg-card/40 backdrop-blur-xl border border-white/10 p-10 rounded-[2rem] hover:border-brand-primary/30 transition-all duration-500 group"
                >
                    <div class="flex items-center mb-6">
                        <div class="flex gap-1 mb-4">
                            <span class="text-xl">⭐</span>
                            <span class="text-xl">⭐</span>
                            <span class="text-xl">⭐</span>
                            <span class="text-xl">⭐</span>
                            <span class="text-xl">⭐</span>
                        </div>
                    </div>
                    <div class="flex items-center mb-4">
                        <div
                            class="w-12 h-12 bg-brand-primary/20 rounded-xl flex items-center justify-center text-brand-primary text-xl font-bold mr-4 group-hover:scale-110 transition-transform"
                        >
                            RC
                        </div>
                        <div>
                            <h4 class="text-white font-bold text-lg m-0">
                                {t('buy.review3_author')}
                            </h4>
                            <p class="text-gray-500 text-sm m-0">
                                {t('buy.review3_role')}
                            </p>
                        </div>
                    </div>
                    <p class="text-gray-300 italic leading-relaxed">
                        {t('buy.review3_text')}
                    </p>
                </div>

                <div

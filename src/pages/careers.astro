---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import teamPhoto from '../assets/team-photo.jpg';

const jobPostings = [
    {
        "@context": "https://schema.org/",
        "@type": "JobPosting",
        "title": "Senior Laravel Developer",
        "description": "Build and maintain our core Laravel email infrastructure and APIs. Work with cutting-edge email technology that powers thousands of Laravel applications worldwide.",
        "identifier": {
            "@type": "PropertyValue",
            "name": "Laravelmail",
            "value": "senior-laravel-developer-2024"
        },
        "datePosted": "2024-09-15",
        "validThrough": "2024-12-15",
        "employmentType": "FULL_TIME",
        "hiringOrganization": {
            "@type": "Organization",
            "name": "Laravelmail",
            "sameAs": "https://laravelmail.com",
            "logo": "https://laravelmail.com/logo.png"
        },
        "jobLocation": {
            "@type": "Place",
            "address": {
                "@type": "PostalAddress",
                "addressLocality": "Remote",
                "addressCountry": "Worldwide"
            }
        },
        "baseSalary": {
            "@type": "MonetaryAmount",
            "currency": "USD",
            "value": {
                "@type": "QuantitativeValue",
                "minValue": 80000,
                "maxValue": 120000,
                "unitText": "YEAR"
            }
        },
        "skills": ["PHP", "Laravel", "MySQL", "Redis", "Email Infrastructure", "API Development"],
        "qualifications": "5+ years of Laravel development experience, strong understanding of email protocols, experience with high-volume applications"
    },
    {
        "@context": "https://schema.org/",
        "@type": "JobPosting",
        "title": "DevOps Engineer",
        "description": "Scale our email infrastructure and ensure high deliverability rates. Work with AWS, Docker, and email servers to maintain reliable email delivery for thousands of applications.",
        "identifier": {
            "@type": "PropertyValue",
            "name": "Laravelmail",
            "value": "devops-engineer-2024"
        },
        "datePosted": "2024-09-15",
        "validThrough": "2024-12-15",
        "employmentType": "FULL_TIME",
        "hiringOrganization": {
            "@type": "Organization",
            "name": "Laravelmail",
            "sameAs": "https://laravelmail.com",
            "logo": "https://laravelmail.com/logo.png"
        },
        "jobLocation": {
            "@type": "Place",
            "address": {
                "@type": "PostalAddress",
                "addressLocality": "Remote",
                "addressCountry": "Worldwide"
            }
        },
        "baseSalary": {
            "@type": "MonetaryAmount",
            "currency": "USD",
            "value": {
                "@type": "QuantitativeValue",
                "minValue": 90000,
                "maxValue": 130000,
                "unitText": "YEAR"
            }
        },
        "skills": ["AWS", "Docker", "Postfix", "Email Deliverability", "Linux", "Infrastructure as Code"],
        "qualifications": "3+ years of DevOps experience, expertise with email servers and deliverability, AWS certification preferred"
    },
    {
        "@context": "https://schema.org/",
        "@type": "JobPosting",
        "title": "Customer Success Engineer",
        "description": "Help Laravel developers integrate and optimize their email workflows. Provide technical support and guidance to ensure customers get maximum value from our platform.",
        "identifier": {
            "@type": "PropertyValue",
            "name": "Laravelmail",
            "value": "customer-success-engineer-2024"
        },
        "datePosted": "2024-09-15",
        "validThrough": "2024-12-15",
        "employmentType": "FULL_TIME",
        "hiringOrganization": {
            "@type": "Organization",
            "name": "Laravelmail",
            "sameAs": "https://laravelmail.com",
            "logo": "https://laravelmail.com/logo.png"
        },
        "jobLocation": {
            "@type": "Place",
            "address": {
                "@type": "PostalAddress",
                "addressLocality": "Remote",
                "addressCountry": "Worldwide"
            }
        },
        "baseSalary": {
            "@type": "MonetaryAmount",
            "currency": "USD",
            "value": {
                "@type": "QuantitativeValue",
                "minValue": 60000,
                "maxValue": 90000,
                "unitText": "YEAR"
            }
        },
        "skills": ["Laravel", "Email Marketing", "Customer Support", "Technical Writing", "API Integration"],
        "qualifications": "2+ years of Laravel experience, excellent communication skills, experience with email systems and customer support"
    },
    {
        "@context": "https://schema.org/",
        "@type": "JobPosting",
        "title": "Frontend Developer",
        "description": "Create intuitive dashboards and email template builders for our users. Build responsive, modern interfaces using Vue.js, Tailwind CSS, and Inertia.js.",
        "identifier": {
            "@type": "PropertyValue",
            "name": "Laravelmail",
            "value": "frontend-developer-2024"
        },
        "datePosted": "2024-09-15",
        "validThrough": "2024-12-15",
        "employmentType": "FULL_TIME",
        "hiringOrganization": {
            "@type": "Organization",
            "name": "Laravelmail",
            "sameAs": "https://laravelmail.com",
            "logo": "https://laravelmail.com/logo.png"
        },
        "jobLocation": {
            "@type": "Place",
            "address": {
                "@type": "PostalAddress",
                "addressLocality": "Remote",
                "addressCountry": "Worldwide"
            }
        },
        "baseSalary": {
            "@type": "MonetaryAmount",
            "currency": "USD",
            "value": {
                "@type": "QuantitativeValue",
                "minValue": 70000,
                "maxValue": 100000,
                "unitText": "YEAR"
            }
        },
        "skills": ["Vue.js", "Tailwind CSS", "Inertia.js", "JavaScript", "HTML/CSS", "Laravel"],
        "qualifications": "3+ years of frontend development experience, proficiency with Vue.js and Tailwind CSS, experience with Laravel/Inertia stack"
    }
];
---

<Layout title="Careers | Laravelmail">
    <!-- Job Posting Structured Data -->
    {jobPostings.map(job => (
        <script type="application/ld+json" set:html={JSON.stringify(job)} />
    ))}

    <main>
        <!-- Hero Section -->
        <section class="pt-20 pb-16 md:pt-28 md:pb-24 overflow-hidden">
            <div class="container-custom">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                    <div>
                        <h1 class="animate-on-scroll delay-0 text-4xl md:text-5xl lg:text-6xl font-bold leading-tight">
                            Join Our <span class="gradient-text">Team</span>
                        </h1>
                        <p class="animate-on-scroll delay-1 mt-6 text-xl text-gray-600 max-w-lg">
                            Help us build the future of Laravel email infrastructure. We're looking for passionate developers who want to revolutionize how applications handle email.
                        </p>
                        <div class="animate-on-scroll delay-2 mt-8">
                            <a href="#open-positions" class="btn btn-primary">View Open Positions</a>
                        </div>
                    </div>
                    <div class="animate-on-scroll delay-3">
                        <div class="relative">
                            <div class="absolute -inset-0.5 bg-gradient-to-r from-red-500 to-orange-500 rounded-xl blur opacity-30"></div>
                            <div class="relative bg-white rounded-xl shadow-xl overflow-hidden">
                                <Image
                                        src={teamPhoto}
                                        alt="Our Team"
                                        class="w-full h-auto"
                                        width={700}
                                        height={500}
                                />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Why Join Us Section -->
        <section class="section bg-gray-50">
            <div class="container-custom">
                <h2 class="animate-on-scroll delay-0 text-3xl md:text-4xl font-bold text-center mb-16">
                    Why Join <span class="gradient-text">Laravelmail</span>?
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <div class="animate-on-scroll delay-1 feature-card">
                        <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center mb-5">
                            <svg class="w-6 h-6 text-red-600" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M4 4H20C21.1 4 22 4.9 22 6V18C22 19.1 21.1 20 20 20H4C2.9 20 2 19.1 2 18V6C2 4.9 2.9 4 4 4Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M22 6L12 13L2 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <h3 class="text-2xl font-semibold mb-4">Email Infrastructure</h3>
                        <p class="text-gray-600 text-lg">Work on cutting-edge email technology that powers thousands of Laravel applications worldwide.</p>
                    </div>

                    <div class="animate-on-scroll delay-2 feature-card">
                        <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mb-5">
                            <svg class="w-6 h-6 text-orange-600" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M17 21V19C17 17.9391 16.5786 16.9217 15.8284 16.1716C15.0783 15.4214 14.0609 15 13 15H5C3.93913 15 2.92172 15.4214 2.17157 16.1716C1.42143 16.9217 1 17.9391 1 19V21" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M9 11C11.2091 11 13 9.20914 13 7C13 4.79086 11.2091 3 9 3C6.79086 3 5 4.79086 5 7C5 9.20914 6.79086 11 9 11Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M23 21V19C22.9993 18.1137 22.7044 17.2528 22.1614 16.5523C21.6184 15.8519 20.8581 15.3516 20 15.13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M16 3.13C16.8604 3.35031 17.623 3.85071 18.1676 4.55232C18.7122 5.25392 19.0078 6.11683 19.0078 7.005C19.0078 7.89318 18.7122 8.75608 18.1676 9.45769C17.623 10.1593 16.8604 10.6597 16 10.88" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <h3 class="text-2xl font-semibold mb-4">Laravel Community</h3>
                        <p class="text-gray-600 text-lg">Be part of the vibrant Laravel ecosystem and contribute to open-source projects used by millions.</p>
                    </div>

                    <div class="animate-on-scroll delay-3 feature-card">
                        <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center mb-5">
                            <svg class="w-6 h-6 text-red-600" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M12 20V10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M18 20V4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M6 20V16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <h3 class="text-2xl font-semibold mb-4">Remote-First Culture</h3>
                        <p class="text-gray-600 text-lg">Work from anywhere with flexible hours, while collaborating with a talented global team.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Benefits Section -->
        <section class="section">
            <div class="container-custom">
                <h2 class="animate-on-scroll delay-0 text-3xl md:text-4xl font-bold text-center mb-16">
                    Our <span class="gradient-text">Benefits</span>
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                    <div class="animate-on-scroll delay-1 feature-card">
                        <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center mb-5">
                            <svg class="w-6 h-6 text-red-600" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M12 1V23" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M17 5H9.5C8.57174 5 7.6815 5.36875 7.02513 6.02513C6.36875 6.6815 6 7.57174 6 8.5C6 9.42826 6.36875 10.3185 7.02513 10.9749C7.6815 11.6313 8.57174 12 9.5 12H14.5C15.4283 12 16.3185 12.3687 16.9749 13.0251C17.6313 13.6815 18 14.5717 18 15.5C18 16.4283 17.6313 17.3185 16.9749 17.9749C16.3185 18.6313 15.4283 19 14.5 19H6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <h3 class="text-xl font-semibold mb-3">Competitive Salary</h3>
                        <p class="text-gray-600">Industry-leading compensation in USD</p>
                    </div>

                    <div class="animate-on-scroll delay-2 feature-card">
                        <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mb-5">
                            <svg class="w-6 h-6 text-orange-600" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M19 4H5C3.89543 4 3 4.89543 3 6V20C3 21.1046 3.89543 22 5 22H19C20.1046 22 21 21.1046 21 20V6C21 4.89543 20.1046 4 19 4Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M16 2V6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M8 2V6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M3 10H21" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <h3 class="text-xl font-semibold mb-3">Flexible Schedule</h3>
                        <p class="text-gray-600">Work when you're most productive</p>
                    </div>

                    <div class="animate-on-scroll delay-3 feature-card">
                        <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center mb-5">
                            <svg class="w-6 h-6 text-red-600" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M2 3H8C9.06087 3 10.0783 3.42143 10.8284 4.17157C11.5786 4.92172 12 5.93913 12 7V21C12 20.2044 11.6839 19.4413 11.1213 18.8787C10.5587 18.3161 9.79565 18 9 18H2V3Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M22 3H16C14.9391 3 13.9217 3.42143 13.1716 4.17157C12.4214 4.92172 12 5.93913 12 7V21C12 20.2044 12.3161 19.4413 12.8787 18.8787C13.4413 18.3161 14.2044 18 15 18H22V3Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <h3 class="text-xl font-semibold mb-3">Learning Budget</h3>
                        <p class="text-gray-600">Annual budget for courses, books, and conferences</p>
                    </div>

                    <div class="animate-on-scroll delay-4 feature-card">
                        <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mb-5">
                            <svg class="w-6 h-6 text-orange-600" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M21 16V8C20.9996 7.64927 20.9071 7.30481 20.7315 7.00116C20.556 6.69751 20.3037 6.44536 20 6.27L13 2.27C12.696 2.09446 12.3511 2.00205 12 2.00205C11.6489 2.00205 11.304 2.09446 11 2.27L4 6.27C3.69626 6.44536 3.44398 6.69751 3.26846 7.00116C3.09294 7.30481 3.00036 7.64927 3 8V16C3.00036 16.3507 3.09294 16.6952 3.26846 16.9988C3.44398 17.3025 3.69626 17.5546 4 17.73L11 21.73C11.304 21.9055 11.6489 21.9979 12 21.9979C12.3511 21.9979 12.696 21.9055 13 21.73L20 17.73C20.3037 17.5546 20.556 17.3025 20.7315 16.9988C20.9071 16.6952 20.9996 16.3507 21 16Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M3.27 6.96L12 12.01L20.73 6.96" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M12 22.08V12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <h3 class="text-xl font-semibold mb-3">Equity Options</h3>
                        <p class="text-gray-600">Share in the company's success</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Open Positions Section -->
        <section id="open-positions" class="section bg-gray-50">
            <div class="container-custom">
                <h2 class="animate-on-scroll delay-0 text-3xl md:text-4xl font-bold text-center mb-16">
                    Open <span class="gradient-text">Positions</span>
                </h2>
                <div class="space-y-6">
                    <div class="animate-on-scroll delay-1 feature-card">
                        <div class="flex flex-col md:flex-row md:items-center md:justify-between">
                            <div>
                                <h3 class="text-2xl font-semibold mb-3">Senior Laravel Developer</h3>
                                <p class="text-gray-600 text-lg mb-4">Build and maintain our core Laravel email infrastructure and APIs.</p>
                                <div class="flex items-center gap-4">
                                    <span class="bg-red-100 text-red-600 px-4 py-1.5 rounded-full text-sm font-medium">Full-time</span>
                                    <span class="bg-orange-100 text-orange-600 px-4 py-1.5 rounded-full text-sm font-medium">Remote</span>
                                    <span class="bg-gray-100 text-gray-600 px-4 py-1.5 rounded-full text-sm font-medium">PHP • Laravel • MySQL</span>
                                </div>
                            </div>
                            <a href="/careers/senior-laravel-developer" class="mt-6 md:mt-0 btn btn-primary">
                                Learn more →
                            </a>
                        </div>
                    </div>

                    <div class="animate-on-scroll delay-2 feature-card">
                        <div class="flex flex-col md:flex-row md:items-center md:justify-between">
                            <div>
                                <h3 class="text-2xl font-semibold mb-3">DevOps Engineer</h3>
                                <p class="text-gray-600 text-lg mb-4">Scale our email infrastructure and ensure high deliverability rates.</p>
                                <div class="flex items-center gap-4">
                                    <span class="bg-red-100 text-red-600 px-4 py-1.5 rounded-full text-sm font-medium">Full-time</span>
                                    <span class="bg-orange-100 text-orange-600 px-4 py-1.5 rounded-full text-sm font-medium">Remote</span>
                                    <span class="bg-gray-100 text-gray-600 px-4 py-1.5 rounded-full text-sm font-medium">AWS • Docker • Postfix</span>
                                </div>
                            </div>
                            <a href="/careers/devops-engineer" class="mt-6 md:mt-0 btn btn-primary">
                                Learn more →
                            </a>
                        </div>
                    </div>

                    <div class="animate-on-scroll delay-3 feature-card">
                        <div class="flex flex-col md:flex-row md:items-center md:justify-between">
                            <div>
                                <h3 class="text-2xl font-semibold mb-3">Customer Success Engineer</h3>
                                <p class="text-gray-600 text-lg mb-4">Help Laravel developers integrate and optimize their email workflows.</p>
                                <div class="flex items-center gap-4">
                                    <span class="bg-red-100 text-red-600 px-4 py-1.5 rounded-full text-sm font-medium">Full-time</span>
                                    <span class="bg-orange-100 text-orange-600 px-4 py-1.5 rounded-full text-sm font-medium">Remote</span>
                                    <span class="bg-gray-100 text-gray-600 px-4 py-1.5 rounded-full text-sm font-medium">Laravel • Email • Support</span>
                                </div>
                            </div>
                            <a href="/careers/customer-success-engineer" class="mt-6 md:mt-0 btn btn-primary">
                                Learn more →
                            </a>
                        </div>
                    </div>

                    <div class="animate-on-scroll delay-4 feature-card">
                        <div class="flex flex-col md:flex-row md:items-center md:justify-between">
                            <div>
                                <h3 class="text-2xl font-semibold mb-3">Frontend Developer</h3>
                                <p class="text-gray-600 text-lg mb-4">Create intuitive dashboards and email template builders for our users.</p>
                                <div class="flex items-center gap-4">
                                    <span class="bg-red-100 text-red-600 px-4 py-1.5 rounded-full text-sm font-medium">Full-time</span>
                                    <span class="bg-orange-100 text-orange-600 px-4 py-1.5 rounded-full text-sm font-medium">Remote</span>
                                    <span class="bg-gray-100 text-gray-600 px-4 py-1.5 rounded-full text-sm font-medium">Vue.js • Tailwind • Inertia</span>
                                </div>
                            </div>
                            <a href="/careers/frontend-developer" class="mt-6 md:mt-0 btn btn-primary">
                                Learn more →
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="section bg-gradient-to-r from-red-600 to-orange-600">
            <div class="container-custom text-center">
                <h2 class="animate-on-scroll delay-0 text-3xl md:text-4xl font-bold text-white mb-8">Don't see the right position?</h2>
                <p class="animate-on-scroll delay-1 text-xl text-white/90 mb-10 max-w-2xl mx-auto">
                    We're always looking for talented Laravel developers and email infrastructure experts. Send us your resume and we'll keep you in mind for future opportunities.
                </p>
                <a
                        href="mailto:careers@laravelmail.com"
                        class="animate-on-scroll delay-2 btn bg-white text-red-600 hover:bg-white/90"
                >
                    Contact Us
                </a>
            </div>
        </section>
    </main>
</Layout>
---
import Layout from "../layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { getRelativeLocaleUrl } from "astro:i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout
    title="Contact Laravel Mail | Book a Consultation"
    description="Ready to transform your business? Schedule a free consultation to discuss your project and automation needs."
>
    <section class="pt-20 pb-16 md:pt-28 md:pb-24 bg-white/5">
        <div class="container-custom">
            <nav class="mb-8" aria-label="Breadcrumb">
                <ol class="flex items-center space-x-2 text-sm text-gray-400">
                    <li>
                        <a href={getRelativeLocaleUrl(lang, "/")} class="hover:text-red-400 transition-colors">Home</a>
                    </li>
                    <li>/</li>
                    <li class="text-red-400 font-medium">Contact</li>
                </ol>
            </nav>

            <div class="text-center max-w-3xl mx-auto animate-on-scroll animated">
                <h1 class="text-4xl md:text-5xl font-bold leading-tight text-white">
                    Schedule Your <span class="gradient-text bg-gradient-to-r from-red-600 to-orange-600 bg-clip-text text-transparent">Consultation</span>
                </h1>
                <p class="mt-6 text-xl text-gray-400">
                    Ready to transform your business? Select a time below to discuss your
                    project and automation needs.
                </p>

                <div class="flex flex-wrap justify-center gap-6 text-sm text-gray-400 mt-8 mb-10">
                    <div class="flex items-center">
                        <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                        </svg>
                        120+ businesses scaled with our system
                    </div>
                    <div class="flex items-center">
                        <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                        </svg>
                        92% client retention rate
                    </div>
                    <div class="flex items-center">
                        <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                        </svg>
                        Booked in under 60 seconds
                    </div>
                </div>

                <div class="mt-8 p-6 bg-gradient-to-r from-[#4A154B] to-[#611f69] rounded-xl max-w-2xl mx-auto">
                    <div class="flex flex-col md:flex-row items-center gap-4">
                        <div class="flex-shrink-0">
                            <svg class="w-12 h-12 text-white" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zM6.313 15.165a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zM8.834 6.313a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zM18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zM17.688 8.834a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312zM15.165 18.956a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zM15.165 17.688a2.527 2.527 0 0 1-2.52-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z"/>
                            </svg>
                        </div>
                        <div class="text-center md:text-left">
                            <h3 class="text-white font-bold text-lg">Join Our Slack Community</h3>
                            <p class="text-white/70 text-sm">Connect with 1,200+ Laravel developers, share knowledge, and get help from the community.</p>
                        </div>
                        <a href="https://join.slack.com/t/laravelmail/shared_invite/zt-2r6gsz5w7-W2cm_N2~AYrsv8UvBxRxSA" target="_blank" rel="noopener noreferrer" class="whitespace-nowrap bg-white text-[#4A154B] font-semibold py-2 px-5 rounded-lg hover:bg-gray-100 transition-colors">
                            Join Slack
                        </a>
                    </div>
                </div>
            </div>

            <div class="mt-12 grid grid-cols-1 lg:grid-cols-2 gap-8">
                <div class="rounded-xl overflow-hidden animate-on-scroll shadow-lg bg-white/10 p-0 animated">
                    <div class="calendly-inline-widget" data-url="https://calendly.com/laravelagency/30min?background_color=0f172a&amp;text_color=ffffff&amp;primary_color=7c3aed&amp&utm_source=website&amp&utm_medium=general_inquiry&amp&utm_campaign=contact_page" style="position: relative;min-width:320px;height:700px;" data-processed="true">
                        <div class="calendly-spinner">
                            <div class="calendly-bounce1"></div>
                            <div class="calendly-bounce2"></div>
                            <div class="calendly-bounce3"></div>
                        </div>
                        <iframe src="https://calendly.com/laravelagency/30min?embed_domain=laravelmail.com&amp;embed_type=Inline&amp;background_color=0f172a&amp;text_color=ffffff&amp;primary_color=7c3aed&amp&utm_source=website&amp&utm_medium=general_inquiry&amp&utm_campaign=contact_page" width="100%" height="100%" frameborder="0" title="Select a Date &amp; Time - Calendly"></iframe>
                    </div>
                    <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async="" data-astro-exec=""></script>
                </div>

                <div class="rounded-xl overflow-hidden animate-on-scroll shadow-lg bg-white/10 animated">
                    <div class="w-full h-full flex flex-col">
                        <div class="bg-gradient-to-r from-blue-600 to-indigo-700 p-6 text-white">
                            <h3 class="text-2xl font-bold mb-1">What to Expect</h3>
                            <p class="text-blue-100">
                                We help tech &amp; service businesses fill their calendar with
                                high-intent clients — without cold calling.
                            </p>
                        </div>

                        <div class="p-6 space-y-6 flex-1">
                            <div class="flex items-start space-x-4">
                                <div class="flex-shrink-0 w-10 h-10 bg-blue-900/20 rounded-full flex items-center justify-center mt-1">
                                    <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                                    </svg>
                                </div>
                                <div>
                                    <h4 class="font-semibold text-white">
                                        Free Strategy Session
                                    </h4>
                                    <p class="text-gray-400 text-sm mt-1">
                                        30-minute consultation to understand your needs and goals.
                                    </p>
                                </div>
                            </div>

                            <div class="flex items-start space-x-4">
                                <div class="flex-shrink-0 w-10 h-10 bg-green-900/20 rounded-full flex items-center justify-center mt-1">
                                    <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                                    </svg>
                                </div>
                                <div>
                                    <h4 class="font-semibold text-white">No Obligation</h4>
                                    <p class="text-gray-400 text-sm mt-1">
                                        No pressure, no sales pitch - just honest advice.
                                    </p>
                                </div>
                            </div>

                            <div class="flex items-start space-x-4">
                                <div class="flex-shrink-0 w-10 h-10 bg-purple-900/20 rounded-full flex items-center justify-center mt-1">
                                    <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                </div>
                                <div>
                                    <h4 class="font-semibold text-white">Actionable Insights</h4>
                                    <p class="text-gray-400 text-sm mt-1">
                                        Get specific recommendations for your business growth.
                                    </p>
                                </div>
                            </div>

                            <blockquote class="border-l-4 border-blue-500 bg-blue-900/10 p-4 rounded-r-lg mt-6">
                                <p class="text-gray-300 italic">
                                    "The consultation was eye-opening. We got concrete next steps
                                    that we implemented immediately."
                                </p>
                                <footer class="mt-2 text-sm text-gray-400 font-medium">
                                    — Sarah M., Tech Startup CEO
                                </footer>
                            </blockquote>

                            <div class="mt-8 p-4 bg-gradient-to-r from-blue-900/20 to-indigo-900/20 rounded-lg border border-blue-900/30">
                                <h4 class="font-semibold text-white mb-2">
                                    Ready to Get Started?
                                </h4>
                                <p class="text-gray-400 text-sm mb-4">
                                    Book your free strategy session and take the first step
                                    towards business growth.
                                </p>
                                <a href="https://calendly.com/laravelagency/30min?utm_source=website&utm_medium=general_inquiry&utm_campaign=contact_page_cta" class="inline-block w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 px-6 rounded-lg text-center transition-all duration-200 shadow-md hover:shadow-lg transform hover:-translate-y-1">
                                    Book Your Free Strategy Call Now
                                </a>
                            </div>

                            <p class="text-xs text-gray-500 mt-2">
                                No sales pitch. Just a 30-minute plan to grow your business.
                            </p>
                        </div>

                        <div class="border-t border-white/10 p-6">
                            <h4 class="font-semibold text-white mb-3">
                                Alternative Contact Methods
                            </h4>
                            <div class="space-y-2">
                                <p class="text-gray-400">
                                    Phone: <a href="tel:+447448218899" class="text-blue-400 hover:underline">+44 744 821 8899</a>
                                </p>
                                <p class="text-gray-400">
                                    Email: <a href="#" id="footer-contact-email" class="text-blue-400 hover:underline"></a>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script is:inline>
        (function() {
            const email = 'info@laravelmail.com';
            const footerEmail = document.getElementById('footer-contact-email');
            if (footerEmail) {
                footerEmail.href = 'mailto:' + email;
                footerEmail.textContent = email;
            }
        })();
    </script>
</Layout>

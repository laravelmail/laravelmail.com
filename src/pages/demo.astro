---
import Layout from "../layouts/Layout.astro";

const demos = [
//   {
//     id: "0pX9fSCyOn0",
//     title: "Platform Overview & Core Features",
//     description: "Learn how to navigate the Laravel Mail dashboard, manage your leads, and launch your first multi-channel campaign in minutes.",
//     category: "Getting Started"
//   },
//   {
//     id: "0pX9fSCyOn0",
//     title: "Visual Automation Builder",
//     description: "A deep dive into our drag-and-drop automation engine. See how to build complex customer journeys across Email, WhatsApp, and Instagram.",
//     category: "Tutorial"
//   },
//   {
//     id: "0pX9fSCyOn0",
//     title: "Lead Intelligence & Scoring",
//     description: "Discover how our AI-driven lead management system helps you prioritize high-intent customers and increase conversion rates.",
//     category: "Advanced"
//   }
];
---

<Layout 
  title="Product Demos - Laravel Mail"
  description="Explore the power of Laravel Mail through our detailed product demonstrations and walkthroughs."
>
  <section class="pt-32 pb-20 bg-brand-bg-darker relative overflow-hidden">
    <!-- Ambient Background Glows -->
    <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-brand-primary/10 blur-[120px] rounded-full animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-brand-accent/5 blur-[120px] rounded-full animate-pulse" style="animation-delay: 2s;"></div>

    <div class="container-custom relative z-10">
      <div class="max-w-4xl mx-auto text-center mb-24 animate-on-scroll">
        <h1 class="text-6xl md:text-8xl font-black text-white mb-8 leading-none tracking-tight">
          Product <span class="bg-gradient-to-r from-brand-primary to-brand-accent bg-clip-text text-transparent">Showcase</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-400 leading-relaxed max-w-3xl mx-auto">
          Experience the future of self-hosted email marketing. Watch how Laravel Mail transforms your communication infrastructure.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        {demos.map((demo, index) => (
          <div 
            class="demo-card group animate-on-scroll"
            style={`animation-delay: ${index * 0.15}s`}
          >
            <div class="relative aspect-video rounded-[2rem] overflow-hidden border border-white/5 bg-[#0f172a]/80 backdrop-blur-xl shadow-2xl transition-all duration-700 group-hover:scale-[1.03] group-hover:border-brand-primary/40 group-hover:shadow-brand-primary/10">
              <iframe
                class="w-full h-full"
                src={`https://www.youtube.com/embed/${demo.id}`}
                title={demo.title}
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
              <!-- Refined Overlay -->
              <div class="absolute inset-0 pointer-events-none border border-white/5 rounded-[2rem] group-hover:border-brand-primary/20 transition-colors duration-500"></div>
            </div>
            
            <div class="mt-10 px-4">
              <div class="flex items-center space-x-4 mb-4">
                <span class="px-4 py-1.5 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-brand-primary text-[10px] font-black uppercase tracking-[0.2em]">
                  {demo.category}
                </span>
                <span class="text-gray-500 text-sm font-medium">Coming Soon</span>
              </div>
              
              <h3 class="text-3xl font-bold text-white mb-4 group-hover:text-brand-primary transition-colors duration-300">
                {demo.title}
              </h3>
              <p class="text-gray-400 text-lg leading-relaxed font-medium">
                {demo.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Community Call to Action -->
  <section class="py-24 bg-brand-bg-darker relative">
    <div class="container-custom">
      <div class="bg-gradient-to-br from-brand-bg-card/80 to-brand-bg/80 border border-white/5 rounded-[3rem] p-12 md:p-20 text-center relative overflow-hidden">
        <div class="absolute inset-0 bg-brand-primary/5 blur-3xl rounded-full"></div>
        <div class="relative z-10">
          <h2 class="text-4xl md:text-5xl font-bold text-white mb-8">Ready to take control?</h2>
          <p class="text-xl text-gray-400 mb-12 max-w-2xl mx-auto">
            Join 2,000+ developers building their own marketing engines with Laravel Mail. Start your self-hosted journey today.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
            <a href="/buy" class="btn btn-primary px-10 py-5 text-xl font-bold rounded-2xl w-full sm:w-auto shadow-2xl shadow-brand-primary/20">
              Get Started Now
            </a>
            <a href="/contact" class="text-white font-bold hover:text-brand-primary transition-colors flex items-center group">
              Request a Custom Demo
              <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .glassmorphism {
    background: rgba(30, 41, 59, 0.4);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  /* Ensure video aspect ratio on mobile */
  @media (max-width: 640px) {
    .demo-card {
      margin-bottom: 2rem;
    }
  }
</style>

---
import Layout from "../layouts/Layout.astro";
import BetaModal from "../components/BetaModal.astro";

const repoUrl = "https://github.com/laravelmail/laravelmail.com";

const deploymentPlatforms = [
    {
        name: "Google Cloud",
        logo: "https://deploy.cloud.run/button.svg",
        url: `https://deploy.cloud.run?git_repo=${repoUrl}`,
        description:
            "Deploy to Google Cloud Run (Serverless Docker) with one click.",
        accent: "from-[#4285F4] to-[#34A853]",
    },
    {
        name: "DigitalOcean",
        logo: "https://www.deploytodo.com/do-btn-blue.svg",
        url: `https://www.digitalocean.com/deploy?repository=${repoUrl}`,
        description:
            "Deploy to DigitalOcean App Platform with native Docker support.",
        accent: "from-[#0080FF] to-[#0069D9]",
    },
    {
        name: "Railway",
        logo: "https://railway.app/button.svg",
        url: `https://railway.app/new/import?repo=${repoUrl}`,
        description: "Zero-config Docker deployment on Railway.",
        accent: "from-[#0B0D0E] to-[#1A1C1D]",
    },
    {
        name: "Heroku",
        logo: "https://www.herokucdn.com/deploy/button.svg",
        url: `https://heroku.com/deploy?template=${repoUrl}`,
        description: "Deploy your Docker implementation to Heroku.",
        accent: "from-[#430098] to-[#7673B0]",
    },
];

// SEO Schema
const schema = {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "Laravel Mail Deployment",
    operatingSystem: "Linux, Docker",
    applicationCategory: "MarketingApplication",
    offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "USD",
    },
    description:
        "Deploy Laravel Mail instantly using our one-click Docker deployment options for Google Cloud Run, DigitalOcean, Railway, and more.",
    publisher: {
        "@type": "Organization",
        name: "Laravel Mail",
        url: "https://laravelmail.com",
    },
};
---

<Layout
    title="Deploy Laravel Mail | One-Click Docker Setup"
    description="Set up your self-hosted marketing platform in seconds. One-click Docker deployment for Google Cloud Run, DigitalOcean, Railway, and Heroku. Free, open-source, and developer-friendly."
>
    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <!-- Tracking Script -->
    <script is:inline>
        function trackDeployClick(platform) {
            if (typeof window.gtag !== "undefined") {
                window.gtag("event", "deploy_click", {
                    platform: platform,
                    event_category: "deployment",
                    event_label: platform,
                });
            }
            if (typeof console !== "undefined") {
                console.log("Tracking deploy click:", platform);
            }
        }
    </script>

    <section class="relative pt-20 pb-20 md:pt-32 md:pb-32 overflow-hidden">
        <!-- Background Ornaments -->
        <div
            class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none opacity-30"
        >
            <div
                class="absolute -top-24 -left-24 w-96 h-96 bg-brand-primary/20 blur-[120px] rounded-full"
            >
            </div>
            <div
                class="absolute top-1/2 -right-24 w-80 h-80 bg-brand-blue/20 blur-[100px] rounded-full"
            >
            </div>
        </div>

        <div class="container-custom relative z-10">
            <div class="max-w-4xl mx-auto text-center mb-20 animate-on-scroll">
                <div
                    class="inline-flex items-center space-x-2 bg-brand-primary/10 border border-brand-primary/20 text-brand-primary px-4 py-2 rounded-full text-sm font-bold mb-6"
                >
                    <span class="relative flex h-2 w-2">
                        <span
                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-primary opacity-75"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-2 w-2 bg-brand-primary"
                        ></span>
                    </span>
                    <span>Ready for Production</span>
                </div>
                <h1
                    class="text-5xl md:text-7xl font-black text-white mb-8 leading-tight tracking-tight"
                >
                    Deploy in <span
                        class="text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-brand-blue"
                        >Seconds</span
                    >
                </h1>
                <p
                    class="text-xl text-gray-400 leading-relaxed max-w-2xl mx-auto"
                >
                    Pick a platform, click a button, and watch your <strong
                        class="text-white">Laravel Mail</strong
                    > instance come to life.
                </p>
            </div>

            <div
                class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-7xl mx-auto"
            >
                <div
                    class="group relative bg-[#1e293b]/40 backdrop-blur-md p-8 rounded-3xl border border-white/5 shadow-sm hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 animate-on-scroll overflow-hidden flex flex-col"
                >
                    <div
                        class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-[#4285F4] to-[#34A853] opacity-0 group-hover:opacity-100 transition-opacity"
                    >
                    </div>
                    <div class="h-12 flex items-center mb-6">
                        <h3
                            class="text-xl font-extrabold text-white group-hover:text-brand-primary transition-colors"
                        >
                            Google Cloud
                        </h3>
                    </div>
                    <p class="text-gray-400 text-sm mb-8 line-clamp-2">
                        Deploy to Google Cloud Run (Serverless Docker) with one
                        click.
                    </p>
                    <div class="mt-auto"></div>
                </div><div
                    class="group relative bg-[#1e293b]/40 backdrop-blur-md p-8 rounded-3xl border border-white/5 shadow-sm hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 animate-on-scroll overflow-hidden flex flex-col"
                >
                    <div
                        class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-[#0080FF] to-[#0069D9] opacity-0 group-hover:opacity-100 transition-opacity"
                    >
                    </div>
                    <div class="h-12 flex items-center mb-6">
                        <h3
                            class="text-xl font-extrabold text-white group-hover:text-brand-primary transition-colors"
                        >
                            DigitalOcean
                        </h3>
                    </div>
                    <p class="text-gray-400 text-sm mb-8 line-clamp-2">
                        Deploy to DigitalOcean App Platform with native Docker
                        support.
                    </p>
                    <div class="mt-auto"></div>
                </div><div
                    class="group relative bg-[#1e293b]/40 backdrop-blur-md p-8 rounded-3xl border border-white/5 shadow-sm hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 animate-on-scroll overflow-hidden flex flex-col"
                >
                    <div
                        class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-[#0B0D0E] to-[#1A1C1D] opacity-0 group-hover:opacity-100 transition-opacity"
                    >
                    </div>
                    <div class="h-12 flex items-center mb-6">
                        <h3
                            class="text-xl font-extrabold text-white group-hover:text-brand-primary transition-colors"
                        >
                            Railway
                        </h3>
                    </div>
                    <p class="text-gray-400 text-sm mb-8 line-clamp-2">
                        Zero-config Docker deployment on Railway.
                    </p>
                    <div class="mt-auto"></div>
                </div><div
                    class="group relative bg-[#1e293b]/40 backdrop-blur-md p-8 rounded-3xl border border-white/5 shadow-sm hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 animate-on-scroll overflow-hidden flex flex-col"
                >
                    <div
                        class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-[#430098] to-[#7673B0] opacity-0 group-hover:opacity-100 transition-opacity"
                    >
                    </div>
                    <div class="h-12 flex items-center mb-6">
                        <h3
                            class="text-xl font-extrabold text-white group-hover:text-brand-primary transition-colors"
                        >
                            Heroku
                        </h3>
                    </div>
                    <p class="text-gray-400 text-sm mb-8 line-clamp-2">
                        Deploy your Docker implementation to Heroku.
                    </p>
                    <div class="mt-auto"></div>
                </div>
            </div>
        </div>
    </section>

    <BetaModal />
</Layout>

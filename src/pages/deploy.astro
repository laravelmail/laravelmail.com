---
import Layout from "../layouts/Layout.astro";
import BetaModal from "../components/BetaModal.astro";

const deploymentPlatforms = [
    {
        name: "Google Cloud",
        logo: "https://deploy.cloud.run/button.svg",
        url: "/buy",
        description:
            "Ready for production with Google Cloud Run (Serverless Docker).",
        accent: "from-[#4285F4] to-[#34A853]",
    },
    {
        name: "DigitalOcean",
        logo: "https://www.deploytodo.com/do-btn-blue.svg",
        url: "/buy",
        description:
            "Scale seamlessly on DigitalOcean App Platform with native Docker.",
        accent: "from-[#0080FF] to-[#0069D9]",
    },
    {
        name: "Railway",
        logo: "https://railway.app/button.svg",
        url: "/buy",
        description: "Zero-config enterprise deployment on Railway.",
        accent: "from-[#0B0D0E] to-[#1A1C1D]",
    },
    {
        name: "Heroku",
        logo: "https://www.herokucdn.com/deploy/button.svg",
        url: "/buy",
        description: "Professional Docker implementation for Heroku.",
        accent: "from-[#430098] to-[#7673B0]",
    },
];

// SEO Schema
const schema = {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "Laravel Mail Deployment",
    operatingSystem: "Linux, Docker",
    applicationCategory: "MarketingApplication",
    offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "USD",
    },
    description:
        "Deploy Laravel Mail instantly using our one-click Docker deployment options for Google Cloud Run, DigitalOcean, Railway, and more.",
    publisher: {
        "@type": "Organization",
        name: "Laravel Mail",
        url: "https://laravelmail.com",
    },
};
---

<Layout
    title="Deploy Laravel Mail | One-Click & Self-Hosted Setup"
    description="Set up your self-hosted marketing platform in seconds. One-click Docker deployment or custom self-hosting with Docker Compose. Free, open-source, and developer-friendly."
>
    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <!-- Tracking Script -->
    <script is:inline>
        function trackDeployClick(platform) {
            if (typeof window.gtag !== "undefined") {
                window.gtag("event", "deploy_click", {
                    platform: platform,
                    event_category: "deployment",
                    event_label: platform,
                });
            }
            if (typeof console !== "undefined") {
                console.log("Tracking deploy click:", platform);
            }
        }
    </script>

    <section class="relative pt-20 pb-16 md:pt-32 md:pb-24 overflow-hidden">
        <!-- Background Ornaments -->
        <div
            class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none opacity-30"
        >
            <div
                class="absolute -top-24 -left-24 w-96 h-96 bg-brand-primary/20 blur-[120px] rounded-full"
            >
            </div>
            <div
                class="absolute top-1/2 -right-24 w-80 h-80 bg-brand-blue/20 blur-[100px] rounded-full"
            >
            </div>
        </div>

        <div class="container-custom relative z-10">
            <div class="max-w-4xl mx-auto text-center mb-20 animate-on-scroll">
                <div
                    class="inline-flex items-center space-x-2 bg-brand-primary/10 border border-brand-primary/20 text-brand-primary px-4 py-2 rounded-full text-sm font-bold mb-6"
                >
                    <span class="relative flex h-2 w-2">
                        <span
                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-primary opacity-75"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-2 w-2 bg-brand-primary"
                        ></span>
                    </span>
                    <span>Ready for Production</span>
                </div>
                <h1
                    class="text-5xl md:text-7xl font-black text-white mb-8 leading-tight tracking-tight"
                >
                    Deploy in <span
                        class="text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-brand-blue"
                        >Seconds</span
                    >
                </h1>
                <p
                    class="text-xl text-gray-400 leading-relaxed max-w-2xl mx-auto"
                >
                    Pick a platform for one-click deployment or use our Docker
                    Compose setup for full control over your infrastructure.
                </p>
            </div>

            <!-- One-Click Grid -->
            <div
                class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-7xl mx-auto mb-32"
            >
                {
                    deploymentPlatforms.map((platform) => (
                        <a
                            href={platform.url}
                            onclick={`trackDeployClick('${platform.name}')`}
                            class="group relative bg-brand-bg-card/40 backdrop-blur-md p-8 rounded-3xl border border-white/10 shadow-sm hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 animate-on-scroll overflow-hidden flex flex-col"
                        >
                            <div
                                class={`absolute top-0 left-0 w-full h-1 bg-gradient-to-r ${platform.accent} opacity-0 group-hover:opacity-100 transition-opacity`}
                            />
                            <div class="h-12 flex items-center mb-6">
                                <img
                                    src={platform.logo}
                                    alt={platform.name}
                                    class="h-8 w-auto grayscale group-hover:grayscale-0 transition-all duration-300"
                                />
                            </div>
                            <h3 class="text-xl font-extrabold text-white group-hover:text-brand-primary transition-colors mb-4">
                                {platform.name}
                            </h3>
                            <p class="text-gray-400 text-sm mb-8 line-clamp-2">
                                {platform.description}
                            </p>
                            <div class="mt-auto flex items-center text-brand-primary font-bold text-sm">
                                Deploy Now
                                <svg
                                    class="w-4 h-4 ml-2 transition-transform group-hover:translate-x-1"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="3"
                                        d="M17 8l4 4m0 0l-4 4m4-4H3"
                                    />
                                </svg>
                            </div>
                        </a>
                    ))
                }
            </div>

            <!-- Manual Setup / Docker Compose -->
            <div class="max-w-5xl mx-auto">
                <div
                    class="bg-gradient-to-br from-[#1e293b]/80 to-[#0f172a]/80 backdrop-blur-xl rounded-[2.5rem] border border-white/10 p-8 md:p-16 shadow-3xl relative overflow-hidden"
                >
                    <!-- Decor -->
                    <div class="absolute top-0 right-0 p-8 opacity-10">
                        <svg
                            class="w-32 h-32 text-brand-primary"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M13.983 7.1L12 1.9l-1.983 5.2H4.42l4.45 3.233-1.7 5.2L12 12.3l4.83 3.233-1.7-5.2 4.45-3.233h-5.597z"
                            ></path>
                        </svg>
                    </div>

                    <div class="relative z-10">
                        <h2
                            class="text-3xl md:text-5xl font-black text-white mb-6"
                        >
                            Self-Host with <span class="text-brand-primary"
                                >Docker Compose</span
                            >
                        </h2>
                        <p class="text-xl text-gray-400 mb-12 max-w-3xl">
                            Gain full control over your customer data. After
                            purchase, you'll receive immediate access to our <strong
                                >Private Docker Repository</strong
                            > and complete source code for self-hosted production.
                        </p>

                        <!-- Step by Step -->
                        <div
                            class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16"
                        >
                            <div class="space-y-4">
                                <div
                                    class="w-12 h-12 rounded-2xl bg-brand-primary/20 flex items-center justify-center text-brand-primary font-black text-xl"
                                >
                                    1
                                </div>
                                <h4 class="text-white font-bold text-lg">
                                    Clone Private Repository
                                </h4>
                                <p class="text-gray-400 text-sm">
                                    Get access to the private Git repository
                                    after your purchase.
                                </p>
                            </div>
                            <div class="space-y-4">
                                <div
                                    class="w-12 h-12 rounded-2xl bg-brand-blue/20 flex items-center justify-center text-brand-blue font-black text-xl"
                                >
                                    2
                                </div>
                                <h4 class="text-white font-bold text-lg">
                                    Configure Environment
                                </h4>
                                <p class="text-gray-400 text-sm">
                                    Copy .env.example to .env and set your app
                                    keys and database credentials.
                                </p>
                            </div>
                            <div class="space-y-4">
                                <div
                                    class="w-12 h-12 rounded-2xl bg-pink-500/20 flex items-center justify-center text-pink-500 font-black text-xl"
                                >
                                    3
                                </div>
                                <h4 class="text-white font-bold text-lg">
                                    Launch Container
                                </h4>
                                <p class="text-gray-400 text-sm">
                                    Run docker-compose up -d and your platform
                                    is live on port 13000.
                                </p>
                            </div>
                        </div>

                        <div
                            class="mt-12 flex flex-col sm:flex-row items-center gap-6"
                        >
                            <a
                                href="https://app.laravelmail.com/docs"
                                target="_blank"
                                class="btn btn-primary px-8 py-4 w-full sm:w-auto text-center font-bold"
                            >
                                Read Full Documentation
                            </a>
                            <p class="text-gray-500 text-sm italic">
                                Need help? Join our <a
                                    href="#"
                                    class="text-brand-primary hover:underline"
                                    >Discord community</a
                                >.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <BetaModal />
</Layout>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        height: 8px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: rgba(0, 0, 0, 0.1);
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.2);
    }
</style>

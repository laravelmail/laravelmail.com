---
import Layout from "../layouts/Layout.astro";
import CTASection from "../components/CTASection.astro";

const title = "Digital Marketing Resources & Statistics 2026 | Laravel Mail";
const description = "Comprehensive list of digital marketing resources, tools, and statistics for developers and marketing professionals.";
---

<Layout title={title} description={description}>
    <section class="pt-32 pb-20 bg-brand-bg relative">
        <div class="container-custom">
            <h1 class="text-4xl md:text-6xl font-black text-white mb-8 text-center uppercase tracking-tighter">
                Digital Marketing <span class="text-brand-primary">Resources</span>
            </h1>
            
            <div class="max-w-4xl mx-auto">
                <p class="text-xl text-gray-400 mb-12 text-center">
                    Curated list of <strong>digital marketing</strong> statistics and tools designed to help you build better
                    <strong>marketing digital</strong> campaigns.
                </p>

                <div class="mb-16">
                    <h2 class="text-3xl font-bold text-white mb-8 border-l-4 border-brand-primary pl-4">Digital Marketing Statistics 2026</h2>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse bg-white/5 rounded-2xl overflow-hidden">
                            <thead>
                                <tr class="bg-white/10 text-white font-bold">
                                    <th class="p-4">Category</th>
                                    <th class="p-4">Statistic</th>
                                    <th class="p-4">Source</th>
                                </tr>
                            </thead>
                            <tbody class="text-gray-300">
                                <tr class="border-b border-white/5">
                                    <td class="p-4 font-bold">Email ROI</td>
                                    <td class="p-4">$42 for every $1 spent</td>
                                    <td class="p-4">DMA</td>
                                </tr>
                                <tr class="border-b border-white/5">
                                    <td class="p-4 font-bold">Automation</td>
                                    <td class="p-4">76% of companies use it</td>
                                    <td class="p-4">HubSpot</td>
                                </tr>
                                <tr class="border-b border-white/5">
                                    <td class="p-4 font-bold">Search (SEO)</td>
                                    <td class="p-4">68% of online experiences start with a search</td>
                                    <td class="p-4">BrightEdge</td>
                                </tr>
                                <tr>
                                    <td class="p-4 font-bold">Developers</td>
                                    <td class="p-4">40% of developers influence marketing tech buys</td>
                                    <td class="p-4">Stack Overflow</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
                    <div class="p-8 rounded-2xl bg-white/5 border border-white/10">
                        <h3 class="text-2xl font-bold text-white mb-4">Downloadable Guides</h3>
                        <ul class="space-y-4">
                            <li>
                                <a href="#" class="flex justify-between items-center text-brand-primary hover:underline">
                                    <span>2026 Digital Marketing Blueprint</span>
                                    <span class="text-xs bg-brand-primary/20 px-2 py-1 rounded text-white italic">PDF</span>
                                </a>
                            </li>
                            <li>
                                <a href="#" class="flex justify-between items-center text-brand-primary hover:underline">
                                    <span>Laravel Email Optimization Guide</span>
                                    <span class="text-xs bg-brand-primary/20 px-2 py-1 rounded text-white italic">PDF</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                    <div class="p-8 rounded-2xl bg-white/5 border border-white/10">
                        <h3 class="text-2xl font-bold text-white mb-4">Community Resources</h3>
                        <p class="text-gray-400 mb-6">
                            Join over 5,000 developers discussing <strong>digital marketing marketing</strong> 
                            in our private Slack community.
                        </p>
                        <a href="/contact" class="text-white font-bold inline-flex items-center gap-2">
                            Join Now <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <CTASection />
</Layout>

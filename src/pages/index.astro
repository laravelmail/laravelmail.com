---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Partners from "../components/Partners.astro";
import Features from "../components/Features.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Testimonials from "../components/Testimonials.astro";
import CTASection from "../components/CTASection.astro";
import FAQ from "../components/FAQ.astro";
---

<Layout
  title="Self hosted marketing platform"
  description="Laravel Mail is a free, open-source marketing automation platform. Self-hosted marketing platform, lead management, and campaign automation software trusted by developers worldwide."
>
  <Hero />
  <Partners />

  <section class="py-24 bg-[#0a0e27]/40 overflow-hidden">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto mb-20">
        <h2
          class="text-4xl md:text-5xl font-black text-white mb-6 leading-tight"
        >
          Marketing Automation
          <span
            class="block text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-brand-accent"
          >
            Across Every Channel
          </span>
        </h2>
        <p class="text-xl text-gray-400 leading-relaxed">
          From WhatsApp marketing broadcasts and Instagram DM automation to
          Google Marketplace listings and smart product-driven campaigns —
          <strong class="text-white">Laravel Mail</strong> scales with your ambition.
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-10 max-w-7xl mx-auto">
        <!-- WhatsApp + Instagram -->
        <div
          class="group relative bg-[#1e293b]/40 backdrop-blur-md rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-500 border border-white/10 overflow-hidden"
        >
          <div
            class="absolute inset-0 bg-gradient-to-br from-green-500/10 to-emerald-600/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
          >
          </div>
          <div class="relative p-10">
            <div class="flex items-center gap-4 mb-6">
              <div
                class="p-4 bg-gradient-to-br from-green-500 to-emerald-600 rounded-2xl shadow-lg"
              >
                <svg
                  class="w-10 h-10 text-white"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.884 3.488"
                  ></path>
                </svg>
              </div>
              <h3
                class="text-3xl font-bold text-white"
                title="whatsapp laravel integration"
              >
                WhatsApp + Instagram
              </h3>
            </div>
            <p class="text-lg text-gray-400 mb-8">
              Official <strong class="text-white">Facebook Partner Login</strong
              > — run WhatsApp Business campaigns, Instagram DM automation, comment
              replies, and story mentions from one dashboard.
            </p>
            <ul class="space-y-4">
              <li class="flex items-center text-gray-300">
                <span
                  class="w-8 h-8 bg-green-500/20 text-green-400 rounded-full flex items-center justify-center font-bold mr-3"
                  >✓</span
                >
                WhatsApp Broadcasts & Flows
              </li>
              <li class="flex items-center text-gray-300">
                <span
                  class="w-8 h-8 bg-green-500/20 text-green-400 rounded-full flex items-center justify-center font-bold mr-3"
                  >✓</span
                >
                Instagram Auto-Replies & Mentions
              </li>
              <li class="flex items-center text-gray-300">
                <span
                  class="w-8 h-8 bg-green-500/20 text-green-400 rounded-full flex items-center justify-center font-bold mr-3"
                  >✓</span
                >
                Shared Team Inbox
              </li>
            </ul>
          </div>
        </div>

        <!-- Google Marketplace + Products -->
        <div
          class="group relative bg-[#1e293b]/40 backdrop-blur-md rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-500 border border-white/10 overflow-hidden"
        >
          <div
            class="absolute inset-0 bg-gradient-to-br from-brand-blue/10 to-indigo-600/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
          >
          </div>
          <div class="relative p-10">
            <div class="flex items-center gap-4 mb-6">
              <div
                class="p-4 bg-gradient-to-br from-brand-blue to-indigo-600 rounded-2xl shadow-lg"
              >
                <svg
                  class="w-10 h-10 text-white"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
                </svg>
              </div>
              <h3 class="text-3xl font-bold text-white">
                Google Marketplace & Products
              </h3>
            </div>
            <p class="text-lg text-gray-400 mb-8">
              List your SaaS on Google Workspace Marketplace and sell
              digital/physical products directly inside your email & WhatsApp
              flows.
            </p>
            <ul class="space-y-4">
              <li class="flex items-center text-gray-300">
                <span
                  class="w-8 h-8 bg-brand-blue/20 text-brand-blue rounded-full flex items-center justify-center font-bold mr-3"
                  >✓</span
                >
                One-click Google Marketplace deployment
              </li>
              <li class="flex items-center text-gray-300">
                <span
                  class="w-8 h-8 bg-brand-blue/20 text-brand-blue rounded-full flex items-center justify-center font-bold mr-3"
                  >✓</span
                >
                Product catalog + checkout in emails
              </li>
              <li class="flex items-center text-gray-300">
                <span
                  class="w-8 h-8 bg-brand-blue/20 text-brand-blue rounded-full flex items-center justify-center font-bold mr-3"
                  >✓</span
                >
                Dynamic pricing & inventory sync
              </li>
            </ul>
          </div>
        </div>

        <!-- SaaS & Agencies -->
        <div
          class="group relative bg-[#1e293b]/40 backdrop-blur-md rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-500 border border-white/10 overflow-hidden"
        >
          <div
            class="absolute inset-0 bg-gradient-to-br from-brand-primary/10 to-brand-accent/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
          >
          </div>
          <div class="relative p-10">
            <div class="flex items-center gap-4 mb-6">
              <div
                class="p-4 bg-gradient-to-br from-brand-primary to-brand-accent rounded-2xl shadow-lg"
              >
                <svg
                  class="w-10 h-10 text-white"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <h3 class="text-3xl font-bold text-white">SaaS & Agencies</h3>
            </div>
            <p class="text-lg text-gray-400 mb-8">
              Multi-tenant workspaces, white-label templates, client billing,
              and the most beautiful automation builder you've ever seen.
            </p>
            <ul class="space-y-4">
              <li class="flex items-center text-gray-300">
                <span
                  class="w-8 h-8 bg-brand-primary/20 text-brand-primary rounded-full flex items-center justify-center font-bold mr-3"
                  >✓</span
                >
                Drag-and-drop visual automation builder
              </li>
              <li class="flex items-center text-gray-300">
                <span
                  class="w-8 h-8 bg-brand-primary/20 text-brand-primary rounded-full flex items-center justify-center font-bold mr-3"
                  >✓</span
                >
                Unlimited clients & workspaces
              </li>
              <li class="flex items-center text-gray-300">
                <span
                  class="w-8 h-8 bg-brand-primary/20 text-brand-primary rounded-full flex items-center justify-center font-bold mr-3"
                  >✓</span
                >
                White-label + custom domains
              </li>
            </ul>
          </div>
        </div>

        <!-- Education & Nonprofits -->
        <div
          class="group relative bg-[#1e293b]/40 backdrop-blur-md rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-500 border border-white/10 overflow-hidden"
        >
          <div
            class="absolute inset-0 bg-gradient-to-br from-orange-500/10 to-red-600/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
          >
          </div>
          <div class="relative p-10">
            <div class="flex items-center gap-4 mb-6">
              <div
                class="p-4 bg-gradient-to-br from-orange-500 to-red-600 rounded-2xl shadow-lg"
              >
                <svg
                  class="w-10 h-10 text-white"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 14l9-5-9-5-9 5 9 5z"></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 14l6.16-3.422A12.083 12.083 0 0112 21.5c-2.694 0-5.092-.884-7.16-2.422L12 14z"
                  ></path>
                </svg>
              </div>
              <h3 class="text-3xl font-bold text-white">
                Education & Nonprofits
              </h3>
            </div>
            <p class="text-lg text-gray-400 mb-8">
              GDPR-compliant, self-hosted, unlimited contacts — perfect for
              universities, schools, NGOs, and membership organizations.
            </p>
            <ul class="space-y-4">
              <li class="flex items-center text-gray-300">
                <span
                  class="w-8 h-8 bg-orange-500/20 text-orange-400 rounded-full flex items-center justify-center font-bold mr-3"
                  >✓</span
                >
                Unlimited contacts & sending volume
              </li>
              <li class="flex items-center text-gray-300">
                <span
                  class="w-8 h-8 bg-orange-500/20 text-orange-400 rounded-full flex items-center justify-center font-bold mr-3"
                  >✓</span
                >
                Full data ownership & privacy
              </li>
              <li class="flex items-center text-gray-300">
                <span
                  class="w-8 h-8 bg-orange-500/20 text-orange-400 rounded-full flex items-center justify-center font-bold mr-3"
                  >✓</span
                >
                Free for registered nonprofits
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- Value Proposition Section - Why Choose Laravel Mail -->
  <section class="py-20">
    <!-- Removed bg-white to reveal dark body -->
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-white">
          Why Marketing Teams Choose Our for Marketing Automation
        </h2>
        <p class="text-xl text-gray-300">
          A comprehensive, self-hosted marketing automation solution that gives
          you complete control over your marketing campaigns, customer data, and
          marketing infrastructure without a monthly subscription fees.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <div
          class="bg-white/5 border border-white/10 p-8 rounded-lg hover:bg-white/10 transition-colors duration-300"
        >
          <div
            class="w-12 h-12 bg-brand-primary/20 rounded-lg flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-brand-primary"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
              ></path>
            </svg>
          </div>
          <h3
            class="text-xl font-bold mb-3 text-white"
            title="laravel mail platform data ownership"
          >
            Data Ownership
          </h3>
          <p class="text-gray-400">
            Your customer data stays on your own servers with full GDPR
            compliance. No third-party access, no data sharing, complete privacy
            control for your subscribers and marketing lists.
          </p>
        </div>

        <div
          class="bg-white/5 border border-white/10 p-8 rounded-lg hover:bg-white/10 transition-colors duration-300"
        >
          <div
            class="w-12 h-12 bg-brand-primary/20 rounded-lg flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-brand-primary"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
          </div>
          <h3
            class="text-xl font-bold mb-3 text-white"
            title="laravel mail zero recurring costs"
          >
            Zero Recurring Costs
          </h3>
          <p class="text-gray-400">
            Eliminate expensive monthly subscriptions. Deploy <strong
              >Laravel Mail</strong
            > on your existing infrastructure and scale unlimited contacts, campaigns,
            and email sends without per-contact pricing or hidden fees.
          </p>
        </div>

        <div
          class="bg-white/5 border border-white/10 p-8 rounded-lg hover:bg-white/10 transition-colors duration-300"
        >
          <div
            class="w-12 h-12 bg-brand-primary/20 rounded-lg flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-brand-primary"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
            </svg>
          </div>
          <h3
            class="text-xl font-bold mb-3 text-white"
            title="laravel mail developer friendly architecture"
          >
            Developer-Friendly Architecture
          </h3>
          <p class="text-gray-400">
            Built on Laravel framework with Setup documentation.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Features />

  <HowItWorks />

  <!-- Use Cases Section - Real-World Applications -->
  <section class="py-20 bg-[#0a0e27]/60">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-white">
          Proven <b>Marketing Automation</b> Solutions Across Industries
        </h2>
        <p class="text-xl text-gray-400">
          See how organizations deploy Laravel Mail to power their email
          marketing campaigns, lead nurturing sequences, and customer engagement
          strategies.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <div
          class="bg-[#1e293b]/40 backdrop-blur-md p-8 rounded-lg shadow-sm border border-white/10"
        >
          <h3
            class="text-2xl font-bold mb-4 text-white"
            title="laravel google marketplace integration"
          >
            Google Marketplace Integration
          </h3>
          <p class="text-gray-400 mb-6">
            Deploy and integrate your products to google marketplace
          </p>
          <ul class="space-y-2 text-gray-300">
            <li class="flex items-start">
              <svg
                class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              <span>Automated cart abandonment recovery sequences</span>
            </li>
            <li class="flex items-start">
              <svg
                class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              <span
                >Behavioral product recommendations and upsell campaigns</span
              >
            </li>
            <li class="flex items-start">
              <svg
                class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              <span>Customer lifecycle segmentation and retention programs</span
              >
            </li>
          </ul>
        </div>

        <div
          class="bg-[#1e293b]/40 backdrop-blur-md p-8 rounded-lg shadow-sm border border-white/10"
        >
          <h3 class="text-2xl font-bold mb-4 text-white">
            SaaS Companies & Software Platforms
          </h3>
          <p class="text-gray-400 mb-6">
            Launch onboarding email sequences for new trial users, feature
            announcement campaigns, usage-based triggers for inactive accounts,
            and renewal reminder automation. Track user engagement metrics and
            send targeted messages based on in-app behavior, subscription tier,
            and feature adoption patterns.
          </p>
          <ul class="space-y-2 text-gray-300">
            <li class="flex items-start">
              <svg
                class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              <span>Automated trial-to-paid conversion sequences</span>
            </li>
            <li class="flex items-start">
              <svg
                class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              <span
                >Feature adoption campaigns and product update notifications</span
              >
            </li>
            <li class="flex items-start">
              <svg
                class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              <span>Churn prevention workflows for at-risk subscribers</span>
            </li>
          </ul>
        </div>

        <div
          class="bg-[#1e293b]/40 backdrop-blur-md p-8 rounded-lg shadow-sm border border-white/10"
        >
          <h3 class="text-2xl font-bold mb-4 text-white">
            Marketing Agencies & Consultants
          </h3>
          <p class="text-gray-400 mb-6">
            Manage multiple client campaigns from a single installation with
            workspace separation, white-label email templates, and
            client-specific reporting dashboards. Deploy Laravel Mail on your
            infrastructure and offer email marketing services without paying
            per-client subscription fees to third-party platforms.
          </p>
          <ul class="space-y-2 text-gray-300">
            <li class="flex items-start">
              <svg
                class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              <span
                >Multi-client campaign management and workspace isolation</span
              >
            </li>
            <li class="flex items-start">
              <svg
                class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              <span>White-label email templates and branded sender domains</span
              >
            </li>
            <li class="flex items-start">
              <svg
                class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              <span
                >Client reporting dashboards with campaign performance analytics</span
              >
            </li>
          </ul>
        </div>

        <div
          class="bg-[#1e293b]/40 backdrop-blur-md p-8 rounded-lg shadow-sm border border-white/10"

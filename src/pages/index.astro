---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Partners from '../components/Partners.astro';
import Features from '../components/Features.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Testimonials from '../components/Testimonials.astro';
import CTASection from '../components/CTASection.astro';
import FAQ from '../components/FAQ.astro';
---

<Layout title="Free Open Source Marketing Automation Software in Docker | Laravel Mail" description="Laravel Mail is a free, open-source marketing automation platform with Docker deployment. Self-hosted email marketing, lead management, and campaign automation software trusted by developers worldwide.">
  <Hero />
  <Partners />

  <!-- Stats Section - Social Proof & Trust Signals -->
  <section class="py-16 bg-gradient-to-b from-gray-50 to-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div class="space-y-2">
          <div class="text-4xl md:text-5xl font-bold text-blue-600">50K+</div>
          <div class="text-gray-600">Active Installations</div>
        </div>
        <div class="space-y-2">
          <div class="text-4xl md:text-5xl font-bold text-blue-600">2M+</div>
          <div class="text-gray-600">Emails Sent Daily</div>
        </div>
        <div class="space-y-2">
          <div class="text-4xl md:text-5xl font-bold text-blue-600">100%</div>
          <div class="text-gray-600">Open Source & Free</div>
        </div>
        <div class="space-y-2">
          <div class="text-4xl md:text-5xl font-bold text-blue-600">24/7</div>
          <div class="text-gray-600">Community Support</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Value Proposition Section - Why Choose Laravel Mail -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Why Marketing Teams Choose Laravel Mail for Email Automation</h2>
        <p class="text-xl text-gray-600">A comprehensive, self-hosted marketing automation solution that gives you complete control over your email campaigns, customer data, and marketing infrastructure without monthly subscription fees.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <div class="bg-gray-50 p-8 rounded-lg">
          <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Complete Data Ownership</h3>
          <p class="text-gray-600">Your customer data stays on your own servers with full GDPR compliance. No third-party access, no data sharing, complete privacy control for your subscribers and marketing lists.</p>
        </div>

        <div class="bg-gray-50 p-8 rounded-lg">
          <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Zero Recurring Costs</h3>
          <p class="text-gray-600">Eliminate expensive monthly subscriptions. Deploy Laravel Mail on your existing infrastructure and scale unlimited contacts, campaigns, and email sends without per-contact pricing or hidden fees.</p>
        </div>

        <div class="bg-gray-50 p-8 rounded-lg">
          <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Developer-Friendly Architecture</h3>
          <p class="text-gray-600">Built on Laravel framework with comprehensive API documentation. Extend functionality, create custom integrations, and modify the platform to match your exact business requirements and marketing workflows.</p>
        </div>
      </div>
    </div>
  </section>

  <Features />
  <HowItWorks />

  <!-- Use Cases Section - Real-World Applications -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Proven Marketing Automation Solutions Across Industries</h2>
        <p class="text-xl text-gray-600">See how organizations deploy Laravel Mail to power their email marketing campaigns, lead nurturing sequences, and customer engagement strategies.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <div class="bg-white p-8 rounded-lg shadow-sm border border-gray-100">
          <h3 class="text-2xl font-bold mb-4">E-commerce & Online Retailers</h3>
          <p class="text-gray-600 mb-6">Deploy automated abandoned cart recovery emails, post-purchase follow-up sequences, product recommendation campaigns, and customer win-back automation. Integrate with WooCommerce, Shopify, and Magento to trigger personalized email campaigns based on customer purchase behavior and browsing history.</p>
          <ul class="space-y-2 text-gray-700">
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Automated cart abandonment recovery sequences</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Behavioral product recommendations and upsell campaigns</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Customer lifecycle segmentation and retention programs</span>
            </li>
          </ul>
        </div>

        <div class="bg-white p-8 rounded-lg shadow-sm border border-gray-100">
          <h3 class="text-2xl font-bold mb-4">SaaS Companies & Software Platforms</h3>
          <p class="text-gray-600 mb-6">Launch onboarding email sequences for new trial users, feature announcement campaigns, usage-based triggers for inactive accounts, and renewal reminder automation. Track user engagement metrics and send targeted messages based on in-app behavior, subscription tier, and feature adoption patterns.</p>
          <ul class="space-y-2 text-gray-700">
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Automated trial-to-paid conversion sequences</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Feature adoption campaigns and product update notifications</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Churn prevention workflows for at-risk subscribers</span>
            </li>
          </ul>
        </div>

        <div class="bg-white p-8 rounded-lg shadow-sm border border-gray-100">
          <h3 class="text-2xl font-bold mb-4">Marketing Agencies & Consultants</h3>
          <p class="text-gray-600 mb-6">Manage multiple client campaigns from a single installation with workspace separation, white-label email templates, and client-specific reporting dashboards. Deploy Laravel Mail on your infrastructure and offer email marketing services without paying per-client subscription fees to third-party platforms.</p>
          <ul class="space-y-2 text-gray-700">
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Multi-client campaign management and workspace isolation</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>White-label email templates and branded sender domains</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Client reporting dashboards with campaign performance analytics</span>
            </li>
          </ul>
        </div>

        <div class="bg-white p-8 rounded-lg shadow-sm border border-gray-100">
          <h3 class="text-2xl font-bold mb-4">Educational Institutions & Nonprofits</h3>
          <p class="text-gray-600 mb-6">Communicate with students, alumni, donors, and community members through segmented newsletter campaigns, event registration sequences, fundraising appeals, and volunteer engagement automation. Laravel Mail's self-hosted architecture ensures compliance with educational data privacy regulations.</p>
          <ul class="space-y-2 text-gray-700">
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Student enrollment and alumni engagement campaigns</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Donor cultivation sequences and fundraising appeal workflows</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-500 mr-2 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Event promotion and automated registration confirmations</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <Testimonials />

  <!-- Integration Section - Technical Compatibility -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Seamless Integrations with Your Existing Marketing Technology Stack</h2>
        <p class="text-xl text-gray-600">Laravel Mail connects with popular platforms and services through REST API, webhooks, and native integrations. Deploy on Docker for consistent performance across development, staging, and production environments.</p>
      </div>

      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-3 gap-8 mb-12">
          <div class="text-center">
            <h3 class="font-bold text-lg mb-4">E-commerce Platforms</h3>
            <div class="space-y-3 text-gray-600">
              <p>WooCommerce</p>
              <p>Shopify</p>
              <p>Magento</p>
              <p>PrestaShop</p>
            </div>
          </div>

          <div class="text-center">
            <h3 class="font-bold text-lg mb-4">CRM & Sales Tools</h3>
            <div class="space-y-3 text-gray-600">
              <p>Salesforce</p>
              <p>HubSpot</p>
              <p>Pipedrive</p>
              <p>Zoho CRM</p>
            </div>
          </div>

          <div class="text-center">
            <h3 class="font-bold text-lg mb-4">Payment Processors</h3>
            <div class="space-y-3 text-gray-600">
              <p>Stripe</p>
              <p>PayPal</p>
              <p>Square</p>
              <p>Authorize.net</p>
            </div>
          </div>
        </div>

        <div class="bg-gray-50 p-8 rounded-lg text-center">
          <h3 class="text-xl font-bold mb-4">Technical Infrastructure</h3>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            <div class="space-y-2">
              <div class="font-semibold text-gray-900">Docker</div>
              <div class="text-sm text-gray-600">Containerized deployment</div>
            </div>
            <div class="space-y-2">
              <div class="font-semibold text-gray-900">MySQL/PostgreSQL</div>
              <div class="text-sm text-gray-600">Database support</div>
            </div>
            <div class="space-y-2">
              <div class="font-semibold text-gray-900">Redis</div>
              <div class="text-sm text-gray-600">Queue management</div>
            </div>
            <div class="space-y-2">
              <div class="font-semibold text-gray-900">REST API</div>
              <div class="text-sm text-gray-600">Custom integrations</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FAQ />
  <CTASection />
</Layout>
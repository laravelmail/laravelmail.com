    </section>

    <!-- Stats -->
    <section class="py-16 bg-[#0d1225] border-y border-white/5">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          <div>
            <div class="text-4xl font-black gradient-text mb-1">500+</div>
            <div class="text-gray-500 text-sm">Email Templates</div>
          </div>
          <div>
            <div class="text-4xl font-black gradient-text mb-1">50K+</div>
            <div class="text-gray-500 text-sm">Developers</div>
          </div>
          <div>
            <div class="text-4xl font-black gradient-text mb-1">10M+</div>
            <div class="text-gray-500 text-sm">Emails Sent</div>
          </div>
          <div>
            <div class="text-4xl font-black gradient-text mb-1">99.9%</div>
            <div class="text-gray-500 text-sm">Uptime</div>
          </div>
        </div>

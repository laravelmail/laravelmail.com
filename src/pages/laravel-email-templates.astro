            <div>
              <div class="font-bold">ER</div>
              <div class="text-gray-500 text-sm">Emma Rodriguez</div>
              <div class="text-gray-600 text-xs">Lead Engineer at SaaSify</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing -->

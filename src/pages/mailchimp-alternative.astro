---
import Layout from "../layouts/Layout.astro";
import CTASection from "../components/CTASection.astro";

const title = "Mailchimp Alternative for Developers & Teams | Laravel Mail";
const description = "The best Mailchimp alternative for Laravel developers. No per-contact tax, better deliverability, and full API control. Compare Laravel Mail vs Mailchimp.";
---

<Layout title={title} description={description}>
    <section class="pt-20 pb-16 md:pt-28 md:pb-24 overflow-hidden relative">
        <div class="container-custom relative">
            <div class="max-w-4xl mx-auto text-center">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-brand-primary text-xs font-bold uppercase tracking-widest mb-6">
                    Comparison Guide
                </div>
                <h1 class="text-4xl md:text-5xl lg:text-7xl font-black leading-tight text-white mb-8">
                    The Modern <br/><span class="gradient-text">Mailchimp Alternative</span>
                </h1>
                <p class="text-xl text-gray-300 leading-relaxed mb-10">
                    Stop paying the "subscriber tax." Laravel Mail is the <strong>Mailchimp alternative</strong> built specifically 
                    for developers who value ownership, deliverability, and fair pricing.
                </p>
                <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                    <a href="/buy" class="btn btn-primary px-8 py-4 text-lg">Switch to Laravel Mail</a>
                    <a href="#comparison" class="text-white hover:text-brand-primary transition-colors font-medium">See the Comparison ↓</a>
                </div>
            </div>
        </div>
    </section>

    <section id="comparison" class="py-20 bg-brand-bg/50">
        <div class="container-custom">
            <div class="max-w-4xl mx-auto">
                <h2 class="text-3xl md:text-4xl font-black text-white mb-12 text-center">Why Laravel Mail is the Best Mailchimp Alternative</h2>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
                    <div class="p-8 rounded-2xl bg-white/5 border border-white/10">
                        <h3 class="text-2xl font-bold text-white mb-4">No Monthly "Taxes"</h3>
                        <p class="text-gray-400">
                            Unlike <strong>Mailchimp plans</strong> that increase in price as your list grows, Laravel Mail is self-hosted. 
                            Whether you have 1,000 or 1,000,000 subscribers, your costs remain flat.
                        </p>
                    </div>
                    <div class="p-8 rounded-2xl bg-white/5 border border-white/10">
                        <h3 class="text-2xl font-bold text-white mb-4">Developer-First API</h3>
                        <p class="text-gray-400">
                            We provide a clean, powerful API that integrates natively with your application stack. 
                            No more fighting with bloated <strong>Mailchimp CRM</strong> features you don't need.
                        </p>
                    </div>
                </div>

                <div class="prose prose-invert max-w-none text-gray-300">
                    <h3>Mailchimp vs Laravel Mail: A Quick Look</h3>
                    <div class="overflow-x-auto my-8">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="border-b border-white/10">
                                    <th class="py-4 px-6 font-bold text-white">Feature</th>
                                    <th class="py-4 px-6 font-bold text-white">Mailchimp</th>
                                    <th class="py-4 px-6 font-bold text-brand-primary">Laravel Mail</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="border-b border-white/5">
                                    <td class="py-4 px-6">Pricing</td>
                                    <td class="py-4 px-6 text-red-400">Scaling monthly fees</td>
                                    <td class="py-4 px-6 text-green-400">Flat £10/mo subscription</td>
                                </tr>
                                <tr class="border-b border-white/5">
                                    <td class="py-4 px-6">Data Ownership</td>
                                    <td class="py-4 px-6">Third-party hosted</td>
                                    <td class="py-4 px-6">100% Self-hosted</td>
                                </tr>
                                <tr class="border-b border-white/5">
                                    <td class="py-4 px-6">Deliverability</td>
                                    <td class="py-4 px-6">Shared IP Pools</td>
                                    <td class="py-4 px-6">Dedicated Infrastructure</td>
                                </tr>
                                <tr class="border-b border-white/5">
                                    <td class="py-4 px-6">API Access</td>
                                    <td class="py-4 px-6">Rate-limited</td>
                                    <td class="py-4 px-6">Unlimited local access</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <p>
                        Searching for a <strong>Mailchimp free alternative</strong>? While Mailchimp offers a limited free tier, 
                        the hidden costs of data lock-in and deliverability issues often outweigh the benefits. 
                        Laravel Mail provides a professional-grade <strong>Mailchimp alternative</strong> that scales with your ambition.
                    </p>
                    
                    <h3>Ready for Better Deliverability?</h3>
                    <p>
                        Tired of your emails landing in the Promotions folder? By using a dedicated <strong>Mailchimp alternative</strong> 
                        infrastructure, you can maintain a pristine sender reputation. Our platform's <strong>mailchimp sms</strong> 
                        completions and advanced triggers give you the tools of a giant at the price of a startup.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <CTASection />
</Layout>

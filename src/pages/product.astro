---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import CTASection from "../components/CTASection.astro";
import Integrations from "../components/Integrations.astro";
import PlatformShowcase from "../components/PlatformShowcase.astro";
import dashboardImage from "../assets/dashboard.png";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { getRelativeLocaleUrl } from 'astro:i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const productSchema = {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "Laravel Mail Marketing Platform",
    applicationCategory: "BusinessApplication, MarketingApplication",
    operatingSystem: "Linux, Docker",
    description:
        "Self-hosted marketing platform with Local AI Agents and verified B2B leads database for automated email campaigns and data sovereignty.",
    aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: "4.9",
        ratingCount: "128",
    },
    offers: {
        "@type": "Offer",
        price: "50",
        priceCurrency: "GBP",
    },
    publisher: {
        "@type": "Organization",
        name: "Laravel Mail",
        url: "https://laravelmail.com",
    },
};
---

<Layout
    title={t('product.title')}
    description={t('product.description')}
>
    <!-- Structured Data -->
    <script
        type="application/ld+json"
        set:html={JSON.stringify(productSchema)}
    />

    <!-- Hero Section -->
    <section class="relative pt-20 pb-16 md:pt-32 md:pb-28 overflow-hidden">
        <div class="absolute inset-0 opacity-10">
            <div
                class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_50%_50%,#7c3aed_0%,transparent_50%)]"
            >
            </div>
        </div>

        <div class="container-custom relative z-10">
            <div class="max-w-4xl mx-auto text-center mb-16">
                <h1
                    class="text-5xl md:text-7xl text-white font-extrabold leading-[1.1] tracking-tight animate-on-scroll"
                >
                    {t('product.hero_title_1')}<span class="gradient-text"
                        >{t('product.hero_title_2')}</span
                    >{t('product.hero_title_3')}
                </h1>
                <p
                    class="mt-8 text-xl text-gray-400 leading-relaxed max-w-2xl mx-auto animate-on-scroll delay-1"
                >
                    {t('product.hero_subtitle')}
                </p>
                <div
                    class="mt-10 flex flex-col sm:flex-row gap-5 justify-center animate-on-scroll delay-2"
                >
                    <a
                        href={getRelativeLocaleUrl(lang, "/install")}
                        class="btn btn-primary px-10 py-4 text-lg font-bold shadow-lg shadow-brand-primary/20 hover:scale-[1.02] active:scale-[0.98] transition-all"
                    >
                        {t('product.purchase_btn')}
                    </a>
                </div>
            </div>

            <div class="animate-on-scroll delay-3 relative max-w-5xl mx-auto">
                <div
                    class="absolute -inset-1 bg-gradient-to-r from-brand-primary to-brand-blue rounded-2xl blur opacity-30"
                >
                </div>
                <div
                    class="relative bg-brand-bg-darker rounded-2xl shadow-2xl overflow-hidden border border-white/10"
                >
                    <Image
                        src={dashboardImage}
                        alt="Laravel Mail Marketing Dashboard"
                        class="w-full h-auto"
                        width={1200}
                        height={800}
                    />
                </div>
            </div>
        </div>
    </section>

    <!-- Email Validation API -->
    <section class="py-24 relative overflow-hidden">
        <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-[500px] h-[500px] bg-green-500/5 blur-[120px] rounded-full pointer-events-none"></div>
        <div class="container-custom relative z-10">
            <div class="max-w-5xl mx-auto">
                <div class="text-center mb-16 animate-on-scroll">
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-green-500/10 border border-green-500/20 text-green-400 text-xs font-bold uppercase tracking-widest mb-6">
                        Email Validation API
                    </div>
                    <h2 class="text-4xl md:text-5xl font-black text-white mb-6">
                        Multi-Engine <span class="gradient-text">Email Validation</span>
                    </h2>
                    <p class="text-xl text-gray-400 max-w-3xl mx-auto">
                        Built-in high-intelligence email validation service powered by FastAPI. Combines SMTP verification, Bayesian inference, and LightGBM machine learning for consensus-based deliverability verdicts.
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
                    <div class="bg-brand-bg-card/40 backdrop-blur-md border border-white/10 rounded-2xl p-6 animate-on-scroll">
                        <div class="w-10 h-10 rounded-xl bg-green-500/20 flex items-center justify-center mb-4">
                            <svg class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <h3 class="text-white font-bold text-lg mb-2">7 Verification Engines</h3>
                        <p class="text-gray-400 text-sm">Bloombox, syntax, MX/DNS, disposable detection, SMTP verification, Bayesian inference, and LightGBM ML.</p>
                    </div>
                    <div class="bg-brand-bg-card/40 backdrop-blur-md border border-white/10 rounded-2xl p-6 animate-on-scroll delay-1">
                        <div class="w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center mb-4">
                            <svg class="w-5 h-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        </div>
                        <h3 class="text-white font-bold text-lg mb-2">Hybrid ML Pipeline</h3>
                        <p class="text-gray-400 text-sm">Combines rule-based filtering with LightGBM models trained on live DuckDB telemetry data.</p>
                    </div>
                    <div class="bg-brand-bg-card/40 backdrop-blur-md border border-white/10 rounded-2xl p-6 animate-on-scroll delay-2">
                        <div class="w-10 h-10 rounded-xl bg-purple-500/20 flex items-center justify-center mb-4">
                            <svg class="w-5 h-5 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                        </div>
                        <h3 class="text-white font-bold text-lg mb-2">Simple REST API</h3>
                        <p class="text-gray-400 text-sm">Single endpoint on port 1098. Returns verdict, confidence scores, and full audit trail per validation.</p>
                    </div>
                </div>

                <div class="text-center animate-on-scroll">
                    <a href={getRelativeLocaleUrl(lang, "/validation")} class="btn btn-primary px-8 py-3 font-bold shadow-lg shadow-brand-primary/20 hover:scale-[1.02] active:scale-[0.98] transition-all">
                        Explore Validation API →
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Core Components -->
    <div class="space-y-0">
        <PlatformShowcase />
        <Integrations />
    </div>

    <CTASection />
</Layout>

<style>
    .gradient-text {
        @apply bg-clip-text text-transparent bg-gradient-to-r from-brand-primary to-brand-blue;
    }
</style>

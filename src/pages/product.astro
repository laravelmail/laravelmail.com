    {
        title: "Activity Tracking",
        description:
            "Monitor team performance with detailed analytics on campaign sends, open rates, and engagement metrics per workspace.",
        icon: "📈",
    },
];

const campaignFeatures = [
    {
        title: "Multi-Channel Campaigns",
        description:
            "Orchestrate email sequences, SMS outreach, and social media engagement from a single unified platform.",
        benefit: "3x higher conversion rates",
    },
    {
        title: "Smart Automation",
        description:
            "Trigger-based workflows that respond to prospect behavior, automatically nurturing leads through your sales funnel.",
        benefit: "Save 20+ hours weekly",
    },
    {
        title: "A/B Testing",
        description:
            "Test subject lines, content variations, and send times to optimize every campaign for maximum engagement.",
        benefit: "45% improvement in opens",
    },
    {
        title: "Performance Analytics",
        description:
            "Real-time dashboards showing opens, clicks, replies, and conversions with detailed attribution reporting.",
        benefit: "Data-driven decisions",
    },
];

const validationFeatures = [
    {
        title: "Email Verification",
        description:
            "Real-time email validation checks syntax, domain validity, and mailbox existence to ensure deliverability.",
        accuracy: "99.9%",
    },
    {
        title: "Bulk List Cleaning",
        description:
            "Process thousands of contacts simultaneously, removing invalid, duplicate, and risky email addresses.",
        accuracy: "Process 100K/hour",
    },
    {
        title: "Spam Trap Detection",
        description:
            "Identify and remove known spam traps and honeypots that could damage your sender reputation.",
        accuracy: "Protect your IP",
    },
    {
        title: "Deliverability Scoring",
        description:
            "Assign quality scores to each contact based on engagement history and validation results.",
        accuracy: "Smart prioritization",
    },
];

const intelligenceFeatures = [
    {
        title: "Buyer Intent Signals",
        description:
            "Track prospect research behavior, content consumption, and technology adoption to identify high-intent buyers actively evaluating solutions.",
        metric: "40% faster sales cycles",
    },
    {
        title: "Company Insights",
        description:
            "Access detailed firmographic data including revenue, employee count, funding rounds, technology stack, and growth indicators.",
        metric: "500M+ company profiles",
    },
    {
        title: "Competitive Intelligence",
        description:
            "Monitor when prospects engage with competitor content and identify accounts in active evaluation stages.",
        metric: "Stay ahead of competition",
    },
    {
        title: "Predictive Lead Scoring",
        description:
            "Machine learning models analyze historical conversion data to predict which leads are most likely to convert.",
        metric: "2x win rates",
    },
];

const mailFeatures = [
    {
        title: "Smart Inbox Management",
        description:
            "Unified inbox combining all campaign responses, allowing your team to manage conversations efficiently with collaborative tools.",
        highlight: "Never miss a reply",
    },
    {
        title: "Email Warm-Up",
        description:
            "Automatically warm up new email accounts with gradual sending increases and engagement simulation to build sender reputation.",
        highlight: "99% inbox placement",
    },
    {
        title: "Deliverability Monitoring",
        description:
            "Track sender reputation, spam scores, and blacklist status across all your sending domains with real-time alerts.",
        highlight: "Protect your reputation",
    },
    {
        title: "Email Templates",
        description:
            "Pre-built, conversion-optimized email templates with dynamic personalization fields and mobile-responsive designs.",
        highlight: "Launch in minutes",
    },
];

const reasonsToOrder = [
    {
        title: "KumoMTA",
        description:
            "Message Transfer Agent (MTA) designed for high-performance outbound email functionality, similar to commercial enterprise MTAs.",
        icon: "🚀",
    },
    {
        title: "Mautic",
        description:
            "Free email marketing software, lead management software and more.",
        icon: "📈",
    },
    {
        title: "SMTP compatible",
        description:
            "All marketing application or service with SMTP. Interspaire, Mailwizz, IEM (Internet Email Marketer) and other.",
        icon: "📧",
    },
    {
        title: "Inject Emails by HTTP API",
        description:
            "Text and HTML bodies, custom headers attachments. Easy to automate and integrate.",
        icon: "🔗",
    },
    {
        title: "Hestia Control Panel",
        description:
            "Lightweight and powerful control panel for the modern web",
        icon: "🛠️",
    },
    {
        title: "Verify & Clean Bulk Email Lists",
        description:
            "100% verification during SMTP session. Keep up to date your email database.",
        icon: "🛡️",
    },
    {
        title: "Up to 32 dedicated IPv4",
        description:
            "For each server. Only fresh and clean IPs from our own subnets. Replacement IPs by request.",
        icon: "🌐",
    },
    {
        title: "Automatic IP rotation",
        description:
            "Built-in logic for rotate outgoing IPs and rDNS with HELO name for each message. It helps to keep more positive reputation of IPs.",
        icon: "🔄",
    },
    {
        title: "Full DNS support",
        description:
            "Free nameservers for domain delegation. Automatic creation of all needed records: rDNS (PTR), DKIM, DMARC, SPF, MX, A.",
        icon: "📋",
    },
    {
        title: "MoneyBack",
        description: "100% MoneyBack. Zero questions.",
        icon: "💰",
    },
    {
        title: "IP reputation monitoring",
        description:
            "Hourly checkings in 100+ DNSRBLs. Daily checkings IP reputation (score from 0 to 100) via service senderscore.org.",
        icon: "📊",
    },
    {
        title: "Delisting service",
        description:
            "We are accredited in most of DNSRBLs so we can delist marked IPs quickly. This is free part of our service.",
        icon: "✨",
    },
    {
        title: "FBL integration",
        description: "Automatic tracking Feedback Loop reports from 20+ ESPs.",
        icon: "📥",
    },
    {
        title: "Exim4 MTA",
        description:
            "Maximum performance. Compatible with all SMTP applications and servers.",
        icon: "⚙️",
    },
    {
        title: "POP/IMAP connectivity",
        description:
            "Full mailbox service for manual handling of replies and bounces. Unlimited mailbox count. Roundcube web gui.",
        icon: "📬",
    },
    {
        title: "High speed delivery",
        description:
            "UP to 100 simultaneous outgoing queues. Up to 1M messages per day.",
        icon: "⚡",
    },
    {
        title: "Extended statistic",
        description: "Sents, opens, clicks, bounces.",
        icon: "📈",
    },
    {
        title: "Health monitoring",
        description:
            "Continuous monitoring of server health and performance across 100+ vital metrics. A separate dashboard with tips for improvement.",
        icon: "🩺",
    },
    {
        title: "SLA 99,9%",
        description:
            "If the server did not work more than 45 minutes over the past month - we will refund the money.",
        icon: "💎",
    },
    {
        title: "Server activation in 15 minutes",
        description:
            "And this is with the installation of all the latest updates for the selected operating system.",
        icon: "⏱️",
    },
    {
        title: "14 years experience",
        description:
            "Thousands of tests, comparisons, debugs and optimizations. You will like the result!",
        icon: "🏆",
    },
];

const productSchema = {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "Laravel Mail Marketing Platform",
    applicationCategory: "BusinessApplication, MarketingApplication",
    operatingSystem: "Linux, Docker",
    description:
        "Enterprise-grade self-hosted marketing platform for email automation, lead enrichment, and buyer intelligence.",
    offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "USD",
    },
    publisher: {
        "@type": "Organization",
        name: "Laravel Mail",
        url: "https://laravelmail.com",
    },
};
import dashboardImage from "../assets/dashboard.png";
---

<Layout
    title="Product Features - Laravel Mail | Self-Hosted Marketing Platform"
    description="Explore enterprise-grade features: Real-time lead enrichment, GDPR-compliant automation, high-accuracy email validation, and advanced buyer intent signals. Control your marketing stack with Laravel Mail."
>
    <!-- Structured Data -->
    <script
        type="application/ld+json"
        set:html={JSON.stringify(productSchema)}
    />

    <section class="relative pt-20 pb-16 md:pt-32 md:pb-28 overflow-hidden">
        <!-- Background decorative elements -->
        <div
            class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full pointer-events-none overflow-hidden opacity-50"
        >
            <div
                class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-brand-primary/20 blur-[120px] rounded-full"
            >
            </div>
            <div
                class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-brand-blue/20 blur-[120px] rounded-full"
            >
            </div>
        </div>

        <div class="container-custom relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <div class="animate-on-scroll">
                    <h1
                        class="text-5xl md:text-7xl text-white font-extrabold leading-[1.1] tracking-tight"
                    >
                        Complete <span class="gradient-text">AI Marketing</span> Platform
                    </h1>
                    <p
                        class="mt-8 text-xl text-gray-400 leading-relaxed max-w-lg"
                    >
                        Our platform combines lead enrichment, campaign
                        automation, AI marketing using Ollama, and buyer
                        intelligence in one powerful, unified system.
                    </p>
                    <div class="mt-10 flex flex-col sm:flex-row gap-5">
                        <a
                            href="https://app.laravelmail.com/"
                            class="btn bg-brand-primary text-white px-10 py-4 text-lg font-bold shadow-lg shadow-brand-primary/20 hover:scale-[1.02] active:scale-[0.98] transition-all"
                        >
                            Start Free Trial
                        </a>
                        <a
                            href="https://app.laravelmail.com/docs"
                            class="btn border-brand-primary/30 text-white px-10 py-4 text-lg font-bold hover:bg-brand-primary/10 hover:border-brand-primary/50 transition-all"
                        >
                            View Documentation
                        </a>
                    </div>

                    <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-6">
                        <div class="flex items-center gap-3">
                            <div
                                class="flex-shrink-0 w-10 h-10 bg-green-500/10 rounded-full flex items-center justify-center"
                            >
                                <svg
                                    class="w-5 h-5 text-green-500"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path></svg
                                >
                            </div>
                            <span class="text-sm font-medium text-gray-400"
                                >99.9% Uptime SLA</span
                            >
                        </div>
                        <div class="flex items-center gap-3">
                            <div
                                class="flex-shrink-0 w-10 h-10 bg-blue-500/10 rounded-full flex items-center justify-center"
                            >
                                <svg
                                    class="w-5 h-5 text-blue-500"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                                    ></path></svg
                                >
                            </div>
                            <span class="text-sm font-medium text-gray-400"
                                >SOC 2 Certified</span
                            >
                        </div>
                        <div class="flex items-center gap-3">
                            <div
                                class="flex-shrink-0 w-10 h-10 bg-brand-blue/20 rounded-full flex items-center justify-center text-brand-blue"
                            >
                                <svg
                                    class="w-5 h-5 text-purple-500"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
                                    ></path></svg
                                >
                            </div>
                            <span class="text-sm font-medium text-gray-400"
                                >WhatsApp Ready</span
                            >
                        </div>
                    </div>
                </div>

                <div
                    class="animate-on-scroll lg:ml-auto"
                    style="animation-delay: 0.2s;"
                >
                    <div class="relative group">
                        <div
                            class="absolute -inset-1 bg-gradient-to-r from-brand-primary to-brand-blue rounded-2xl blur opacity-40 group-hover:opacity-60 transition duration-1000 group-hover:duration-200"
                        >
                        </div>
                        <div
                            class="relative bg-brand-bg-darker rounded-2xl shadow-2xl overflow-hidden border border-white/10"
                        >
                            <Image
                                src={dashboardImage}
                                alt="Marketing dashboard showing campaigns analytics"
                                class="w-full h-auto transform group-hover:scale-[1.02] transition-transform duration-500 brightness-90 group-hover:brightness-100"
                                width={600}
                                height={400}
                            />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Workspaces Section -->
    <section class="py-24 bg-brand-bg-darker/60">
        <div class="container-custom">
            <div class="text-center max-w-3xl mx-auto animate-on-scroll">
                <h2
                    class="text-4xl md:text-5xl font-bold tracking-tight text-white"
                >
                    Organize your marketing
                </h2>
                <div
                    class="mt-4 w-24 h-1.5 bg-gradient-to-r from-brand-primary to-brand-blue mx-auto rounded-full"
                >
                </div>
                <p class="mt-6 text-xl text-gray-400 leading-relaxed">
                    Centralize your marketing operations with powerful
                    integrations that scale with your organization.
                </p>
            </div>

            <div class="mt-20 grid grid-cols-1 md:grid-cols-2 gap-8">
                {
                    workspaceFeatures.map((feature, index) => (
                        <div
                            class="group bg-brand-bg-card/40 backdrop-blur-md rounded-2xl p-10 animate-on-scroll shadow-sm hover:shadow-xl transition-all duration-300 border border-white/10 hover:border-brand-primary/30 hover:translate-y-[-4px]"
                            style={`animation-delay: ${index * 0.1}s`}
                        >
                            <div class="text-4xl mb-6 group-hover:scale-110 transition-transform duration-300 inline-block">
                                {feature.icon}
                            </div>
                            <h3 class="text-2xl font-bold mb-4 text-white group-hover:text-brand-blue transition-colors">
                                {feature.title}
                            </h3>
                            <p class="text-gray-400 leading-relaxed text-lg">
                                {feature.description}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Campaigns Section -->
    <section class="py-24 bg-brand-bg-darker overflow-hidden relative">
        <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full pointer-events-none"
        >
            <div
                class="absolute top-0 right-0 w-1/3 h-1/3 bg-brand-blue/10 blur-[100px] rounded-full"
            >
            </div>
            <div
                class="absolute bottom-0 left-0 w-1/3 h-1/3 bg-brand-primary/10 blur-[100px] rounded-full"
            >
            </div>
        </div>

        <div class="container-custom relative z-10">
            <div class="text-center max-w-3xl mx-auto animate-on-scroll">
                <h2
                    class="text-4xl md:text-5xl text-white font-bold tracking-tight"
                >
                    Powerful Campaign Automation
                </h2>
                <div
                    class="mt-4 w-24 h-1.5 bg-gradient-to-r from-brand-primary to-brand-blue mx-auto rounded-full"
                >
                </div>
                <p class="mt-6 text-xl text-gray-400 leading-relaxed">
                    Build sophisticated multi-touch campaigns that nurture leads
                    automatically. From cold outreach to customer retention,
                    automate your entire email marketing funnel.
                </p>
            </div>

            <div class="mt-20 grid grid-cols-1 md:grid-cols-2 gap-8">
                {
                    campaignFeatures.map((feature, index) => (
                        <div
                            class="group bg-brand-bg-card/40 backdrop-blur-md rounded-2xl p-10 animate-on-scroll border border-white/10 hover:border-brand-blue/50 transition-all duration-300 shadow-2xl"
                            style={`animation-delay: ${index * 0.1}s`}
                        >
                            <h3 class="text-2xl font-bold mb-4 text-white group-hover:text-brand-blue transition-colors">
                                {feature.title}
                            </h3>
                            <p class="text-gray-400 mb-8 leading-relaxed text-lg">
                                {feature.description}
                            </p>
                            <div class="inline-flex items-center px-4 py-2 bg-brand-blue/10 rounded-full text-sm font-bold text-brand-blue border border-brand-blue/20">
                                <svg
                                    class="w-4 h-4 mr-2"
                                    fill="currentColor"
                                    viewBox="0 0 20 20"
                                >
                                    <path
                                        fill-rule="evenodd"
                                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                        clip-rule="evenodd"
                                    />
                                </svg>
                                {feature.benefit}
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Email Validation Section -->
    <section class="py-24 bg-brand-bg-darker/40 overflow-hidden">
        <div class="container-custom">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
                <div class="animate-on-scroll">
                    <h2
                        class="text-4xl md:text-5xl font-bold tracking-tight text-white"
                    >
                        <span class="gradient-text">Email Validation</span> That Protects
                        Your Reputation
                    </h2>
                    <p class="mt-6 text-xl text-gray-400 leading-relaxed">
                        Maintain pristine sender reputation with
                        enterprise-grade email validation. Our real-time
                        verification engine checks every contact before sending,
                        ensuring maximum deliverability and protecting your
                        domain reputation.
                    </p>

                    <div class="mt-12 space-y-8">
                        {
                            validationFeatures.map((feature) => (
                                <div class="flex items-start group">
                                    <div class="flex-shrink-0 h-12 w-12 rounded-xl bg-gradient-to-br from-brand-primary to-brand-blue flex items-center justify-center text-white shadow-lg group-hover:scale-110 transition-transform duration-300">
                                        <svg
                                            class="w-6 h-6"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M5 13l4 4L19 7"
                                            />
                                        </svg>
                                    </div>
                                    <div class="ml-6">
                                        <h4 class="text-xl font-bold text-white">
                                            {feature.title}
                                        </h4>
                                        <p class="text-gray-400 mt-2 leading-relaxed">
                                            {feature.description}
                                        </p>
                                        <div class="mt-3 inline-flex items-center text-sm font-bold text-brand-primary uppercase tracking-widest">
                                            <span class="w-2 h-2 bg-brand-primary rounded-full mr-2" />
                                            {feature.accuracy} Accuracy
                                        </div>
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>

                <div
                    class="animate-on-scroll relative"
                    style="animation-delay: 0.2s;"
                >
                    <!-- Glass card decoration -->
                    <div
                        class="absolute -top-10 -right-10 w-40 h-40 bg-leadscaptain-blue/10 blur-3xl rounded-full"
                    >
                    </div>
                    <div
                        class="absolute -bottom-10 -left-10 w-40 h-40 bg-leadscaptain-purple/10 blur-3xl rounded-full"
                    >
                    </div>

                    <div
                        class="relative bg-brand-bg-card/40 backdrop-blur-md rounded-3xl shadow-[0_32px_64px_-16px_rgba(0,0,0,0.1)] p-10 border border-white/10"
                    >
                        <div class="space-y-6">
                            <div
                                class="flex items-center justify-between mb-8 pb-6 border-b border-white/10"
                            >
                                <h3 class="font-bold text-white">
                                    Live Verification
                                </h3>
                                <div
                                    class="px-3 py-1 bg-green-500/10 text-green-400 rounded-full text-xs font-bold uppercase tracking-wider"
                                >
                                    System Active
                                </div>
                            </div>

                            <div
                                class="flex items-center justify-between p-5 bg-green-500/10 rounded-2xl border border-green-500/20 transform hover:scale-[1.02] transition-transform duration-300"
                            >
                                <div class="flex items-center">
                                    <div
                                        class="h-4 w-4 bg-green-500 rounded-full mr-4 shadow-[0_0_12px_rgba(34,197,94,0.5)]"
                                    >
                                    </div>
                                    <span
                                        class="font-mono text-sm text-gray-300 font-medium"
                                        >john@apple.com</span
                                    >
                                </div>
                                <span
                                    class="text-green-400 font-bold text-sm bg-brand-bg-darker/60 px-3 py-1 rounded-lg shadow-sm"
                                    >VALID</span
                                >
                            </div>

                            <div
                                class="flex items-center justify-between p-5 bg-red-500/10 rounded-2xl border border-red-500/20 transform hover:scale-[1.02] transition-transform duration-300"
                            >
                                <div class="flex items-center">
                                    <div
                                        class="h-4 w-4 bg-red-500 rounded-full mr-4 shadow-[0_0_12px_rgba(239,68,68,0.5)]"
                                    >
                                    </div>
                                    <span
                                        class="font-mono text-sm text-gray-300 font-medium"
                                        >info@fake.xyz</span
                                    >
                                </div>
                                <span
                                    class="text-red-400 font-bold text-sm bg-brand-bg-darker/60 px-3 py-1 rounded-lg shadow-sm"
                                    >INVALID</span
                                >

---
import Layout from "../layouts/Layout.astro";
import CTASection from "../components/CTASection.astro";
import UseCases from "../components/UseCases.astro";
import Testimonials from "../components/Testimonials.astro";
import PlatformShowcase from "../components/PlatformShowcase.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const solutions = [
    {
        title: t('solutions.ecommerce_title'),
        description: t('solutions.ecommerce_desc'),
        icon: "🛍️",
    },
    {
        title: t('solutions.saas_title'),
        description: t('solutions.saas_desc'),
        icon: "💻",
    },
    {
        title: t('solutions.agencies_title'),
        description: t('solutions.agencies_desc'),
        icon: "🏢",
    },
];
---

<Layout
    title={t('solutions.title')}
    description={t('solutions.description')}
>
    <!-- Header -->
    <section
        class="pt-20 pb-16 md:pt-32 md:pb-24 bg-brand-bg-darker relative overflow-hidden"
    >
        <div class="absolute inset-0 opacity-5">
            <div
                class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-brand-primary to-transparent"
            >
            </div>
        </div>

        <div class="container-custom relative">
            <div class="text-center max-w-4xl mx-auto">
                <h1
                    class="animate-on-scroll delay-0 text-5xl md:text-7xl font-extrabold leading-tight text-white mb-8"
                >
                    {t('solutions.hero_1')}<span class="gradient-text">{t('solutions.hero_2')}</span>{t('solutions.hero_3')}
                </h1>
                <p
                    class="animate-on-scroll delay-1 mt-6 text-xl text-gray-400 max-w-2xl mx-auto"
                >
                    {t('solutions.hero_subtitle')}
                </p>
            </div>
        </div>
    </section>

    <!-- Industry Grid -->
    <section class="py-24 bg-brand-bg-darker/40">
        <div class="container-custom">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                {
                    solutions.map((solution, index) => (
                        <div
                            class={`bg-brand-bg-card/40 backdrop-blur-md rounded-2xl p-10 shadow-lg border border-white/10 animate-on-scroll delay-${index + 2} hover:border-brand-primary/30 transition-all`}
                        >
                            <div class="text-5xl mb-6">{solution.icon}</div>
                            <h3 class="text-2xl font-bold text-white mb-4">
                                {solution.title}
                            </h3>
                            <p class="text-gray-400 leading-relaxed">
                                {solution.description}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Products Showcase -->
    <main id="main-content" class="flex-grow">
        <section class="pb-20 relative overflow-hidden">
            <div class="absolute top-20 left-1/4 w-[500px] h-[500px] bg-primary/10 blur-[150px] rounded-full -z-10"></div>
            <div class="absolute bottom-20 right-1/4 w-[400px] h-[400px] bg-indigo-600/10 blur-[120px] rounded-full -z-10"></div>
            <div class="mx-auto max-w-7xl w-full px-5 sm:px-8 md:px-14 lg:px-5">
                <div class="text-center max-w-4xl mx-auto">
                    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-gray-100 dark:border-gray-800 backdrop-blur-sm mb-8">
                        <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
                        <span class="text-sm font-semibold text-heading-3">Premium Laravel Solutions</span>
                    </div>
                    <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-heading-1 leading-tight mb-6">
                        Powerful <span class="text-transparent bg-clip-text bg-gradient-to-br from-indigo-600 from-20% via-primary via-30% to-green-600"> Software </span> for Modern Businesses
                    </h1>
                    <p class="md:text-lg text-heading-3 text-xl md:text-2xl leading-relaxed max-w-3xl mx-auto mb-10">
                        Self-hosted Laravel packages that give you complete control. No subscriptions, no SaaS lock-in. One-time purchase, lifetime access.
                    </p>
                    <div class="flex flex-wrap justify-center gap-8 text-xs md:text-sm text-heading-3 font-bold uppercase tracking-widest">
                        <span class="flex items-center gap-2">
                            <svg class="w-5 h-5 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                            </svg>
                            One-Time Purchase
                        </span>
                        <span class="flex items-center gap-2">
                            <svg class="w-5 h-5 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                            </svg>
                            Lifetime Updates
                        </span>
                        <span class="flex items-center gap-2">
                            <svg class="w-5 h-5 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                            </svg>
                            Priority Support
                        </span>
                    </div>
                </div>

                <div class="mt-20 space-y-16">
                    <!-- Laravel Social -->
                    <div class="group relative p-8 md:p-12 rounded-3xl bg-white dark:bg-white/5 border border-gray-100 dark:border-gray-800 transition-all duration-500 hover:shadow-2xl overflow-hidden">
                        <div class="absolute -right-20 -top-20 w-64 h-64 bg-gradient-to-br opacity-5 blur-3xl group-hover:opacity-10 transition-opacity"></div>
                        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10">
                            <div class="lg:col-span-5">
                                <div class="relative">
                                    <div class="absolute inset-0 bg-gradient-to-br from-primary to-indigo-800 rounded-2xl blur-xl opacity-20 group-hover:opacity-40 transition-opacity"></div>
                                    <div class="relative h-64 bg-gradient-to-br from-primary to-indigo-800 rounded-2xl flex items-center justify-center text-white shadow-xl group-hover:scale-[1.02] transition-transform duration-500">
                                        <div class="text-center">
                                            <span class="text-6xl font-bold opacity-20 absolute inset-0 flex items-center justify-center whitespace-nowrap overflow-hidden leading-none select-none"> Laravel Social </span>
                                            <h3 class="text-2xl font-black relative z-10">Laravel Social</h3>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="lg:col-span-7">
                                <div class="flex items-center gap-4 mb-6">
                                    <div class="h-12 w-12 rounded-xl bg-gradient-to-br from-primary to-indigo-800 flex items-center justify-center shadow-lg shadow-indigo-500/20">
                                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v8M8 12h8"></path>
                                        </svg>
                                    </div>
                                    <h2 class="text-3xl font-black text-heading-1">Laravel Social</h2>
                                </div>
                                <p class="md:text-lg text-heading-3 text-lg leading-relaxed mb-8">The ultimate social media scheduler for Laravel. Automate your presence across Facebook, Instagram, Twitter, LinkedIn, and more with AI-powered content generation.</p>
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-10">
                                    <div class="flex items-start gap-3">
                                        <div class="w-5 h-5 rounded-full bg-emerald-500/10 flex items-center justify-center mt-1">
                                            <svg class="w-3 h-3 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                                            </svg>
                                        </div>
                                        <div>
                                            <span class="text-heading-1 font-bold block text-sm">Multi-Platform</span>
                                            <span class="text-heading-3 text-xs">Post to 6+ social networks</span>
                                        </div>
                                    </div>
                                    <div class="flex items-start gap-3">
                                        <div class="w-5 h-5 rounded-full bg-emerald-500/10 flex items-center justify-center mt-1">
                                            <svg class="w-3 h-3 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                                            </svg>
                                        </div>
                                        <div>
                                            <span class="text-heading-1 font-bold block text-sm">AI Content</span>
                                            <span class="text-heading-3 text-xs">Generate posts with GPT-4</span>
                                        </div>
                                    </div>
                                    <div class="flex items-start gap-3">
                                        <div class="w-5 h-5 rounded-full bg-emerald-500/10 flex items-center justify-center mt-1">
                                            <svg class="w-3 h-3 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                                            </svg>
                                        </div>
                                        <div>
                                            <span class="text-heading-1 font-bold block text-sm">Visual Calendar</span>
                                            <span class="text-heading-3 text-xs">Manage your social schedule</span>
                                        </div>
                                    </div>
                                    <div class="flex items-start gap-3">
                                        <div class="w-5 h-5 rounded-full bg-emerald-500/10 flex items-center justify-center mt-1">
                                            <svg class="w-3 h-3 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                                            </svg>
                                        </div>
                                        <div>
                                            <span class="text-heading-1 font-bold block text-sm">Analytics</span>
                                            <span class="text-heading-3 text-xs">Track engagement and growth</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="flex flex-wrap items-center gap-6">
                                    <a href="https://laravelsocial.com" target="_blank" class="px-8 py-3 bg-primary text-white font-bold rounded-xl hover:bg-primary/90 transition shadow-lg flex items-center gap-2 group/btn">
                                        Learn More
                                        <svg class="w-5 h-5 group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                                        </svg>
                                    </a>
                                    <span class="text-heading-3 font-semibold text-sm flex items-center gap-2">
                                        <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
                                        </svg>
                                        laravelsocial.com
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Laravel Mail -->
                    <div class="group relative p-8 md:p-12 rounded-3xl bg-white dark:bg-white/5 border border-gray-100 dark:border-gray-800 transition-all duration-500 hover:shadow-2xl overflow-hidden">
                        <div class="absolute -right-20 -top-20 w-64 h-64 bg-gradient-to-br opacity-5 blur-3xl group-hover:opacity-10 transition-opacity"></div>
                        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10">
                            <div class="lg:col-span-5 lg:order-2">
                                <div class="relative">
                                    <div class="absolute inset-0 bg-gradient-to-br from-violet-600 to-violet-800 rounded-2xl blur-xl opacity-20 group-hover:opacity-40 transition-opacity"></div>
                                    <div class="relative h-64 bg-gradient-to-br from-violet-600 to-violet-800 rounded-2xl flex items-center justify-center text-white shadow-xl group-hover:scale-[1.02] transition-transform duration-500">
                                        <div class="text-center">
                                            <span class="text-6xl font-bold opacity-20 absolute inset-0 flex items-center justify-center whitespace-nowrap overflow-hidden leading-none select-none"> Laravel Mail </span>
                                            <h3 class="text-2xl font-black relative z-10">Laravel Mail</h3>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="lg:col-span-7 lg:order-1">
                                <div class="flex items-center gap-4 mb-6">
                                    <div class="h-12 w-12 rounded-xl bg-gradient-to-br from-violet-600 to-violet-800 flex items-center justify-center shadow-lg shadow-indigo-500/20">
                                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v8M8 12h8"></path>
                                        </svg>
                                    </div>
                                    <h2 class="text-3xl font-black text-heading-1">Laravel Mail</h2>
                                </div>
                                <p class="md:text-lg text-heading-3 text-lg leading-relaxed mb-8">A comprehensive email marketing and automation platform built for Laravel. Send beautiful campaigns, manage subscriber lists, and track performance with real-time analytics.</p>
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-10">
                                    <div class="flex items-start gap-3">
                                        <div class="w-5 h-5 rounded-full bg-emerald-500/10 flex items-center justify-center mt-1">
                                            <svg class="w-3 h-3 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                                            </svg>
                                        </div>
                                        <div>
                                            <span class="text-heading-1 font-bold block text-sm">Drag & Drop Editor</span>
                                            <span class="text-heading-3 text-xs">Create stunning emails without code</span>
                                        </div>
                                    </div>
                                    <div class="flex items-start gap-3">
                                        <div class="w-5 h-5 rounded-full bg-emerald-500/10 flex items-center justify-center mt-1">
                                            <svg class="w-3 h-3 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                                            </svg>
                                        </div>
                                        <div>
                                            <span class="text-heading-1 font-bold block text-sm">Smart Segmentation</span>
                                            <span class="text-heading-3 text-xs">Target the right audience</span>
                                        </div>
                                    </div>
                                    <div class="flex items-start gap-3">
                                        <div class="w-5 h-5 rounded-full bg-emerald-500/10 flex items-center justify-center mt-1">
                                            <svg class="w-3 h-3 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                                            </svg>
                                        </div>
                                        <div>
                                            <span class="text-heading-1 font-bold block text-sm">Advanced Analytics</span>
                                            <span class="text-heading-3 text-xs">Open, click, and conversion tracking</span>
                                        </div>
                                    </div>
                                    <div class="flex items-start gap-3">
                                        <div class="w-5 h-5 rounded-full bg-emerald-500/10 flex items-center justify-center mt-1">
                                            <svg class="w-3 h-3 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                                            </svg>
                                        </div>
                                        <div>
                                            <span class="text-heading-1 font-bold block text-sm">Automation Flows</span>
                                            <span class="text-heading-3 text-xs">Welcome and nurture sequences</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="flex flex-wrap items-center gap-6">
                                    <a href="/" class="px-8 py-3 bg-primary text-white font-bold rounded-xl hover:bg-primary/90 transition shadow-lg flex items-center gap-2 group/btn">
                                        Learn More
                                        <svg class="w-5 h-5 group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                                        </svg>
                                    </a>
                                    <span class="text-heading-3 font-semibold text-sm flex items-center gap-2">
                                        <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
                                        </svg>
                                        laravelmail.com
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Laravel SEO -->
                    <div class="group relative p-8 md:p-12 rounded-3xl bg-white dark:bg-white/5 border border-gray-100 dark:border-gray-800 transition-all duration-500 hover:shadow-2xl overflow-hidden">
                        <div class="absolute -right-20 -top-20 w-64 h-64 bg-gradient-to-br opacity-5 blur-3xl group-hover:opacity-10 transition-opacity"></div>
                        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10">
                            <div class="lg:col-span-5">
                                <div class="relative">
                                    <div class="absolute inset-0 bg-gradient-to-br from-pink-600 to-pink-800 rounded-2xl blur-xl opacity-20 group-hover:opacity-40 transition-opacity"></div>
                                    <div class="relative h-64 bg-gradient-to-br from-pink-600 to-pink-800 rounded-2xl flex items-center justify-center text-white shadow-xl group-hover:scale-[1.02] transition-transform duration-500">
                                        <div class="text-center">
                                            <span class="text-6xl font-bold opacity-20 absolute inset-0 flex items-center justify-center whitespace-nowrap overflow-hidden leading-none select-none"> Laravel SEO </span>
                                            <h3 class="text-2xl font-black relative z-10">Laravel SEO</h3>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="lg:col-span-7">
                                <div class="flex items-center gap-4 mb-6">
                                    <div class="h-12 w-12 rounded-xl bg-gradient-to-br from-pink-600 to-pink-800 flex items-center justify-center shadow-lg shadow-indigo-500/20">
                                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v8M8 12h8"></path>
                                        </svg>
                                    </div>
                                    <h2 class="text-3xl font-black text-heading-1">Laravel SEO</h2>
                                </div>
                                <p class="md:text-lg text-heading-3 text-lg leading-relaxed mb-8">The ultimate SEO toolkit for Laravel applications. Boost your search rankings with automated meta tags, dynamic sitemaps, structured data markup, and powerful analytics.</p>
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-10">
                                    <div class="flex items-start gap-3">
                                        <div class="w-5 h-5 rounded-full bg-emerald-500/10 flex items-center justify-center mt-1">
                                            <svg class="w-3 h-3 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                                            </svg>
                                        </div>
                                        <div>
                                            <span class="text-heading-1 font-bold block text-sm">Dynamic Meta Tags</span>
                                            <span class="text-heading-3 text-xs">Auto-generate optimized tags</span>
                                        </div>
                                    </div>
                                    <div class="flex items-start gap-3">
                                        <div class="w-5 h-5 rounded-full bg-emerald-500/10 flex items-center justify-center mt-1">
                                            <svg class="w-3 h-3 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                                            </svg>
                                        </div>
                                        <div>
                                            <span class="text-heading-1 font-bold block text-sm">Smart Sitemaps</span>
                                            <span class="text-heading-3 text-xs">XML sitemaps with auto-updates</span>
                                        </div>
                                    </div>
                                    <div class="flex items-start gap-3">
                                        <div class="w-5 h-5 rounded-full bg-emerald-500/10 flex items-center justify-center mt-1">
                                            <svg class="w-3 h-3 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                                            </svg>
                                        </div>
                                        <div>
                                            <span class="text-heading-1 font-bold block text-sm">Schema Markup</span>
                                            <span class="text-heading-3 text-xs">JSON-LD structured data made easy</span>
                                        </div>
                                    </div>

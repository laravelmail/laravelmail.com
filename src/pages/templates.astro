---
import Layout from "../layouts/Layout.astro";

interface Template {
    name: string;
    thumbnail_url?: string;
    category?: string;
    description?: string;
}

// Fetch templates from the API
let templatesData: Template[] | null = null;
let error: string | null = null;

try {
    const response = await fetch(
        "https://app.laravelmail.com/api/v1/templates",
    );
    if (!response.ok) {
        throw new Error("Failed to fetch templates");
    }
    const json = await response.json();
    templatesData = json.data;
} catch (e: any) {
    error = e.message;
    console.error(e);
}
---

<Layout title="Email Templates - Laravel Mail">
    <main class="min-h-screen pt-24 pb-16 bg-brand-bg-darker">
        <div class="container-custom">
            <div class="max-w-4xl mx-auto text-center mb-16 animate-on-scroll">
                <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">
                    Premium Email Templates
                </h1>
                <p class="text-xl text-gray-400">
                    Professional, responsive, and conversion-optimized email
                    templates for your Laravel Mail campaigns.
                </p>
            </div>

            {
                error ? (
                    <div class="max-w-2xl mx-auto p-8 bg-red-500/10 border border-red-500/20 rounded-2xl text-center">
                        <p class="text-red-400 font-semibold">
                            Error loading templates: {error}
                        </p>
                        <p class="mt-2 text-gray-400">
                            Please try again later.
                        </p>
                    </div>
                ) : (
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        {templatesData &&
                            templatesData.map((template) => (
                                <div class="group bg-brand-bg-card/40 backdrop-blur-md rounded-2xl border border-white/10 overflow-hidden hover:border-brand-primary/50 transition-all duration-500 hover:-translate-y-2">
                                    <div class="aspect-video relative overflow-hidden bg-gray-900/50">
                                        <img
                                            src={
                                                template.thumbnail_url ||
                                                "/placeholder-template.png"
                                            }
                                            alt={template.name}
                                            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                                        />
                                        <div class="absolute inset-0 bg-gradient-to-t from-gray-900 to-transparent opacity-60" />
                                    </div>
                                    <div class="p-6">
                                        <div class="flex justify-between items-start mb-4">
                                            <h3 class="text-xl font-bold text-white group-hover:text-brand-primary transition-colors">
                                                {template.name}
                                            </h3>
                                            <span class="px-2 py-1 bg-brand-primary/20 text-brand-primary text-xs font-bold rounded uppercase tracking-wider">
                                                {template.category || "Basic"}
                                            </span>
                                        </div>
                                        <p class="text-gray-400 text-sm mb-6 line-clamp-2">
                                            {template.description ||
                                                "A beautiful and responsive template designed for high engagement."}
                                        </p>
                                        <div class="flex items-center justify-between">
                                            <a
                                                href={`https://app.laravelmail.com/register`}
                                                class="inline-flex items-center text-brand-primary font-bold hover:underline group-hover:translate-x-1 transition-transform"
                                            >
                                                Use Template
                                                <svg
                                                    class="w-4 h-4 ml-2"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    viewBox="0 0 24 24"
                                                >
                                                    <path
                                                        stroke-linecap="round"
                                                        stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M17 8l4 4m0 0l-4 4m4-4H3"
                                                    />
                                                </svg>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            ))}
                    </div>
                )
            }
        </div>
    </main>
</Layout>

<style>
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

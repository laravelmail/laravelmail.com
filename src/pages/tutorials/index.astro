---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Tutorials | Laravel Mail Platform">
    <main>
        <!-- Hero Section -->
        <section class="pt-20 pb-16 md:pt-28 md:pb-24 overflow-hidden">
            <div class="container-custom">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                    <div>
                        <h1 class="animate-on-scroll delay-0 text-4xl md:text-5xl lg:text-6xl font-bold leading-tight">
                            Learn with <span class="gradient-text">LeadsCaptain</span>
                        </h1>
                        <p class="animate-on-scroll delay-1 mt-6 text-xl text-gray-600 max-w-lg">
                            Step-by-step guides to help you integrate our enrichment APIs, sync with CRMs, and scale your sales data infrastructure.
                        </p>
                        <div class="animate-on-scroll delay-2 mt-8">
                            <a href="/" class="btn btn-primary">View Tutorials</a>
                        </div>
                    </div>
                    <div class="animate-on-scroll delay-3">
                        <div class="relative">
                            <div class="absolute -inset-0.5 bg-gradient-to-r from-leadscaptain-purple to-leadscaptain-blue rounded-xl blur opacity-30"></div>
                            <div class="relative bg-white rounded-xl shadow-xl overflow-hidden p-8">
                                <div class="space-y-6">
                                    <div class="flex items-center gap-4">
                                        <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center">
                                            <svg class="w-6 h-6 text-leadscaptain-purple" viewBox="0 0 24 24" fill="none">
                                                <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                            </svg>
                                        </div>
                                        <div>
                                            <h3 class="font-semibold text-gray-900">Documentation</h3>
                                            <p class="text-gray-600">Comprehensive guides</p>
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-4">
                                        <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
                                            <svg class="w-6 h-6 text-leadscaptain-blue" viewBox="0 0 24 24" fill="none">
                                                <path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                            </svg>
                                        </div>
                                        <div>
                                            <h3 class="font-semibold text-gray-900">API Reference</h3>
                                            <p class="text-gray-600">Detailed API docs</p>
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-4">
                                        <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center">
                                            <svg class="w-6 h-6 text-leadscaptain-purple" viewBox="0 0 24 24" fill="none">
                                                <path d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                            </svg>
                                        </div>
                                        <div>
                                            <h3 class="font-semibold text-gray-900">Quick Start</h3>
                                            <p class="text-gray-600">Get up and running</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Getting Started Section -->
        <section class="section bg-gray-50">
            <div class="container-custom">
                <h2 class="animate-on-scroll delay-0 text-3xl md:text-4xl font-bold text-center mb-16">
                    Getting <span class="gradient-text">Started</span>
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <div class="animate-on-scroll delay-1 feature-card">
                        <h3 class="text-xl font-semibold mb-3">Quick Start Guide</h3>
                        <p class="text-gray-600">Enrich your first 100 leads in under 15 minutes.</p>
                        <a href="/" class="mt-4 inline-block text-leadscaptain-purple hover:text-leadscaptain-blue">
                            Learn more →
                        </a>
                    </div>

                    <div class="animate-on-scroll delay-2 feature-card">
                        <h3 class="text-xl font-semibold mb-3">CRM Setup</h3>
                        <p class="text-gray-600">Connect Salesforce, HubSpot, or your CRM for real-time sync.</p>
                        <a href="/" class="mt-4 inline-block text-leadscaptain-purple hover:text-leadscaptain-blue">
                            Learn more →
                        </a>
                    </div>

                    <div class="animate-on-scroll delay-3 feature-card">
                        <h3 class="text-xl font-semibold mb-3">API Integration</h3>
                        <p class="text-gray-600">Integrate LeadsCaptain API to auto-enrich and verify leads.</p>
                        <a href="/" class="mt-4 inline-block text-leadscaptain-purple hover:text-leadscaptain-blue">
                            Learn more →
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Popular Tutorials -->
        <section id="popular-tutorials" class="section">
            <div class="container-custom">
                <h2 class="animate-on-scroll delay-0 text-3xl md:text-4xl font-bold text-center mb-16">
                    Popular <span class="gradient-text">Tutorials</span>
                </h2>
                <div class="space-y-6">
                    <div class="animate-on-scroll delay-1 feature-card">
                        <h3 class="text-xl font-semibold mb-2">Enrich Your First Lead</h3>
                        <p class="text-gray-600 text-lg mb-4">Step-by-step guide to enrich and verify your first B2B contact.</p>
                        <a href="/" class="text-leadscaptain-purple hover:text-leadscaptain-blue">Read tutorial →</a>
                    </div>

                    <div class="animate-on-scroll delay-2 feature-card">
                        <h3 class="text-xl font-semibold mb-2">Syncing Leads with HubSpot</h3>
                        <p class="text-gray-600 text-lg mb-4">How to integrate LeadsCaptain with HubSpot for real-time enrichment.</p>
                        <a href="/" class="text-leadscaptain-purple hover:text-leadscaptain-blue">Read tutorial →</a>
                    </div>

                    <div class="animate-on-scroll delay-3 feature-card">
                        <h3 class="text-xl font-semibold mb-2">Real-Time Verification Workflow</h3>
                        <p class="text-gray-600 text-lg mb-4">Build a workflow that validates lead data as soon as it enters your CRM.</p>
                        <a href="/" class="text-leadscaptain-purple hover:text-leadscaptain-blue">Read tutorial →</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Categories -->
        <section class="section bg-gray-50">
            <div class="container-custom">
                <h2 class="animate-on-scroll delay-0 text-3xl md:text-4xl font-bold text-center mb-16">
                    Browse by <span class="gradient-text">Category</span>
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <a href="/" title="free lead enrichment" class="feature-card">Lead Enrichment</a>
                    <a href="/" title="free lead cms integrations" class="feature-card">CRM Integrations</a>
                    <a href="/" class="feature-card">Data Accuracy & Compliance</a>
                    <a href="/" class="feature-card">Reporting & Analytics</a>
                    <a href="/" class="feature-card">Security & Privacy</a>
                    <a href="/" class="feature-card">Developer Guides</a>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="py-20 bg-gradient-to-r from-payflo-purple to-payflo-blue text-white relative overflow-hidden">
            <!-- Animated background elements -->
            <div class="absolute inset-0 overflow-hidden opacity-10">
                <div class="absolute -top-40 -left-40 w-80 h-80 bg-white rounded-full blur-3xl animate-pulse"></div>
                <div class="absolute top-40 -right-20 w-60 h-60 bg-white rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
                <div class="absolute -bottom-40 left-1/3 w-80 h-80 bg-white rounded-full blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
            </div>
            <div class="container-custom text-center">
                <h2 class="text-3xl md:text-4xl font-bold text-white mb-8">Need Help?</h2>
                <p class="text-xl text-white/90 mb-10 max-w-2xl mx-auto">
                    Can't find what you're looking for? Our support & sales teams are here to help you get the most out of LeadsCaptain.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a href="/contact" title="buy b2b leads cheap" class="btn bg-white text-payflo-purple hover:bg-opacity-90 transform transition-all duration-300 hover:scale-105 hover:shadow-lg">Contact Support</a>
                    <a href="/contact" title="free b2b leads" class="btn bg-transparent border-2 border-white hover:bg-white/10">Talk to Sales</a>
                </div>
            </div>
        </section>
    </main>
</Layout>
